<p style="font-size: 16px; color: #374151;">Hi <%= @user.first_name %>,</p>

<p style="font-size: 14px; color: #6b7280; line-height: 1.6;">
  Welcome to <strong style="color: #2563eb;">RezumFit Pro</strong>! Your subscription is now active and you have unlimited access to all features.
</p>

<table width="100%" cellpadding="0" cellspacing="0" style="margin: 24px 0; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden;">
  <tr>
    <td style="padding: 12px 16px; background: #f9fafb; border-bottom: 1px solid #e5e7eb;">
      <span style="font-size: 13px; color: #6b7280;">Plan</span>
    </td>
    <td style="padding: 12px 16px; background: #f9fafb; border-bottom: 1px solid #e5e7eb; text-align: right;">
      <span style="font-size: 13px; font-weight: 600; color: #374151;"><%= @subscription.plan_name %></span>
    </td>
  </tr>
  <tr>
    <td style="padding: 12px 16px; border-bottom: 1px solid #e5e7eb;">
      <span style="font-size: 13px; color: #6b7280;">Status</span>
    </td>
    <td style="padding: 12px 16px; border-bottom: 1px solid #e5e7eb; text-align: right;">
      <span style="font-size: 13px; font-weight: 600; color: #16a34a;">Active</span>
    </td>
  </tr>
  <tr>
    <td style="padding: 12px 16px;">
      <span style="font-size: 13px; color: #6b7280;">Next Billing</span>
    </td>
    <td style="padding: 12px 16px; text-align: right;">
      <span style="font-size: 13px; font-weight: 600; color: #374151;"><%= @subscription.current_period_end&.strftime("%B %d, %Y") || "—" %></span>
    </td>
  </tr>
</table>

<p style="font-size: 14px; color: #374151; font-weight: 600;">What you get with Pro:</p>

<table width="100%" cellpadding="0" cellspacing="0" style="margin: 16px 0;">
  <tr>
    <td style="padding: 6px 0;">
      <span style="color: #16a34a; font-size: 14px;">&#10003;</span>
      <span style="font-size: 13px; color: #6b7280; padding-left: 8px;">Unlimited resume optimizations</span>
    </td>
  </tr>
  <tr>
    <td style="padding: 6px 0;">
      <span style="color: #16a34a; font-size: 14px;">&#10003;</span>
      <span style="font-size: 13px; color: #6b7280; padding-left: 8px;">AI-powered cover letters</span>
    </td>
  </tr>
  <tr>
    <td style="padding: 6px 0;">
      <span style="color: #16a34a; font-size: 14px;">&#10003;</span>
      <span style="font-size: 13px; color: #6b7280; padding-left: 8px;">ATS score analysis</span>
    </td>
  </tr>
  <tr>
    <td style="padding: 6px 0;">
      <span style="color: #16a34a; font-size: 14px;">&#10003;</span>
      <span style="font-size: 13px; color: #6b7280; padding-left: 8px;">Priority support</span>
    </td>
  </tr>
</table>

<div style="text-align: center; margin: 32px 0 16px;">
  <a href="<%= dashboard_url %>" style="background: linear-gradient(135deg, #2563eb, #7c3aed); color: #ffffff; padding: 12px 32px; text-decoration: none; border-radius: 8px; font-size: 14px; font-weight: 600; display: inline-block;">
    Go to Dashboard
  </a>
</div>
