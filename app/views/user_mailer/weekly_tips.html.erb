<% tips = [
  { title: "5 ATS Hacks That Actually Work", body: "Most resumes get rejected by ATS before a human ever sees them. Here are 5 proven tricks: (1) Use standard section headings, (2) Include exact keywords from the job posting, (3) Avoid tables and graphics, (4) Use a single-column layout, (5) Save as PDF unless told otherwise." },
  { title: "The #1 Resume Mistake", body: "The biggest mistake? Writing a generic resume for every job. Recruiters spend 6-7 seconds scanning your resume. If it doesn't match the specific role, it goes in the reject pile. ReZum tailors your resume for each application automatically." },
  { title: "Cover Letters That Get Interviews", body: "A great cover letter does 3 things: (1) Shows you understand the company's problems, (2) Proves you can solve them with specific examples, (3) Ends with a clear call to action. ReZum generates cover letters that hit all three." },
  { title: "Keywords That Make Recruiters Notice", body: "Recruiters search for specific keywords. Include the exact job title, required technologies, industry terms, and soft skills mentioned in the posting. ReZum's keyword extraction identifies the most important ones automatically." },
  { title: "How Top Candidates Optimize Their Search", body: "Top performers apply to fewer jobs but with better-tailored materials. They research each company, customize their resume, write targeted cover letters, and follow up systematically. ReZum handles the first three — you handle the follow-up." }
] %>
<% tip = tips[@tip_number % tips.length] %>

<div style="max-width: 600px; margin: 0 auto; font-family: 'Helvetica Neue', Arial, sans-serif;">
  <div style="background: linear-gradient(135deg, #2563eb, #7c3aed); padding: 32px; text-align: center; border-radius: 12px 12px 0 0;">
    <p style="color: rgba(255,255,255,0.8); margin: 0 0 4px; font-size: 12px; text-transform: uppercase; letter-spacing: 1px;">Weekly Career Tip</p>
    <h1 style="color: white; margin: 0; font-size: 22px;"><%= tip[:title] %></h1>
  </div>

  <div style="background: white; padding: 32px; border: 1px solid #e5e7eb; border-top: none;">
    <p style="font-size: 16px; color: #374151;">Hi <%= @user.first_name %>,</p>

    <p style="font-size: 14px; color: #6b7280; line-height: 1.8;">
      <%= tip[:body] %>
    </p>

    <div style="text-align: center; margin: 32px 0;">
      <a href="<%= dashboard_url %>" style="background: linear-gradient(135deg, #2563eb, #7c3aed); color: white; padding: 12px 32px; text-decoration: none; border-radius: 8px; font-size: 14px; font-weight: 600; display: inline-block;">
        Optimize Your Resume Now
      </a>
    </div>
  </div>

  <div style="text-align: center; padding: 16px; font-size: 12px; color: #9ca3af;">
    <p><a href="<%= unsubscribe_url(email: @user.email, token: @user.referral_code) %>" style="color: #9ca3af;">Unsubscribe</a></p>
  </div>
</div>
