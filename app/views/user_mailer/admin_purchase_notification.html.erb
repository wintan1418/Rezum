<p style="font-size: 16px; color: #374151; font-weight: 600;">New Purchase Alert</p>

<table width="100%" cellpadding="0" cellspacing="0" style="margin: 16px 0; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden;">
  <tr>
    <td style="padding: 12px 16px; background: #f0fdf4; border-bottom: 1px solid #e5e7eb;">
      <span style="font-size: 13px; color: #6b7280;">Customer</span>
    </td>
    <td style="padding: 12px 16px; background: #f0fdf4; border-bottom: 1px solid #e5e7eb; text-align: right;">
      <span style="font-size: 13px; font-weight: 600; color: #374151;"><%= @user.full_name %> (<%= @user.email %>)</span>
    </td>
  </tr>
  <tr>
    <td style="padding: 12px 16px; border-bottom: 1px solid #e5e7eb;">
      <span style="font-size: 13px; color: #6b7280;">Country</span>
    </td>
    <td style="padding: 12px 16px; border-bottom: 1px solid #e5e7eb; text-align: right;">
      <span style="font-size: 13px; font-weight: 600; color: #374151;"><%= @user.country_code.present? ? ISO3166::Country[@user.country_code]&.common_name || @user.country_code : "Unknown" %></span>
    </td>
  </tr>
  <tr>
    <td style="padding: 12px 16px; border-bottom: 1px solid #e5e7eb;">
      <span style="font-size: 13px; color: #6b7280;">Purchase</span>
    </td>
    <td style="padding: 12px 16px; border-bottom: 1px solid #e5e7eb; text-align: right;">
      <span style="font-size: 13px; font-weight: 600; color: #374151;"><%= @payment.description_display %></span>
    </td>
  </tr>
  <tr>
    <td style="padding: 12px 16px; border-bottom: 1px solid #e5e7eb;">
      <span style="font-size: 13px; color: #6b7280;">Amount</span>
    </td>
    <td style="padding: 12px 16px; border-bottom: 1px solid #e5e7eb; text-align: right;">
      <span style="font-size: 15px; font-weight: 700; color: #16a34a;"><%= @payment.amount_display %></span>
    </td>
  </tr>
  <tr>
    <td style="padding: 12px 16px;">
      <span style="font-size: 13px; color: #6b7280;">Date</span>
    </td>
    <td style="padding: 12px 16px; text-align: right;">
      <span style="font-size: 13px; font-weight: 600; color: #374151;"><%= @payment.created_at.strftime("%B %d, %Y at %I:%M %p") %></span>
    </td>
  </tr>
</table>

<div style="text-align: center; margin: 24px 0;">
  <a href="<%= admin_root_url %>" style="background: linear-gradient(135deg, #2563eb, #7c3aed); color: #ffffff; padding: 10px 24px; text-decoration: none; border-radius: 8px; font-size: 13px; font-weight: 600; display: inline-block;">
    View Dashboard
  </a>
</div>
