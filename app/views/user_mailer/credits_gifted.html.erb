<p style="font-size: 16px; color: #374151;">Hi <%= @user.first_name %>,</p>

<p style="font-size: 14px; color: #6b7280; line-height: 1.6;">
  Great news! You've received <strong style="color: #2563eb;"><%= @credits %> free credits</strong> on your RezumFit account.
</p>

<% if @reason %>
<div style="margin: 20px 0; padding: 16px; background: #f0f9ff; border-left: 4px solid #2563eb; border-radius: 0 8px 8px 0;">
  <p style="font-size: 13px; color: #6b7280; margin: 0 0 4px;">Reason</p>
  <p style="font-size: 14px; color: #1e40af; font-weight: 600; margin: 0;"><%= @reason %></p>
</div>
<% end %>

<table width="100%" cellpadding="0" cellspacing="0" style="margin: 24px 0; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden;">
  <tr>
    <td style="padding: 12px 16px; background: #f9fafb; border-bottom: 1px solid #e5e7eb;">
      <span style="font-size: 13px; color: #6b7280;">Credits Added</span>
    </td>
    <td style="padding: 12px 16px; background: #f9fafb; border-bottom: 1px solid #e5e7eb; text-align: right;">
      <span style="font-size: 13px; font-weight: 600; color: #2563eb;"><%= @credits %></span>
    </td>
  </tr>
  <tr>
    <td style="padding: 12px 16px;">
      <span style="font-size: 13px; color: #6b7280;">Your New Balance</span>
    </td>
    <td style="padding: 12px 16px; text-align: right;">
      <span style="font-size: 13px; font-weight: 600; color: #374151;"><%= @user.credits_remaining %> credits</span>
    </td>
  </tr>
</table>

<p style="font-size: 14px; color: #6b7280; line-height: 1.6;">
  Here's what you can do with your credits:
</p>

<ul style="font-size: 13px; color: #6b7280; line-height: 1.8; padding-left: 20px;">
  <li><strong>Resume Optimization</strong> — 2 credits</li>
  <li><strong>Cover Letter</strong> — 1 credit</li>
  <li><strong>AI Resume Builder</strong> — 10 credits</li>
  <li><strong>Interview Prep</strong> — 3 credits</li>
</ul>

<div style="text-align: center; margin: 32px 0 16px;">
  <a href="<%= dashboard_url %>" style="background: linear-gradient(135deg, #2563eb, #7c3aed); color: #ffffff; padding: 12px 32px; text-decoration: none; border-radius: 8px; font-size: 14px; font-weight: 600; display: inline-block;">
    Use Your Credits
  </a>
</div>

<p style="font-size: 12px; color: #9ca3af; margin-top: 24px;">
  These credits have been added to your account and are ready to use right away. They never expire!
</p>
