<div style="max-width: 600px; margin: 0 auto; font-family: 'Helvetica Neue', Arial, sans-serif;">
  <div style="background: linear-gradient(135deg, #2563eb, #7c3aed); padding: 32px; text-align: center; border-radius: 12px 12px 0 0;">
    <h1 style="color: white; margin: 0; font-size: 24px;">You're Out of Credits</h1>
  </div>

  <div style="background: white; padding: 32px; border: 1px solid #e5e7eb; border-top: none;">
    <p style="font-size: 16px; color: #374151;">Hi <%= @user.first_name %>,</p>

    <p style="font-size: 14px; color: #6b7280; line-height: 1.6;">
      You've used all your credits! Upgrade to Pro for unlimited resume optimizations and cover letter generation, or purchase a credit pack.
    </p>

    <div style="display: flex; gap: 16px; justify-content: center; margin: 32px 0; flex-wrap: wrap;">
      <a href="<%= new_subscription_url %>" style="background: linear-gradient(135deg, #2563eb, #7c3aed); color: white; padding: 12px 24px; text-decoration: none; border-radius: 8px; font-size: 14px; font-weight: 600; display: inline-block;">
        Go Pro — $29/mo
      </a>
      <a href="<%= billing_index_url %>" style="background: white; color: #374151; padding: 12px 24px; text-decoration: none; border-radius: 8px; font-size: 14px; font-weight: 600; display: inline-block; border: 1px solid #d1d5db;">
        Buy Credits
      </a>
    </div>
  </div>

  <div style="text-align: center; padding: 16px; font-size: 12px; color: #9ca3af;">
    <p><a href="<%= unsubscribe_url(email: @user.email, token: @user.referral_code) %>" style="color: #9ca3af;">Unsubscribe</a></p>
  </div>
</div>
