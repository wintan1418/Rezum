<div style="max-width: 600px; margin: 0 auto; font-family: 'Helvetica Neue', Arial, sans-serif;">
  <div style="background: linear-gradient(135deg, #2563eb, #7c3aed); padding: 32px; text-align: center; border-radius: 12px 12px 0 0;">
    <h1 style="color: white; margin: 0; font-size: 24px;">We Miss You!</h1>
  </div>

  <div style="background: white; padding: 32px; border: 1px solid #e5e7eb; border-top: none;">
    <p style="font-size: 16px; color: #374151;">Hi <%= @user.first_name %>,</p>

    <p style="font-size: 14px; color: #6b7280; line-height: 1.6;">
      It's been a while since you've visited ReZum. Your resume toolkit is ready and waiting to help you land your next role.
    </p>

    <% if @user.credits_remaining > 0 %>
      <div style="background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 8px; padding: 16px; margin: 24px 0; text-align: center;">
        <p style="margin: 0; font-size: 14px; color: #1e40af;">
          You still have <strong><%= @user.credits_remaining %> credit<%= 's' if @user.credits_remaining != 1 %></strong> available!
        </p>
      </div>
    <% end %>

    <p style="font-size: 14px; color: #6b7280; line-height: 1.6;">Here's what you can do:</p>
    <ul style="font-size: 14px; color: #6b7280; line-height: 1.8; padding-left: 20px;">
      <li>Upload and optimize a resume for a new role</li>
      <li>Generate a tailored cover letter</li>
      <li>Check your ATS compatibility score</li>
    </ul>

    <div style="text-align: center; margin: 32px 0;">
      <a href="<%= dashboard_url %>" style="background: linear-gradient(135deg, #2563eb, #7c3aed); color: white; padding: 12px 32px; text-decoration: none; border-radius: 8px; font-size: 14px; font-weight: 600; display: inline-block;">
        Come Back to ReZum
      </a>
    </div>
  </div>

  <div style="text-align: center; padding: 16px; font-size: 12px; color: #9ca3af;">
    <p><a href="<%= unsubscribe_url(email: @user.email, token: @user.referral_code) %>" style="color: #9ca3af;">Unsubscribe</a></p>
  </div>
</div>
