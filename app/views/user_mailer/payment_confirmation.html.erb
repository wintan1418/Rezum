<p style="font-size: 16px; color: #374151;">Hi <%= @user.first_name %>,</p>

<p style="font-size: 14px; color: #6b7280; line-height: 1.6;">
  Your payment has been confirmed! Here are the details:
</p>

<table width="100%" cellpadding="0" cellspacing="0" style="margin: 24px 0; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden;">
  <tr>
    <td style="padding: 12px 16px; background: #f9fafb; border-bottom: 1px solid #e5e7eb;">
      <span style="font-size: 13px; color: #6b7280;">Description</span>
    </td>
    <td style="padding: 12px 16px; background: #f9fafb; border-bottom: 1px solid #e5e7eb; text-align: right;">
      <span style="font-size: 13px; font-weight: 600; color: #374151;"><%= @payment.description_display %></span>
    </td>
  </tr>
  <tr>
    <td style="padding: 12px 16px; border-bottom: 1px solid #e5e7eb;">
      <span style="font-size: 13px; color: #6b7280;">Amount</span>
    </td>
    <td style="padding: 12px 16px; border-bottom: 1px solid #e5e7eb; text-align: right;">
      <span style="font-size: 13px; font-weight: 600; color: #374151;"><%= @payment.amount_display %></span>
    </td>
  </tr>
  <tr>
    <td style="padding: 12px 16px; border-bottom: 1px solid #e5e7eb;">
      <span style="font-size: 13px; color: #6b7280;">Credits Added</span>
    </td>
    <td style="padding: 12px 16px; border-bottom: 1px solid #e5e7eb; text-align: right;">
      <span style="font-size: 13px; font-weight: 600; color: #2563eb;"><%= @payment.credits_purchased %></span>
    </td>
  </tr>
  <tr>
    <td style="padding: 12px 16px;">
      <span style="font-size: 13px; color: #6b7280;">Date</span>
    </td>
    <td style="padding: 12px 16px; text-align: right;">
      <span style="font-size: 13px; font-weight: 600; color: #374151;"><%= @payment.created_at.strftime("%B %d, %Y at %I:%M %p") %></span>
    </td>
  </tr>
</table>

<p style="font-size: 14px; color: #6b7280; line-height: 1.6;">
  Your updated credit balance is <strong style="color: #2563eb;"><%= @user.credits_remaining %> credits</strong>. Each resume optimization uses 1 credit.
</p>

<div style="text-align: center; margin: 32px 0 16px;">
  <a href="<%= dashboard_url %>" style="background: linear-gradient(135deg, #2563eb, #7c3aed); color: #ffffff; padding: 12px 32px; text-decoration: none; border-radius: 8px; font-size: 14px; font-weight: 600; display: inline-block;">
    Start Optimizing
  </a>
</div>

<p style="font-size: 12px; color: #9ca3af; margin-top: 24px;">
  If you have any questions about this payment, reply to this email or contact our support team.
</p>
