<nav class="bg-white border-b border-gray-200 sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16">
      <!-- Left: Logo + Nav Links -->
      <div class="flex items-center">
        <%= link_to root_path, class: "flex items-center space-x-2 mr-8" do %>
          <div class="w-8 h-8 bg-gradient-to-br from-blue-600 to-purple-600 rounded-lg flex items-center justify-center shadow-sm">
            <span class="text-white font-bold text-lg">R</span>
          </div>
          <span class="text-xl font-bold text-gray-900 hidden sm:block">RezumFit</span>
        <% end %>

        <div class="hidden sm:flex items-center space-x-1">
          <%= link_to articles_path, class: "inline-flex items-center px-3 py-2 text-sm font-medium transition-colors #{controller_name == 'articles' ? 'text-blue-600 border-b-2 border-blue-600' : 'text-gray-600 hover:text-gray-900'}" do %>
            Blog
          <% end %>
          <%= link_to ats_checker_path, class: "inline-flex items-center px-3 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors" do %>
            Free ATS Checker
          <% end %>
        </div>
      </div>

      <!-- Right: Auth buttons -->
      <div class="flex items-center space-x-3">
        <% if user_signed_in? %>
          <%= link_to dashboard_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors" do %>Dashboard<% end %>
          <% if current_user.admin? %>
            <%= link_to admin_root_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors" do %>Admin<% end %>
          <% end %>
        <% else %>
          <%= link_to new_user_session_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors" do %>Sign In<% end %>
          <%= link_to new_user_registration_path, class: "inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-xl shadow-sm transition-colors" do %>Get Started Free<% end %>
        <% end %>
      </div>
    </div>
  </div>
</nav>
