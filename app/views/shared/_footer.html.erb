<footer class="mt-auto" data-controller="developer-card" data-action="keydown@window->developer-card#keydown" style="background: var(--paper); border-top: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); font-family: 'Inter Tight', system-ui, sans-serif;">
  <div class="max-w-7xl mx-auto" style="padding: 20px 24px;">
    <div style="display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 16px;">

      <!-- Brand + © -->
      <div style="display: flex; align-items: center; gap: 12px;">
        <span style="width: 20px; height: 20px; border: 1.5px solid var(--ink); border-radius: 50%; position: relative; display: inline-block;">
          <span style="position: absolute; inset: 4px; background: var(--ink); border-radius: 50%; clip-path: polygon(0 0,100% 0,100% 60%,40% 60%,40% 100%,0 100%); display: block;"></span>
        </span>
        <span style="font-family: 'Fraunces', serif; font-weight: 500; font-size: 16px; letter-spacing: -0.02em; color: var(--ink); font-variation-settings: 'opsz' 24;">RezumFit</span>
        <span class="font-mono-label" style="color: var(--muted);">© <%= Date.current.year %></span>
      </div>

      <!-- Links -->
      <div style="display: flex; align-items: center; gap: 18px; flex-wrap: wrap;">
        <%= link_to "Terms", terms_path, style: "font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); text-decoration: none;" %>
        <%= link_to "Privacy", privacy_path, style: "font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); text-decoration: none;" %>
        <span style="color: color-mix(in oklab, var(--ink) 14%, transparent);">·</span>
        <button type="button" data-action="click->developer-card#open" style="display: inline-flex; align-items: center; gap: 6px; background: transparent; border: none; cursor: pointer; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); padding: 0;">
          <span>Built by</span>
          <span style="color: var(--ink); font-weight: 500;">WinTech</span>
          <svg style="width: 11px; height: 11px;" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Developer Card Modal — editorial -->
  <div data-developer-card-target="modal" data-action="click->developer-card#backdropClose" class="hidden fixed inset-0 z-50 flex items-center justify-center" style="background: color-mix(in oklab, var(--ink) 70%, transparent); backdrop-filter: blur(6px); padding: 16px;">
    <div data-card style="background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent); border-radius: 8px; max-width: 420px; width: 100%; overflow: hidden; transform: scale(0.95); opacity: 0; transition: all 0.2s ease-out;">

      <!-- Header (ink-dark) -->
      <div style="background: var(--ink); color: var(--paper); padding: 36px 28px 32px; text-align: center;">
        <div style="width: 64px; height: 64px; margin: 0 auto 14px; border-radius: 50%; background: color-mix(in oklab, var(--paper) 12%, transparent); border: 1px solid color-mix(in oklab, var(--paper) 22%, transparent); display: flex; align-items: center; justify-content: center;">
          <span style="font-family: 'Fraunces', serif; font-size: 28px; font-weight: 500; color: var(--paper); font-variation-settings: 'opsz' 36;">W</span>
        </div>
        <h3 style="font-family: 'Fraunces', serif; font-size: 24px; font-weight: 500; letter-spacing: -0.02em; color: var(--paper); margin: 0; font-variation-settings: 'opsz' 36;">Oluwawintan</h3>
        <p class="font-mono-label" style="color: var(--accent); margin-top: 6px;">Full-stack developer</p>
      </div>

      <!-- Contact rows -->
      <div style="padding: 20px;">
        <div style="border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 6px; overflow: hidden;">
          <% [
            { href: "mailto:wintan1418@gmail.com", label: "Email", value: "wintan1418@gmail.com" },
            { href: "tel:+2348145804206", label: "Phone", value: "+234 814 580 4206" },
            { href: "https://www.linkedin.com/in/oluwintan/", label: "LinkedIn", value: "linkedin.com/in/oluwintan", external: true },
            { href: "https://github.com/wintan1418", label: "GitHub", value: "github.com/wintan1418", external: true }
          ].each_with_index do |row, i| %>
            <a href="<%= row[:href] %>" <%= "target=\"_blank\" rel=\"noopener noreferrer\"".html_safe if row[:external] %>
               style="display: flex; align-items: center; justify-content: space-between; padding: 14px 16px; <%= 'border-top: 1px solid color-mix(in oklab, var(--ink) 10%, transparent);' if i > 0 %> color: var(--ink); text-decoration: none; transition: background .15s;"
               onmouseover="this.style.background='var(--paper-2)'"
               onmouseout="this.style.background='transparent'">
              <div style="min-width: 0;">
                <span class="font-mono-label" style="color: var(--accent);"><%= row[:label] %></span>
                <p style="font-size: 14px; color: var(--ink); margin-top: 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= row[:value] %></p>
              </div>
              <span style="color: var(--muted); flex-shrink: 0; margin-left: 14px;">→</span>
            </a>
          <% end %>
        </div>

        <button type="button" data-action="click->developer-card#close" class="btn-outline" style="width: 100%; justify-content: center; padding: 12px; margin-top: 16px; cursor: pointer;">
          Close
        </button>
      </div>
    </div>
  </div>
</footer>
