        <span class="text-sm font-semibold text-gray-900">ReZum</span>
        <span class="text-gray-300">|</span>
        <p class="text-sm text-gray-500">&copy; <%= Date.current.year %></p>
      </div>

      <div class="flex items-center gap-4">
        <%= link_to "Terms", terms_path, class: "text-xs text-gray-400 hover:text-gray-600 transition-colors" %>
        <%= link_to "Privacy", privacy_path, class: "text-xs text-gray-400 hover:text-gray-600 transition-colors" %>
        <span class="text-gray-200">|</span>
        <button data-action="click->developer-card#open" class="inline-flex items-center gap-1.5 text-xs text-gray-500 hover:text-blue-600 transition-colors group cursor-pointer">
