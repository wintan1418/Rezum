<% return if current_user.has_premium_subscription? %>

<div style="display: flex; flex-direction: column; gap: 14px; padding: 22px 24px; background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent); border-radius: 6px; margin-bottom: 24px;" class="upsell-row">
  <div style="display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap;">
    <div style="min-width: 0; flex: 1;">
      <span class="font-mono-label" style="color: var(--accent);">Upgrade</span>
      <p style="font-family:'Fraunces',serif; font-size: 19px; font-weight: 500; letter-spacing: -0.01em; font-variation-settings:'opsz' 24; margin-top: 4px; line-height: 1.25;">
        <%= local_assigns[:heading] || "Unlock more power." %>
      </p>
      <p style="font-size: 13px; color: var(--muted); margin-top: 4px; line-height: 1.5;">
        <%= local_assigns[:message] || "Upgrade to Pro for unlimited access to all features." %>
      </p>
    </div>
    <%= link_to new_subscription_path, class: "btn-accent", style: "flex-shrink: 0;" do %>
      Upgrade now
      <svg style="width: 14px; height: 14px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    <% end %>
  </div>
</div>
