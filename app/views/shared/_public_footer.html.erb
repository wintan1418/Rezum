<footer class="bg-gray-900 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <!-- Product -->
      <div>
        <h4 class="text-sm font-semibold text-white mb-4">Product</h4>
        <ul class="space-y-2.5">
          <li><%= link_to "Features", root_path(anchor: "features"), class: "text-sm text-gray-400 hover:text-white transition-colors" %></li>
          <li><%= link_to "Pricing", root_path(anchor: "pricing"), class: "text-sm text-gray-400 hover:text-white transition-colors" %></li>
          <li><%= link_to "How It Works", root_path(anchor: "how-it-works"), class: "text-sm text-gray-400 hover:text-white transition-colors" %></li>
          <li><%= link_to "Free ATS Checker", ats_checker_path, class: "text-sm text-gray-400 hover:text-white transition-colors" %></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-sm font-semibold text-white mb-4">Resources</h4>
        <ul class="space-y-2.5">
          <li><%= link_to "Blog", articles_path, class: "text-sm text-gray-400 hover:text-white transition-colors" %></li>
          <li><%= link_to "Resume Tips", articles_path(category: 'resume_tips'), class: "text-sm text-gray-400 hover:text-white transition-colors" %></li>
          <li><%= link_to "ATS Guide", articles_path(category: 'ats_guide'), class: "text-sm text-gray-400 hover:text-white transition-colors" %></li>
          <li><%= link_to "Interview Prep", articles_path(category: 'interview_prep'), class: "text-sm text-gray-400 hover:text-white transition-colors" %></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-sm font-semibold text-white mb-4">Legal</h4>
        <ul class="space-y-2.5">
          <li><%= link_to "Terms of Service", terms_path, class: "text-sm text-gray-400 hover:text-white transition-colors" %></li>
          <li><%= link_to "Privacy Policy", privacy_path, class: "text-sm text-gray-400 hover:text-white transition-colors" %></li>
        </ul>
      </div>

      <!-- Account -->
      <div>
        <h4 class="text-sm font-semibold text-white mb-4">Account</h4>
        <ul class="space-y-2.5">
          <% if user_signed_in? %>
            <li><%= link_to "Dashboard", dashboard_path, class: "text-sm text-gray-400 hover:text-white transition-colors" %></li>
            <li><%= link_to "My Resumes", resumes_path, class: "text-sm text-gray-400 hover:text-white transition-colors" %></li>
          <% else %>
            <li><%= link_to "Sign In", new_user_session_path, class: "text-sm text-gray-400 hover:text-white transition-colors" %></li>
            <li><%= link_to "Sign Up", new_user_registration_path, class: "text-sm text-gray-400 hover:text-white transition-colors" %></li>
          <% end %>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center space-x-2">
        <div class="w-7 h-7 bg-gradient-to-br from-blue-500 to-purple-600 rounded-lg flex items-center justify-center">
          <span class="text-white font-bold text-xs">R</span>
        </div>
        <span class="text-sm font-semibold text-white">RezumFit</span>
      </div>
      <p class="text-sm text-gray-500">&copy; <%= Date.current.year %> RezumFit. All rights reserved.</p>
    </div>
  </div>
</footer>
