<nav class="sticky top-0 z-40" data-controller="mobile-menu" style="background: color-mix(in oklab, var(--paper) 92%, transparent); backdrop-filter: blur(10px); border-bottom: 1px solid color-mix(in oklab, var(--ink) 10%, transparent);">
  <div class="max-w-7xl mx-auto" style="padding: 0 24px;">
    <div class="flex justify-between items-center" style="height: 64px;">

      <!-- Left: brand + nav -->
      <div class="flex items-center">
        <%= link_to root_path, class: "flex items-center", style: "gap: 10px; margin-right: 32px; text-decoration: none; color: var(--ink);" do %>
          <span style="width:22px; height:22px; border:1.5px solid var(--ink); border-radius:50%; position:relative; display:inline-block;">
            <span style="position:absolute; inset:4px; background:var(--ink); border-radius:50%; clip-path: polygon(0 0,100% 0,100% 60%,40% 60%,40% 100%,0 100%); display:block;"></span>
          </span>
          <span class="hidden sm:block" style="font-family:'Fraunces',serif; font-weight:500; font-size:19px; letter-spacing:-0.02em; font-variation-settings:'opsz' 24;">RezumFit</span>
        <% end %>

        <!-- Desktop links -->
        <div class="hidden md:flex items-center" style="gap: 4px;">
          <% nav_links = [
            [dashboard_path, "Dashboard", "dashboard"],
            [resumes_path, "Resumes", "resumes"],
            [pitch_decks_path, "Pitch Decks", "pitch_decks"],
            [cover_letters_path, "Cover Letters", "cover_letters"],
            [job_applications_path, "Applications", "job_applications"]
          ] %>
          <% nav_links.each do |path, label, ctrl| %>
            <% active = controller_name == ctrl %>
            <%= link_to path, style: "padding: 8px 12px; font-size: 13.5px; font-weight: 400; text-decoration: none; transition: color .15s; color: #{active ? 'var(--ink)' : 'color-mix(in oklab, var(--ink) 65%, transparent)'}; #{active ? 'border-bottom: 1.5px solid var(--accent);' : ''}" do %>
              <%= label %>
            <% end %>
          <% end %>

          <!-- Tools dropdown -->
          <div class="relative" data-controller="dropdown">
            <% tools_active = %w[interview_preps linkedin_optimizations scraped_jobs ats_checker].include?(controller_name) %>
            <button type="button" data-action="click->dropdown#toggle" style="padding: 8px 12px; font-size: 13.5px; font-weight: 400; background: transparent; border: none; cursor: pointer; display: inline-flex; align-items: center; gap: 4px; color: <%= tools_active ? 'var(--ink)' : 'color-mix(in oklab, var(--ink) 65%, transparent)' %>; <%= 'border-bottom: 1.5px solid var(--accent);' if tools_active %>">
              Tools
              <svg style="width: 10px; height: 10px;" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </button>
            <div data-dropdown-target="menu" class="hidden absolute left-0 z-50" style="margin-top: 4px; width: 220px; background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 6px; box-shadow: 0 12px 32px -12px rgba(20,23,28,0.18); padding: 6px; overflow: hidden;">
              <% [
                [interview_preps_path, "Interview Prep"],
                [linkedin_optimizations_path, "LinkedIn"],
                [ats_checker_path, "ATS Score Checker"]
              ].each do |path, label| %>
                <%= link_to path, style: "display: block; padding: 9px 12px; font-size: 13px; color: var(--ink); text-decoration: none; border-radius: 4px; transition: background .15s;",
                    onmouseover: "this.style.background='var(--paper-2)'", onmouseout: "this.style.background='transparent'" do %>
                  <%= label %>
                <% end %>
              <% end %>
              <div style="height: 1px; background: color-mix(in oklab, var(--ink) 10%, transparent); margin: 4px 8px;"></div>
              <%= link_to scraped_jobs_path, style: "display: flex; align-items: center; justify-content: space-between; padding: 9px 12px; font-size: 13px; color: var(--ink); text-decoration: none; border-radius: 4px; transition: background .15s;",
                  onmouseover: "this.style.background='var(--paper-2)'", onmouseout: "this.style.background='transparent'" do %>
                Job Scraper
                <span class="font-mono-label" style="color: var(--accent); font-size: 9px;">Pro</span>
              <% end %>
            </div>
          </div>

          <%= link_to billing_index_path, style: "padding: 8px 12px; font-size: 13.5px; font-weight: 400; text-decoration: none; color: #{controller_name == 'billing' ? 'var(--ink)' : 'color-mix(in oklab, var(--ink) 65%, transparent)'}; #{controller_name == 'billing' ? 'border-bottom: 1.5px solid var(--accent);' : ''}" do %>
            Billing
          <% end %>
          <%= link_to articles_path, style: "padding: 8px 12px; font-size: 13.5px; font-weight: 400; text-decoration: none; color: #{controller_name == 'articles' ? 'var(--ink)' : 'color-mix(in oklab, var(--ink) 65%, transparent)'};" do %>
            Blog
          <% end %>
        </div>
      </div>

      <!-- Right: status + user dropdown -->
      <div class="flex items-center" style="gap: 14px;">
        <% badge = subscription_status_badge(current_user) %>
        <span class="hidden sm:inline-flex items-center font-mono-label" style="padding: 5px 10px; border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent); border-radius: 999px; color: var(--ink); background: var(--paper);">
          <%= badge[:text] %>
        </span>

        <!-- User dropdown -->
        <div class="relative" data-controller="dropdown">
          <button type="button" data-action="click->dropdown#toggle" style="display: flex; align-items: center; gap: 8px; padding: 4px; background: transparent; border: none; cursor: pointer; border-radius: 999px;">
            <img src="<%= current_user.avatar_url(variant: :thumb) %>" alt="<%= current_user.display_name %>" style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover; border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent);">
            <span class="hidden lg:block" style="font-size: 13.5px; color: var(--ink);"><%= current_user.first_name %></span>
            <svg class="hidden lg:block" style="width: 12px; height: 12px; color: var(--muted);" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
          </button>

          <div data-dropdown-target="menu" class="hidden absolute right-0 z-50" style="margin-top: 8px; width: 240px; background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 6px; box-shadow: 0 12px 32px -12px rgba(20,23,28,0.18); overflow: hidden;">
            <div style="padding: 14px 16px; border-bottom: 1px solid color-mix(in oklab, var(--ink) 10%, transparent);">
              <p style="font-family:'Fraunces',serif; font-size: 15px; font-weight: 500; letter-spacing: -0.01em; color: var(--ink); margin: 0;"><%= current_user.display_name %></p>
              <p style="font-size: 12px; color: var(--muted); margin-top: 2px; word-break: break-all;"><%= current_user.email %></p>
            </div>
            <div style="padding: 6px;">
              <% [
                [settings_path, "Settings"],
                [billing_index_path, "Billing"],
                [referrals_path, "Referrals"]
              ].each do |path, label| %>
                <%= link_to path, style: "display: block; padding: 9px 12px; font-size: 13px; color: var(--ink); text-decoration: none; border-radius: 4px; transition: background .15s;",
                    onmouseover: "this.style.background='var(--paper-2)'", onmouseout: "this.style.background='transparent'" do %>
                  <%= label %>
                <% end %>
              <% end %>

              <% if current_user.admin? %>
                <%= link_to admin_root_path, style: "display: flex; align-items: center; justify-content: space-between; padding: 9px 12px; font-size: 13px; color: var(--ink); text-decoration: none; border-radius: 4px; transition: background .15s;",
                    onmouseover: "this.style.background='var(--paper-2)'", onmouseout: "this.style.background='transparent'" do %>
                  Admin Panel
                  <span class="font-mono-label" style="color: var(--accent); font-size: 9px;">Admin</span>
                <% end %>
              <% end %>
            </div>
            <div style="border-top: 1px solid color-mix(in oklab, var(--ink) 10%, transparent); padding: 6px;">
              <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, style: "display: block; padding: 9px 12px; font-size: 13px; color: var(--ink); text-decoration: none; border-radius: 4px; transition: background .15s;",
                  onmouseover: "this.style.background='var(--paper-2)'", onmouseout: "this.style.background='transparent'" do %>
                Sign out
              <% end %>
            </div>
          </div>
        </div>

        <!-- Mobile hamburger -->
        <button type="button" data-action="click->mobile-menu#toggle" class="md:hidden" style="padding: 8px; background: transparent; border: none; color: var(--ink); cursor: pointer;">
          <svg data-mobile-menu-target="openIcon" style="width: 22px; height: 22px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg data-mobile-menu-target="closeIcon" class="hidden" style="width: 22px; height: 22px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div data-mobile-menu-target="menu" class="hidden md:hidden" style="background: var(--paper); border-top: 1px solid color-mix(in oklab, var(--ink) 10%, transparent);">
    <div style="padding: 16px 20px;">
      <% [
        [dashboard_path, "Dashboard", "dashboard"],
        [resumes_path, "Resumes", "resumes"],
        [pitch_decks_path, "Pitch Decks", "pitch_decks"],
        [cover_letters_path, "Cover Letters", "cover_letters"],
        [job_applications_path, "Applications", "job_applications"],
        [interview_preps_path, "Interview Prep", "interview_preps"],
        [linkedin_optimizations_path, "LinkedIn", "linkedin_optimizations"],
        [ats_checker_path, "ATS Checker", "ats_checker"],
        [scraped_jobs_path, "Job Scraper (Pro)", "scraped_jobs"],
        [billing_index_path, "Billing", "billing"],
        [articles_path, "Blog", "articles"]
      ].each do |path, label, ctrl| %>
        <% active = controller_name == ctrl %>
        <%= link_to path, style: "display: block; padding: 11px 12px; font-size: 14px; color: #{active ? 'var(--ink)' : 'color-mix(in oklab, var(--ink) 70%, transparent)'}; text-decoration: none; #{'border-left: 2px solid var(--accent); padding-left: 10px;' if active}" do %>
          <%= label %>
        <% end %>
      <% end %>
    </div>

    <div style="border-top: 1px solid color-mix(in oklab, var(--ink) 10%, transparent); padding: 16px 20px;">
      <div class="flex items-center" style="gap: 12px; margin-bottom: 12px;">
        <img src="<%= current_user.avatar_url(variant: :thumb) %>" alt="" style="width: 36px; height: 36px; border-radius: 50%; object-fit: cover;">
        <div>
          <p style="font-family:'Fraunces',serif; font-size: 15px; font-weight: 500; color: var(--ink); margin: 0;"><%= current_user.display_name %></p>
          <p style="font-size: 12px; color: var(--muted); margin-top: 1px;"><%= current_user.email %></p>
        </div>
      </div>
      <%= link_to settings_path, style: "display: block; padding: 9px 12px; font-size: 14px; color: var(--ink); text-decoration: none;" do %>Settings<% end %>
      <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, style: "display: block; padding: 9px 12px; font-size: 14px; color: var(--ink); text-decoration: none;" do %>Sign out<% end %>
    </div>
  </div>
</nav>
