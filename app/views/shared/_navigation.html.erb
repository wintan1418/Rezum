          <p class="text-sm font-semibold text-gray-900"><%= current_user.display_name %></p>
          <p class="text-xs text-gray-500"><%= current_user.email %></p>
        </div>
      </div>

      <%= link_to settings_path, class: "flex items-center px-3 py-2 rounded-lg text-sm text-gray-700 hover:bg-gray-50" do %>
        Settings
      <% end %>

      <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "flex items-center px-3 py-2 rounded-lg text-sm text-red-600 hover:bg-red-50" do %>
        Sign Out
      <% end %>
    </div>
  </div>
</nav>
