<div class="fixed bottom-6 right-6 z-50" data-controller="chat-widget">
  <!-- Chat Bubble Button -->
  <button data-action="click->chat-widget#toggle" class="w-14 h-14 bg-gradient-to-r from-blue-600 to-purple-600 rounded-full shadow-lg hover:shadow-xl flex items-center justify-center transition-all hover:scale-105 group">
    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>
    <% if defined?(current_user) && current_user %>
      <% unread_total = current_user.conversations.sum { |c| c.unread_count_for(current_user) } %>
      <% if unread_total > 0 %>
        <span class="absolute -top-1 -right-1 w-5 h-5 bg-red-500 rounded-full text-white text-xs font-bold flex items-center justify-center" data-chat-widget-target="badge"><%= unread_total %></span>
      <% end %>
    <% end %>
  </button>

  <!-- Chat Panel -->
  <div data-chat-widget-target="panel" class="hidden absolute bottom-16 right-0 w-80 sm:w-96 bg-white rounded-2xl shadow-2xl border border-gray-200 overflow-hidden">
    <!-- Header -->
    <div class="bg-gradient-to-r from-blue-600 to-purple-600 px-5 py-4 flex items-center justify-between">
      <div>
        <h3 class="text-white font-semibold text-sm">Help & Support</h3>
        <p class="text-blue-100 text-xs">Find answers or chat with us</p>
      </div>
      <button data-action="click->chat-widget#close" class="text-white/70 hover:text-white transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Tabs -->
    <div class="flex border-b border-gray-200">
      <button data-action="click->chat-widget#showFaq" data-chat-widget-target="faqTab"
              class="flex-1 py-2.5 text-xs font-semibold text-center border-b-2 border-blue-600 text-blue-600 transition-colors">
        <svg class="w-3.5 h-3.5 inline-block mr-1 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        FAQ
      </button>
      <button data-action="click->chat-widget#showChat" data-chat-widget-target="chatTab"
              class="flex-1 py-2.5 text-xs font-semibold text-center border-b-2 border-transparent text-gray-400 hover:text-gray-600 transition-colors relative">
        <svg class="w-3.5 h-3.5 inline-block mr-1 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        Chat with us
        <% if defined?(current_user) && current_user %>
          <% unread_total = current_user.conversations.sum { |c| c.unread_count_for(current_user) } %>
          <% if unread_total > 0 %>
            <span class="absolute top-1.5 right-3 w-4 h-4 bg-red-500 rounded-full text-white text-[9px] font-bold flex items-center justify-center"><%= unread_total %></span>
          <% end %>
        <% end %>
      </button>
    </div>

    <!-- FAQ Content -->
    <div data-chat-widget-target="faqContent" class="p-4 max-h-80 overflow-y-auto">
      <!-- Search -->
      <div class="relative mb-3">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </div>
        <input type="text"
               data-chat-widget-target="faqSearch"
               data-action="input->chat-widget#filterFaq"
               placeholder="Search for answers..."
               class="w-full rounded-lg border border-gray-200 text-xs py-2 pl-9 pr-3 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none">
      </div>

      <!-- FAQ Items -->
      <div class="space-y-1.5">
        <% FaqHelper::FAQ_ITEMS.each_with_index do |faq, index| %>
          <div data-chat-widget-target="faqItem" data-question="<%= faq[:question].downcase %>" class="border border-gray-100 rounded-lg overflow-hidden">
            <button type="button"
                    data-action="click->chat-widget#toggleFaq"
                    data-index="<%= index %>"
                    class="w-full flex items-center justify-between px-3 py-2.5 text-left hover:bg-gray-50 transition-colors">
              <span class="text-xs font-medium text-gray-800 pr-2 leading-snug"><%= faq[:question] %></span>
              <svg data-chat-widget-target="faqIcon" class="w-3.5 h-3.5 text-gray-400 flex-shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div data-chat-widget-target="faqAnswer" class="hidden px-3 pb-3">
              <p class="text-xs text-gray-600 leading-relaxed"><%= faq[:answer] %></p>
            </div>
          </div>
        <% end %>
      </div>

      <!-- CTA to chat -->
      <div class="mt-4 pt-3 border-t border-gray-100 text-center">
        <p class="text-xs text-gray-400 mb-2">Can't find what you're looking for?</p>
        <button data-action="click->chat-widget#showChat"
                class="inline-flex items-center gap-1.5 px-4 py-2 bg-gradient-to-r from-blue-600 to-purple-600 text-white text-xs font-semibold rounded-lg hover:from-blue-700 hover:to-purple-700 transition-all">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
          Chat with Customer Care
        </button>
      </div>
    </div>

    <!-- Chat Content -->
    <div data-chat-widget-target="chatContent" class="hidden p-4 max-h-80 overflow-y-auto">
      <% if defined?(current_user) && current_user %>
        <% recent_conversations = current_user.conversations.recent.limit(3) %>
        <% if recent_conversations.any? %>
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-3">Recent Conversations</p>
          <div class="space-y-2 mb-4">
            <% recent_conversations.each do |conv| %>
              <%= link_to chat_path(conv), class: "block px-3 py-2 rounded-lg hover:bg-gray-50 transition-colors" do %>
                <div class="flex items-center justify-between">
                  <p class="text-sm font-medium text-gray-900 truncate"><%= conv.subject %></p>
                  <% uc = conv.unread_count_for(current_user) %>
                  <% if uc > 0 %>
                    <span class="w-4 h-4 bg-blue-600 rounded-full text-white text-[10px] font-bold flex items-center justify-center"><%= uc %></span>
                  <% end %>
                </div>
                <p class="text-xs text-gray-400"><%= time_ago_in_words(conv.updated_at) %> ago</p>
              <% end %>
            <% end %>
          </div>
        <% end %>

        <!-- New Conversation Form -->
        <div class="<%= recent_conversations.any? ? 'border-t border-gray-100 pt-4' : '' %>">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-3">Start New Conversation</p>
          <%= form_tag chat_index_path, method: :post, class: "space-y-3" do %>
            <input type="text" name="subject" placeholder="Subject..." class="w-full rounded-lg border border-gray-200 text-sm py-2 px-3 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none">
            <textarea name="body" rows="2" placeholder="How can we help?" class="w-full rounded-lg border border-gray-200 text-sm py-2 px-3 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none resize-none"></textarea>
            <button type="submit" class="w-full py-2 bg-gradient-to-r from-blue-600 to-purple-600 text-white text-sm font-semibold rounded-lg hover:from-blue-700 hover:to-purple-700 transition-all">
              Send Message
            </button>
          <% end %>
        </div>

        <%= link_to "View All Conversations", chat_index_path, class: "block text-center text-sm text-blue-600 hover:text-blue-700 font-medium mt-3" %>
      <% end %>
    </div>
  </div>
</div>
