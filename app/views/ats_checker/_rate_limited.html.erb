<div style="background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 8px; padding: 36px 32px;" class="animate-fade-up">
  <div style="text-align: center;">
    <span class="font-mono-label" style="color: var(--accent);">Limit reached</span>
    <h3 class="font-display" style="font-size: 32px; line-height: 1.05; margin-top: 8px;">You've used your <em>free check</em>.</h3>
    <p style="font-family: 'Fraunces', serif; font-style: italic; font-weight: 300; color: var(--muted); font-size: 16px; max-width: 38ch; margin: 14px auto 28px; line-height: 1.45;">
      Create a free account to check more resumes, get AI-powered optimization, and download ATS-friendly versions.
    </p>

    <%= link_to new_user_registration_path, class: "btn-ink", style: "width: 100%; justify-content: center; padding: 16px 24px;" do %>
      Create free account
      <svg style="width: 14px; height: 14px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    <% end %>

    <p style="font-size: 13px; color: var(--muted); margin-top: 14px;">
      Already have an account?
      <%= link_to "Sign in", new_user_session_path, style: "color: var(--ink); border-bottom: 1px solid var(--ink); text-decoration: none; padding-bottom: 1px; margin-left: 4px;" %>
    </p>
  </div>

  <!-- Perks -->
  <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);">
    <span class="font-mono-label" style="display: block; margin-bottom: 16px;">What you get</span>
    <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px;">
      <% [
        "Unlimited ATS score checks",
        "2 free AI resume optimizations",
        "AI cover letter generator",
        "PDF & DOCX downloads"
      ].each do |perk| %>
        <li style="display: grid; grid-template-columns: auto 1fr; gap: 12px; align-items: center; font-size: 14px; color: var(--ink); font-family: 'Fraunces', serif; font-weight: 300; font-variation-settings: 'opsz' 24;">
          <span class="font-mono-label" style="color: var(--accent);">✓</span>
          <span><%= perk %></span>
        </li>
      <% end %>
    </ul>
  </div>
</div>
