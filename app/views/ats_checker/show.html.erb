<% content_for :title, "Free ATS Resume Score Checker — RezumFit" %>
<% content_for :meta_description, "Check your resume's ATS compatibility score for free. Upload your resume and get instant feedback on formatting, keywords, and improvements to pass applicant tracking systems." %>

<% content_for :head do %>
  <script type="application/ld+json">
  <%= raw({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Free ATS Resume Score Checker",
    "url": ats_checker_url,
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "description": "Check your resume's ATS compatibility score for free."
  }.to_json) %>
  </script>
  <style>
    @keyframes score-fill { from { stroke-dashoffset: 283; } }
    @keyframes fade-up { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .animate-fade-up { animation: fade-up 0.5s ease-out; }
    .ats-drop{ position: relative; border: 1px dashed color-mix(in oklab, var(--ink) 22%, transparent); border-radius: 8px; padding: 56px 28px; text-align: center; cursor: pointer; transition: border-color .2s, background .2s; background: #FBFBFC; }
    .ats-drop:hover{ border-color: var(--ink); background: var(--paper-2); }
    .ats-drop.dragging{ border-color: var(--accent); background: color-mix(in oklab, var(--accent) 6%, var(--paper)); }
  </style>
<% end %>

<div style="background: var(--paper); min-height: 100vh; color: var(--ink); font-family: 'Inter Tight', system-ui, sans-serif;">
  <div style="padding: 56px 0 80px;">
    <div class="max-w-7xl mx-auto" style="padding: 0 24px;">

      <!-- Header -->
      <div style="text-align: center; margin-bottom: 56px;">
        <% unless user_signed_in? %>
          <span class="font-mono-label" style="display: inline-flex; align-items: center; gap: 8px; padding: 6px 14px; border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent); border-radius: 999px; background: var(--paper); color: var(--accent); margin-bottom: 24px;">
            <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--accent); animation: edit-pulse 2s infinite; display: inline-block;"></span>
            100% Free · No sign-up required
          </span>
        <% end %>
        <h1 class="font-display" style="font-size: clamp(48px, 7vw, 96px); line-height: 0.98; letter-spacing: -0.04em; max-width: 18ch; margin: 0 auto;">
          Free ATS resume<br><em>score checker</em>.
        </h1>
        <p style="font-family: 'Fraunces', serif; font-style: italic; font-weight: 300; font-size: 21px; color: var(--muted); max-width: 48ch; margin: 24px auto 0; line-height: 1.4;">
          Upload your resume, get an instant ATS compatibility score, and a punch-list of fixes that get you past the bots.
        </p>
      </div>

      <!-- Two-up: upload | results -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: start;" class="ats-grid">

        <!-- Upload form -->
        <div style="background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 8px; padding: 32px;" data-controller="ats-checker">
          <span class="font-mono-label">01 / Upload</span>
          <h2 class="font-display" style="font-size: 28px; line-height: 1.05; margin-top: 6px;">Drop your resume here.</h2>
          <p style="font-size: 13px; color: var(--muted); margin-top: 4px; margin-bottom: 24px;">PDF, DOCX, or TXT — up to 10MB.</p>

          <%= form_with url: ats_checker_check_path, method: :post, multipart: true, data: { ats_checker_target: "form", action: "submit->ats-checker#submit", turbo: true } do |f| %>

            <div class="ats-drop"
                 data-ats-checker-target="dropZone"
                 data-action="dragover->ats-checker#dragOver dragenter->ats-checker#dragOver dragleave->ats-checker#dragLeave drop->ats-checker#drop click->ats-checker#openFilePicker">

              <!-- Upload state -->
              <div data-ats-checker-target="uploadIcon">
                <svg style="width: 32px; height: 32px; color: var(--ink); margin: 0 auto 18px; display: block; opacity: 0.6;" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                </svg>
                <p style="font-family: 'Fraunces', serif; font-size: 19px; font-weight: 500; letter-spacing: -0.01em; font-variation-settings: 'opsz' 24;">Drag &amp; drop your resume here</p>
                <p class="font-mono-label" style="margin-top: 8px;">or click to browse</p>
              </div>

              <!-- File selected state -->
              <div data-ats-checker-target="fileInfo" class="hidden">
                <span class="font-mono-label" style="color: var(--accent);">✓ Ready</span>
                <p style="font-family: 'Fraunces', serif; font-size: 18px; font-weight: 500; letter-spacing: -0.01em; margin-top: 8px;" data-ats-checker-target="fileName"></p>
                <p class="font-mono-label" style="margin-top: 4px;" data-ats-checker-target="fileSize"></p>
              </div>
            </div>

            <input type="file" name="resume_file" accept=".pdf,.docx,.doc,.txt" class="hidden" data-ats-checker-target="fileInput" data-action="change->ats-checker#fileSelected">

            <button type="submit" data-ats-checker-target="submitBtn" class="btn-ink"
                    style="width: 100%; justify-content: center; padding: 16px 24px; margin-top: 20px; font-size: 15px; opacity: 1;"
                    disabled>
              <span data-ats-checker-target="submitText">Check my ATS score</span>
              <span data-ats-checker-target="loadingText" class="hidden" style="align-items: center; justify-content: center;">
                <svg class="animate-spin" style="width: 14px; height: 14px; margin-right: 8px; color: var(--paper);" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                Analyzing…
              </span>
            </button>
          <% end %>

          <% if @rate_limited %>
            <div style="margin-top: 24px; padding: 18px 20px; background: var(--ink); color: var(--paper); border-radius: 6px;">
              <span class="font-mono-label" style="color: var(--accent);">Limit reached</span>
              <p style="font-family: 'Fraunces', serif; font-size: 17px; font-weight: 400; letter-spacing: -0.01em; margin-top: 4px;">You've used your free check.</p>
              <p style="font-size: 13px; color: color-mix(in oklab, var(--paper) 65%, transparent); margin-top: 4px; line-height: 1.5;">Create a free account to check more resumes and unlock AI optimization.</p>
              <div style="display: flex; gap: 10px; margin-top: 14px; flex-wrap: wrap;">
                <%= link_to "Create free account", new_user_registration_path, class: "btn-accent", style: "padding: 9px 16px; font-size: 13px;" %>
                <%= link_to "Sign in", new_user_session_path, style: "padding: 9px 16px; font-size: 13px; color: color-mix(in oklab, var(--paper) 75%, transparent); text-decoration: none; align-self: center;" %>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Results area -->
        <div id="ats-results">
          <div style="background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 8px; padding: 48px 32px; text-align: center;">
            <span class="font-mono-label">02 / Results</span>
            <h3 class="font-display" style="font-size: 32px; line-height: 1.05; margin-top: 8px;">Your <em>score</em> appears here.</h3>
            <p style="font-family: 'Fraunces', serif; font-style: italic; font-weight: 300; color: var(--muted); font-size: 16px; max-width: 32ch; margin: 12px auto 32px;">
              Upload your resume to get an instant ATS compatibility analysis with actionable improvements.
            </p>

            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; text-align: left; max-width: 280px; margin: 0 auto;">
              <% [
                "ATS format compatibility check",
                "Content quality analysis",
                "Actionable improvement tips"
              ].each do |item| %>
                <li style="display: grid; grid-template-columns: auto 1fr; gap: 12px; align-items: start; font-size: 14px; color: var(--ink);">
                  <span class="font-mono-label" style="color: var(--accent); padding-top: 1px;">✦</span>
                  <span><%= item %></span>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>

      <!-- Social proof -->
      <div style="margin-top: 80px; padding-top: 48px; border-top: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);">
        <span class="font-mono-label" style="display: block; text-align: center; color: var(--muted); margin-bottom: 28px;">Trusted by job seekers worldwide</span>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; max-width: 600px; margin: 0 auto;" class="ats-stats">
          <% [["10K+", "Resumes analyzed"], ["85%", "Avg score improvement"], ["4.8/5", "User rating"]].each_with_index do |(n, l), i| %>
            <div style="text-align: center; padding: 0 24px; <%= 'border-left: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);' unless i == 0 %>">
              <div style="font-family: 'Fraunces', serif; font-size: 48px; font-weight: 400; letter-spacing: -0.03em; line-height: 0.95; font-variation-settings: 'opsz' 96;">
                <em style="font-style: italic; color: var(--accent);"><%= n %></em>
              </div>
              <div class="font-mono-label" style="margin-top: 8px;"><%= l %></div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  @media (max-width: 960px){ .ats-grid{grid-template-columns: 1fr !important;} }
  @media (max-width: 600px){ .ats-stats{grid-template-columns: 1fr !important;} .ats-stats > div{padding: 18px 0 !important; border-left: none !important; border-top: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);} .ats-stats > div:first-child{border-top: none;} }
</style>
