<% score = results[:overall_score] %>
<% score_color = score >= 75 ? "var(--accent)" : score >= 50 ? "var(--ink)" : "var(--ink)" %>
<% score_label = score >= 75 ? "ATS-friendly" : score >= 50 ? "Needs work" : "Significant fixes needed" %>

<div style="background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 8px; padding: 32px;" class="animate-fade-up" data-controller="score-gauge email-gate">

  <!-- Score gauge -->
  <div style="text-align: center; margin-bottom: 28px;">
    <div style="position: relative; display: inline-flex; align-items: center; justify-content: center; width: 168px; height: 168px;">
      <svg style="width: 168px; height: 168px; transform: rotate(-90deg);" viewBox="0 0 100 100">
        <circle cx="50" cy="50" r="45" fill="none" stroke="color-mix(in oklab, var(--ink) 10%, transparent)" stroke-width="6"/>
        <circle cx="50" cy="50" r="45" fill="none"
                stroke="<%= score_color %>"
                stroke-width="6" stroke-linecap="round"
                stroke-dasharray="283"
                stroke-dashoffset="<%= 283 - (283 * score / 100.0) %>"
                data-score-gauge-target="circle"
                data-final-offset="<%= 283 - (283 * score / 100.0) %>"
                style="stroke-dashoffset: 283; transition: stroke-dashoffset 1.5s ease-out;"/>
      </svg>
      <div style="position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <span style="font-family: 'Fraunces', serif; font-size: 56px; font-weight: 400; letter-spacing: -0.04em; line-height: 0.9; color: var(--ink); font-variation-settings: 'opsz' 144;" data-score-gauge-target="number" data-final-score="<%= score %>">0</span>
        <span class="font-mono-label" style="margin-top: 4px; color: var(--muted);">/ 100</span>
      </div>
    </div>

    <p style="font-family: 'Fraunces', serif; font-style: italic; font-weight: 300; font-size: 17px; color: var(--muted); margin-top: 16px; font-variation-settings: 'opsz' 24;">
      <%= score_label %>.
    </p>
  </div>

  <!-- Sub-scores -->
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 6px; overflow: hidden; margin-bottom: 24px;">
    <div style="padding: 18px 20px; background: var(--paper);">
      <span class="font-mono-label">Format</span>
      <div style="font-family: 'Fraunces', serif; font-size: 36px; font-weight: 400; letter-spacing: -0.03em; line-height: 0.95; font-variation-settings: 'opsz' 96; margin-top: 8px;"><%= results[:format_score] %></div>
    </div>
    <div style="padding: 18px 20px; background: var(--paper); border-left: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);">
      <span class="font-mono-label">Content</span>
      <div style="font-family: 'Fraunces', serif; font-size: 36px; font-weight: 400; letter-spacing: -0.03em; line-height: 0.95; font-variation-settings: 'opsz' 96; margin-top: 8px;"><%= results[:content_score] %></div>
    </div>
  </div>

  <!-- Issues found -->
  <% if results[:issues].present? %>
    <div style="margin-bottom: 24px;">
      <span class="font-mono-label" style="color: var(--accent); display: block; margin-bottom: 12px;"><%= results[:issues].length %> issues found</span>
      <div style="display: flex; flex-wrap: wrap; gap: 6px;">
        <% results[:issues].each do |issue| %>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 11px; padding: 5px 10px; background: var(--ink); color: var(--paper); border-radius: 999px; letter-spacing: 0.04em;"><%= issue %></span>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- ============================================ -->
  <!-- EMAIL GATE -->
  <!-- ============================================ -->
  <% unless user_signed_in? %>
    <div data-email-gate-target="gate" style="position: relative;">
      <!-- Blurred preview -->
      <div style="position: relative; overflow: hidden; border-radius: 6px; max-height: 180px;">
        <div style="filter: blur(4px); opacity: 0.4; pointer-events: none; user-select: none;">
          <% if results[:strengths].present? %>
            <div style="margin-bottom: 16px;">
              <span class="font-mono-label">Strengths</span>
              <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px;">
                <% results[:strengths].first(3).each do |s| %>
                  <span style="font-family: 'JetBrains Mono', monospace; font-size: 11px; padding: 5px 10px; border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent); border-radius: 999px;"><%= s %></span>
                <% end %>
              </div>
            </div>
          <% end %>
          <% if results[:improvements].present? %>
            <div>
              <span class="font-mono-label">How to fix</span>
              <ol style="list-style: none; padding: 0; margin: 8px 0 0; display: flex; flex-direction: column; gap: 8px;">
                <% results[:improvements].first(3).each_with_index do |imp, i| %>
                  <li style="font-family: 'Fraunces', serif; font-size: 14px; font-weight: 300;"><%= i+1 %>. <%= imp %></li>
                <% end %>
              </ol>
            </div>
          <% end %>
        </div>
        <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, color-mix(in oklab, var(--paper) 30%, transparent), var(--paper));"></div>
      </div>

      <!-- Email capture -->
      <div style="margin-top: 16px; background: var(--ink); color: var(--paper); border-radius: 8px; padding: 28px 24px; text-align: center;">
        <span class="font-mono-label" style="color: var(--accent);">Unlock report</span>
        <h4 class="font-display" style="font-size: 24px; line-height: 1.05; color: var(--paper); margin-top: 8px;">Get your full <em>ATS report</em>.</h4>
        <p style="font-family: 'Fraunces', serif; font-style: italic; font-weight: 300; color: color-mix(in oklab, var(--paper) 70%, transparent); font-size: 14px; margin: 10px 0 20px; max-width: 36ch; margin-left: auto; margin-right: auto;">
          Enter your email to see your strengths, detailed improvements, and how to fix every issue.
        </p>

        <div style="display: flex; gap: 8px; max-width: 380px; margin: 0 auto; flex-wrap: wrap;">
          <input type="email" data-email-gate-target="email" placeholder="you@email.com"
            style="flex: 1; min-width: 180px; padding: 12px 14px; background: color-mix(in oklab, var(--paper) 8%, var(--ink)); border: 1px solid color-mix(in oklab, var(--paper) 18%, transparent); border-radius: 6px; color: var(--paper); font-family: 'Inter Tight', system-ui, sans-serif; font-size: 14px; outline: none;">
          <button type="button" data-action="click->email-gate#unlock" class="btn-accent" style="padding: 12px 20px; font-size: 13px; flex-shrink: 0;">
            Show report
          </button>
        </div>
        <p class="font-mono-label" style="margin-top: 14px; color: color-mix(in oklab, var(--paper) 50%, transparent);">Free · No spam · Unsubscribe anytime</p>
      </div>
    </div>
  <% end %>

  <!-- ============================================ -->
  <!-- FULL REPORT -->
  <!-- ============================================ -->
  <div data-email-gate-target="content" class="<%= user_signed_in? ? '' : 'hidden' %>">
    <!-- Strengths -->
    <% if results[:strengths].present? %>
      <div style="margin-bottom: 24px;">
        <span class="font-mono-label" style="color: var(--accent); display: block; margin-bottom: 12px;">Strengths</span>
        <div style="display: flex; flex-wrap: wrap; gap: 6px;">
          <% results[:strengths].each do |s| %>
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 11px; padding: 5px 10px; border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent); border-radius: 999px; color: var(--ink);">✓ <%= s %></span>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Improvements -->
    <% if results[:improvements].present? %>
      <div style="margin-bottom: 28px;">
        <span class="font-mono-label" style="color: var(--accent); display: block; margin-bottom: 16px;">How to fix these issues</span>
        <ol style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 14px;">
          <% results[:improvements].each_with_index do |imp, i| %>
            <li style="display: grid; grid-template-columns: 28px 1fr; gap: 14px; align-items: start;">
              <span class="font-mono-label" style="color: var(--accent); padding-top: 4px;"><%= sprintf("%02d", i+1) %></span>
              <span style="font-family: 'Fraunces', serif; font-size: 15px; font-weight: 300; line-height: 1.5; font-variation-settings: 'opsz' 24;"><%= imp %></span>
            </li>
          <% end %>
        </ol>
      </div>
    <% end %>

    <!-- CTA -->
    <div style="border-top: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); padding-top: 28px; margin-top: 8px;">
      <div style="background: var(--ink); color: var(--paper); border-radius: 8px; padding: 36px 32px; text-align: center;">
        <% issue_count = results[:issues]&.length || 0 %>
        <% improvement_count = results[:improvements]&.length || 0 %>

        <% if score < 75 %>
          <p class="font-display" style="font-size: 40px; line-height: 1.05; color: var(--paper); margin: 0;">
            <em style="font-style: italic; color: var(--accent);"><%= issue_count + improvement_count %></em> issues found.
          </p>
          <p style="font-family: 'Fraunces', serif; font-style: italic; font-weight: 300; color: color-mix(in oklab, var(--paper) 70%, transparent); font-size: 16px; margin: 12px 0 24px;">Our AI can fix them all in one pass — and boost your score above 80%.</p>
        <% else %>
          <p class="font-display" style="font-size: 36px; line-height: 1.05; color: var(--paper); margin: 0;">
            Good score. Make it <em style="font-style: italic; color: var(--accent);">better</em>.
          </p>
          <p style="font-family: 'Fraunces', serif; font-style: italic; font-weight: 300; color: color-mix(in oklab, var(--paper) 70%, transparent); font-size: 16px; margin: 12px 0 24px;">Optimize for a specific job posting and hit 95%+ ATS compatibility.</p>
        <% end %>

        <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
          <% if user_signed_in? %>
            <%= link_to new_resume_path, class: "btn-accent" do %>
              Fix my resume
              <svg style="width: 14px; height: 14px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            <% end %>
          <% else %>
            <%= link_to new_user_registration_path, class: "btn-accent" do %>
              Fix all issues — free account
              <svg style="width: 14px; height: 14px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            <% end %>
          <% end %>
        </div>

        <div style="display: flex; gap: 18px; justify-content: center; flex-wrap: wrap; margin-top: 22px;">
          <% ["2 free credits", "No credit card", "30 seconds"].each do |perk| %>
            <span class="font-mono-label" style="color: color-mix(in oklab, var(--paper) 60%, transparent);">✓ <%= perk %></span>
          <% end %>
        </div>

        <% unless user_signed_in? %>
          <p style="font-size: 13px; color: color-mix(in oklab, var(--paper) 70%, transparent); margin-top: 18px;">
            Already have an account? <%= link_to "Sign in", new_user_session_path, style: "color: var(--paper); text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 3px;" %>
          </p>
        <% end %>
      </div>
    </div>
  </div>
</div>
