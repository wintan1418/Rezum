<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-8 animate-fade-up" data-controller="score-gauge">

  <!-- Score Gauge -->
  <div class="text-center mb-8">
    <div class="relative inline-flex items-center justify-center w-36 h-36">
      <svg class="w-36 h-36 transform -rotate-90" viewBox="0 0 100 100">
        <circle cx="50" cy="50" r="45" fill="none" stroke="#f3f4f6" stroke-width="8"/>
        <circle cx="50" cy="50" r="45" fill="none"
                stroke="<%= results[:overall_score] >= 75 ? '#22c55e' : results[:overall_score] >= 50 ? '#eab308' : '#ef4444' %>"
                stroke-width="8" stroke-linecap="round"
                stroke-dasharray="283"
                stroke-dashoffset="<%= 283 - (283 * results[:overall_score] / 100.0) %>"
                data-score-gauge-target="circle"
                data-final-offset="<%= 283 - (283 * results[:overall_score] / 100.0) %>"
                style="stroke-dashoffset: 283; transition: stroke-dashoffset 1.5s ease-out;"/>
      </svg>
      <div class="absolute inset-0 flex flex-col items-center justify-center">
        <span class="text-3xl font-bold text-gray-900" data-score-gauge-target="number" data-final-score="<%= results[:overall_score] %>">0</span>
        <span class="text-xs text-gray-500 font-medium">/100</span>
      </div>
    </div>

    <% if results[:overall_score] >= 75 %>
      <p class="mt-3 text-sm font-semibold text-green-600">Great! Your resume is ATS-friendly</p>
    <% elsif results[:overall_score] >= 50 %>
      <p class="mt-3 text-sm font-semibold text-yellow-600">Needs improvement — some issues detected</p>
    <% else %>
      <p class="mt-3 text-sm font-semibold text-red-600">Low score — significant improvements needed</p>
    <% end %>
  </div>

  <!-- Sub-scores -->
  <div class="grid grid-cols-2 gap-4 mb-6">
    <div class="bg-gray-50 rounded-xl p-4 text-center">
      <p class="text-2xl font-bold text-gray-900"><%= results[:format_score] %></p>
      <p class="text-xs text-gray-500 font-medium mt-1">Format Score</p>
    </div>
    <div class="bg-gray-50 rounded-xl p-4 text-center">
      <p class="text-2xl font-bold text-gray-900"><%= results[:content_score] %></p>
      <p class="text-xs text-gray-500 font-medium mt-1">Content Score</p>
    </div>
  </div>

  <!-- Strengths -->
  <% if results[:strengths].present? %>
    <div class="mb-5">
      <h4 class="text-sm font-semibold text-gray-900 mb-2 flex items-center gap-1.5">
        <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        Strengths
      </h4>
      <div class="flex flex-wrap gap-2">
        <% results[:strengths].each do |s| %>
          <span class="inline-block px-3 py-1 text-xs font-medium bg-green-50 text-green-700 border border-green-200 rounded-full"><%= s %></span>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Issues -->
  <% if results[:issues].present? %>
    <div class="mb-5">
      <h4 class="text-sm font-semibold text-gray-900 mb-2 flex items-center gap-1.5">
        <svg class="w-4 h-4 text-red-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
        Issues Found
      </h4>
      <div class="flex flex-wrap gap-2">
        <% results[:issues].each do |issue| %>
          <span class="inline-block px-3 py-1 text-xs font-medium bg-red-50 text-red-700 border border-red-200 rounded-full"><%= issue %></span>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Improvements -->
  <% if results[:improvements].present? %>
    <div class="mb-6">
      <h4 class="text-sm font-semibold text-gray-900 mb-3 flex items-center gap-1.5">
        <svg class="w-4 h-4 text-blue-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/></svg>
        Top Improvements
      </h4>
      <ol class="space-y-2">
        <% results[:improvements].each_with_index do |imp, i| %>
          <li class="flex items-start gap-2.5 text-sm text-gray-700">
            <span class="flex-shrink-0 w-5 h-5 rounded-full bg-blue-100 text-blue-700 text-xs font-bold flex items-center justify-center mt-0.5"><%= i + 1 %></span>
            <span><%= imp %></span>
          </li>
        <% end %>
      </ol>
    </div>
  <% end %>

  <!-- CTA -->
  <div class="border-t border-gray-100 pt-6 mt-6">
    <div class="bg-gradient-to-r from-blue-50 to-purple-50 rounded-xl p-5 text-center">
      <h4 class="text-base font-semibold text-gray-900 mb-1">Want to boost your score to 80+?</h4>

      <% if user_signed_in? %>
        <p class="text-sm text-gray-600 mb-4">Upload this resume and let our AI optimize it for any job posting.</p>
        <%= link_to new_resume_path, class: "inline-flex items-center px-6 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 rounded-xl shadow-md hover:shadow-lg transition-all" do %>
          Optimize My Resume
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        <% end %>
      <% else %>
        <p class="text-sm text-gray-600 mb-4">Create a free account and let our AI optimize your resume for any job posting.</p>
        <%= link_to new_user_registration_path, class: "inline-flex items-center px-6 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 rounded-xl shadow-md hover:shadow-lg transition-all" do %>
          Sign Up Free &mdash; Optimize Now
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        <% end %>
        <p class="mt-2 text-xs text-gray-500">
          Already have an account? <%= link_to "Sign in", new_user_session_path, class: "text-blue-600 hover:underline font-medium" %>
        </p>
      <% end %>
    </div>
  </div>

</div>
