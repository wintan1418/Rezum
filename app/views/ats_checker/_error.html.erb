<div style="background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 8px; padding: 40px 32px; text-align: center;" class="animate-fade-up">
  <span class="font-mono-label" style="color: var(--accent);">Analysis failed</span>
  <h3 class="font-display" style="font-size: 26px; line-height: 1.05; margin-top: 8px;">Something <em>didn't</em> parse.</h3>
  <p style="font-family: 'Fraunces', serif; font-style: italic; font-weight: 300; color: var(--muted); font-size: 16px; margin-top: 14px; max-width: 38ch; margin-left: auto; margin-right: auto;"><%= message %></p>
  <p class="font-mono-label" style="margin-top: 16px; color: var(--muted);">Please try again with a different file.</p>
</div>
