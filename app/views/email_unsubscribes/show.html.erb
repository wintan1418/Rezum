<div class="min-h-screen flex items-center justify-center bg-gray-50">
  <div class="max-w-md mx-auto text-center px-4">
    <% if @unsubscribed %>
      <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-gray-900 mb-3">You've Been Unsubscribed</h1>
      <p class="text-gray-500 mb-6">You won't receive any more marketing emails from RezumFit. You'll still receive transactional emails (password resets, receipts).</p>
    <% else %>
      <div class="w-16 h-16 rounded-full bg-red-100 flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-gray-900 mb-3">Invalid Link</h1>
      <p class="text-gray-500 mb-6">This unsubscribe link is invalid or has expired.</p>
    <% end %>

    <%= link_to root_path, class: "text-sm text-blue-600 hover:text-blue-800 font-medium" do %>
      ← Back to RezumFit
    <% end %>
  </div>
</div>
