<div class="p-6 lg:p-8">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
    <p class="text-sm text-gray-500 mt-1">Overview of your platform metrics</p>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-4 mb-8">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Total Users</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= number_with_delimiter(@total_users) %></p>
      <p class="text-xs text-green-600 mt-1">+<%= @new_users_this_week %> this week</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Subscribers</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= number_with_delimiter(@active_subscribers) %></p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Resumes</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= number_with_delimiter(@total_resumes) %></p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Cover Letters</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= number_with_delimiter(@total_cover_letters) %></p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Revenue</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= number_to_currency(@total_revenue, unit: "₦") %></p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">New This Week</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= @new_users_this_week %></p>
    </div>
  </div>

  <!-- Charts -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <h3 class="text-sm font-semibold text-gray-900 mb-4">User Signups (Last 30 Days)</h3>
      <%= line_chart @user_growth, colors: ["#2563eb"], library: { plugins: { legend: { display: false } } } %>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <h3 class="text-sm font-semibold text-gray-900 mb-4">Resumes Created (Last 30 Days)</h3>
      <%= line_chart @resume_growth, colors: ["#7c3aed"], library: { plugins: { legend: { display: false } } } %>
    </div>
  </div>

  <!-- Bulk Email -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h3 class="text-sm font-semibold text-gray-900">Send Bulk Email</h3>
        <p class="text-xs text-gray-500 mt-1">Send emails to all users (excludes unsubscribed)</p>
      </div>
      <div class="flex items-center gap-2 text-xs text-gray-400">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        <%= User.where(unsubscribed_at: nil).count %> eligible users
      </div>
    </div>

    <%= form_with url: admin_send_bulk_email_path, method: :post, local: true, class: "flex items-end gap-3" do |f| %>
      <div class="flex-1">
        <label class="block text-xs font-medium text-gray-600 mb-1.5">Email Template</label>
        <%= f.select :email_type, @available_emails.map { |k, v| [v, k] }, {}, class: "w-full rounded-lg border-gray-300 text-sm focus:border-blue-500 focus:ring-blue-500" %>
      </div>
      <%= f.submit "Send to All Users", class: "px-5 py-2.5 bg-gradient-to-r from-blue-600 to-purple-600 text-white text-sm font-semibold rounded-lg hover:from-blue-700 hover:to-purple-700 transition-all cursor-pointer whitespace-nowrap", data: { confirm: "Are you sure? This will send emails to ALL users." } %>
    <% end %>
  </div>

  <!-- Recent Users -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
      <h3 class="text-sm font-semibold text-gray-900">Recent Users</h3>
      <%= link_to "View All", admin_users_path, class: "text-sm text-blue-600 hover:text-blue-700 font-medium" %>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Credits</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Resumes</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Joined</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @recent_users.each do |user| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <img src="<%= user.avatar_url(variant: :thumb) %>" alt="" class="w-8 h-8 rounded-full object-cover">
                  <div class="ml-3">
                    <p class="text-sm font-medium text-gray-900">
                      <%= link_to user.full_name, admin_user_path(user), class: "hover:text-blue-600" %>
                    </p>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= user.email %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= user.credits_remaining %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= user.resumes.count %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= time_ago_in_words(user.created_at) %> ago</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
