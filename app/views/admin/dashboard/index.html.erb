<div class="p-6 lg:p-8" data-controller="currency-toggle" data-currency-toggle-rate-value="1600">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
      <p class="text-sm text-gray-500 mt-1">Overview of your platform metrics</p>
    </div>
    <div class="flex items-center gap-3">
      <!-- Currency Toggle -->
      <div class="flex items-center bg-white border border-gray-200 rounded-lg p-0.5">
        <button type="button" data-action="click->currency-toggle#showNGN" data-currency-toggle-target="ngnBtn"
          class="px-3 py-1.5 text-xs font-semibold rounded-md bg-blue-600 text-white transition-colors">
          NGN
        </button>
        <button type="button" data-action="click->currency-toggle#showUSD" data-currency-toggle-target="usdBtn"
          class="px-3 py-1.5 text-xs font-semibold rounded-md text-gray-500 hover:text-gray-700 transition-colors">
          USD
        </button>
      </div>
      <!-- Reports Dropdown -->
      <div class="relative" data-controller="dropdown">
        <button data-action="click->dropdown#toggle" class="inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Export Report
        </button>
        <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-gray-100 py-1 z-10">
          <%= link_to admin_report_path(type: "revenue", format: :csv), class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" do %>
            Revenue Report (CSV)
          <% end %>
          <%= link_to admin_report_path(type: "users", format: :csv), class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" do %>
            Users Report (CSV)
          <% end %>
          <%= link_to admin_report_path(type: "subscriptions", format: :csv), class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" do %>
            Subscriptions Report (CSV)
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Revenue Stats -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="bg-gradient-to-br from-green-500 to-emerald-600 rounded-xl shadow-sm p-5 text-white">
      <p class="text-xs font-medium text-green-100 uppercase tracking-wider">Total Revenue</p>
      <p class="text-2xl font-bold mt-1" data-currency-toggle-target="amount" data-ngn="<%= number_to_currency(@total_revenue_kobo / 100.0, unit: '₦', delimiter: ',', precision: 0) %>" data-usd="<%= number_to_currency(@total_revenue_kobo / 100.0 / 1600, unit: '$', delimiter: ',', precision: 0) %>">
        <%= number_to_currency(@total_revenue_kobo / 100.0, unit: "₦", delimiter: ",", precision: 0) %>
      </p>
    </div>
    <div class="bg-gradient-to-br from-blue-500 to-indigo-600 rounded-xl shadow-sm p-5 text-white">
      <p class="text-xs font-medium text-blue-100 uppercase tracking-wider">This Month</p>
      <p class="text-2xl font-bold mt-1" data-currency-toggle-target="amount" data-ngn="<%= number_to_currency(@revenue_this_month_kobo / 100.0, unit: '₦', delimiter: ',', precision: 0) %>" data-usd="<%= number_to_currency(@revenue_this_month_kobo / 100.0 / 1600, unit: '$', delimiter: ',', precision: 0) %>">
        <%= number_to_currency(@revenue_this_month_kobo / 100.0, unit: "₦", delimiter: ",", precision: 0) %>
      </p>
      <% if @revenue_last_month_kobo > 0 %>
        <% change = ((@revenue_this_month_kobo - @revenue_last_month_kobo) * 100.0 / @revenue_last_month_kobo).round(0) %>
        <p class="text-xs mt-1 <%= change >= 0 ? 'text-green-200' : 'text-red-200' %>"><%= change >= 0 ? '+' : '' %><%= change %>% vs last month</p>
      <% end %>
    </div>
    <div class="bg-gradient-to-br from-purple-500 to-pink-600 rounded-xl shadow-sm p-5 text-white">
      <p class="text-xs font-medium text-purple-100 uppercase tracking-wider">Today</p>
      <p class="text-2xl font-bold mt-1" data-currency-toggle-target="amount" data-ngn="<%= number_to_currency(@revenue_today_kobo / 100.0, unit: '₦', delimiter: ',', precision: 0) %>" data-usd="<%= number_to_currency(@revenue_today_kobo / 100.0 / 1600, unit: '$', delimiter: ',', precision: 0) %>">
        <%= number_to_currency(@revenue_today_kobo / 100.0, unit: "₦", delimiter: ",", precision: 0) %>
      </p>
    </div>
    <div class="bg-gradient-to-br from-amber-500 to-orange-600 rounded-xl shadow-sm p-5 text-white">
      <p class="text-xs font-medium text-amber-100 uppercase tracking-wider">Credits Sold</p>
      <p class="text-2xl font-bold mt-1"><%= number_with_delimiter(@total_credits_sold) %></p>
    </div>
  </div>

  <!-- Platform Stats -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Total Users</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= number_with_delimiter(@total_users) %></p>
      <p class="text-xs text-green-600 mt-1">+<%= @new_users_this_week %> this week</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Subscribers</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= number_with_delimiter(@active_subscribers) %></p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Resumes</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= number_with_delimiter(@total_resumes) %></p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Cover Letters</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= number_with_delimiter(@total_cover_letters) %></p>
    </div>
  </div>

  <!-- Revenue Breakdown + Charts -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <!-- Revenue by Type -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <h3 class="text-sm font-semibold text-gray-900 mb-4">Revenue Breakdown</h3>
      <div class="space-y-4">
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-gray-500">Credit Purchases</span>
            <span class="font-semibold text-gray-900" data-currency-toggle-target="amount" data-ngn="<%= number_to_currency(@credit_revenue_kobo / 100.0, unit: '₦', delimiter: ',', precision: 0) %>" data-usd="<%= number_to_currency(@credit_revenue_kobo / 100.0 / 1600, unit: '$', delimiter: ',', precision: 0) %>">
              <%= number_to_currency(@credit_revenue_kobo / 100.0, unit: "₦", delimiter: ",", precision: 0) %>
            </span>
          </div>
          <% credit_pct = @total_revenue_kobo > 0 ? (@credit_revenue_kobo * 100.0 / @total_revenue_kobo).round : 0 %>
          <div class="w-full bg-gray-100 rounded-full h-2">
            <div class="bg-blue-500 h-2 rounded-full" style="width: <%= credit_pct %>%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-gray-500">Subscriptions</span>
            <span class="font-semibold text-gray-900" data-currency-toggle-target="amount" data-ngn="<%= number_to_currency(@subscription_revenue_kobo / 100.0, unit: '₦', delimiter: ',', precision: 0) %>" data-usd="<%= number_to_currency(@subscription_revenue_kobo / 100.0 / 1600, unit: '$', delimiter: ',', precision: 0) %>">
              <%= number_to_currency(@subscription_revenue_kobo / 100.0, unit: "₦", delimiter: ",", precision: 0) %>
            </span>
          </div>
          <div class="w-full bg-gray-100 rounded-full h-2">
            <div class="bg-purple-500 h-2 rounded-full" style="width: <%= 100 - credit_pct %>%"></div>
          </div>
        </div>
      </div>

      <% if @subscription_by_plan.any? %>
        <hr class="my-4 border-gray-100">
        <h4 class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-3">Active Plans</h4>
        <div class="space-y-2">
          <% @subscription_by_plan.each do |plan_id, count| %>
            <div class="flex justify-between text-sm">
              <span class="text-gray-600"><%= plan_id.to_s.gsub("price_", "").titleize %></span>
              <span class="font-semibold text-gray-900"><%= count %></span>
            </div>
          <% end %>
        </div>
      <% end %>

      <!-- Payment Funnel -->
      <% if @payment_funnel.any? %>
        <hr class="my-4 border-gray-100">
        <h4 class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-3">Payment Status</h4>
        <div class="space-y-2">
          <% @payment_funnel.sort_by { |_, v| -v }.each do |status, count| %>
            <div class="flex justify-between text-sm">
              <span class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full <%= status == 'success' ? 'bg-green-500' : status == 'pending' ? 'bg-yellow-500' : 'bg-gray-400' %>"></span>
                <span class="text-gray-600"><%= status.humanize %></span>
              </span>
              <span class="font-semibold text-gray-900"><%= count %></span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Revenue Chart -->
    <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <h3 class="text-sm font-semibold text-gray-900 mb-4">Revenue (Last 30 Days) — NGN</h3>
      <%= area_chart @revenue_growth, colors: ["#16a34a"], library: { plugins: { legend: { display: false } } } %>
    </div>
  </div>

  <!-- Charts Row 2 -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <h3 class="text-sm font-semibold text-gray-900 mb-4">User Signups (Last 30 Days)</h3>
      <%= line_chart @user_growth, colors: ["#2563eb"], library: { plugins: { legend: { display: false } } } %>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <h3 class="text-sm font-semibold text-gray-900 mb-4">Resumes Created (Last 30 Days)</h3>
      <%= line_chart @resume_growth, colors: ["#7c3aed"], library: { plugins: { legend: { display: false } } } %>
    </div>
  </div>

  <!-- Geography + Traffic Sources -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <!-- Revenue by Country -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h3 class="text-sm font-semibold text-gray-900">Revenue by Country</h3>
      </div>
      <% if @revenue_by_country.any? %>
        <div class="divide-y divide-gray-50">
          <% @revenue_by_country.each do |country_code, amount_kobo| %>
            <div class="px-6 py-3 flex items-center justify-between">
              <span class="text-sm text-gray-700">
                <% country_name = country_code != "Unknown" ? (ISO3166::Country[country_code]&.common_name || country_code) : "Unknown" %>
                <%= country_name %>
              </span>
              <span class="text-sm font-semibold text-gray-900" data-currency-toggle-target="amount" data-ngn="<%= number_to_currency(amount_kobo / 100.0, unit: '₦', delimiter: ',', precision: 0) %>" data-usd="<%= number_to_currency(amount_kobo / 100.0 / 1600, unit: '$', delimiter: ',', precision: 0) %>">
                <%= number_to_currency(amount_kobo / 100.0, unit: "₦", delimiter: ",", precision: 0) %>
              </span>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="px-6 py-8 text-center text-sm text-gray-500">No revenue data yet</div>
      <% end %>
    </div>

    <!-- Users by Country + Traffic Sources -->
    <div class="space-y-6">
      <!-- Users by Country -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
          <h3 class="text-sm font-semibold text-gray-900">Users by Country</h3>
        </div>
        <% if @users_by_country.any? %>
          <div class="divide-y divide-gray-50">
            <% @users_by_country.first(5).each do |country_code, count| %>
              <div class="px-6 py-2.5 flex items-center justify-between">
                <span class="text-sm text-gray-700"><%= ISO3166::Country[country_code]&.common_name || country_code %></span>
                <span class="text-sm font-semibold text-gray-900"><%= count %></span>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="px-6 py-6 text-center text-sm text-gray-500">No country data yet</div>
        <% end %>
      </div>

      <!-- Traffic Sources -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
          <h3 class="text-sm font-semibold text-gray-900">Traffic Sources (30 days)</h3>
        </div>
        <% if @traffic_sources.any? %>
          <div class="divide-y divide-gray-50">
            <% @traffic_sources.first(5).each do |domain, count| %>
              <div class="px-6 py-2.5 flex items-center justify-between">
                <span class="text-sm text-gray-700"><%= domain %></span>
                <span class="text-sm font-semibold text-gray-900"><%= count %> visits</span>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="px-6 py-6 text-center text-sm text-gray-500">No traffic data yet</div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Recent Users -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-6">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
      <h3 class="text-sm font-semibold text-gray-900">Recent Users</h3>
      <%= link_to "View All", admin_users_path, class: "text-sm text-blue-600 hover:text-blue-700 font-medium" %>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Country</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Credits</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Joined</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @recent_users.each do |user| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <img src="<%= user.avatar_url(variant: :thumb) %>" alt="" class="w-8 h-8 rounded-full object-cover">
                  <div class="ml-3">
                    <p class="text-sm font-medium text-gray-900">
                      <%= link_to user.full_name, admin_user_path(user), class: "hover:text-blue-600" %>
                    </p>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= user.email %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= user.country_code.present? ? (ISO3166::Country[user.country_code]&.common_name || user.country_code) : "—" %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= user.credits_remaining %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= time_ago_in_words(user.created_at) %> ago</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Recent Payments -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
      <h3 class="text-sm font-semibold text-gray-900">Recent Payments</h3>
    </div>
    <% if @recent_payments.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Country</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @recent_payments.each do |payment| %>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap">
                  <%= link_to payment.user.full_name, admin_user_path(payment.user), class: "text-sm font-medium text-gray-900 hover:text-blue-600" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= payment.user.country_code.present? ? (ISO3166::Country[payment.user.country_code]&.common_name || payment.user.country_code) : "—" %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= payment.description_display %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-green-600"><%= payment.amount_display %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= time_ago_in_words(payment.created_at) %> ago</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-6 py-8 text-center text-sm text-gray-500">No payments yet</div>
    <% end %>
  </div>
</div>
