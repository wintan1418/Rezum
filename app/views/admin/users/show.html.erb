<div class="p-6 lg:p-8">
  <!-- Header -->
  <div class="flex items-center gap-3 mb-6">
    <%= link_to admin_users_path, class: "text-gray-400 hover:text-gray-600 transition-colors" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>
    <h1 class="text-2xl font-bold text-gray-900"><%= @user.full_name %></h1>
    <% if @user.admin? %>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">Admin</span>
    <% end %>
    <% if @user.disabled? %>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Disabled</span>
    <% end %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- User Info Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <div class="flex items-center mb-6">
        <img src="<%= @user.avatar_url(variant: :large) %>" alt="" class="w-16 h-16 rounded-full object-cover">
        <div class="ml-4">
          <h2 class="text-lg font-semibold text-gray-900"><%= @user.full_name %></h2>
          <p class="text-sm text-gray-500"><%= @user.email %></p>
        </div>
      </div>

      <div class="space-y-3 text-sm">
        <div class="flex justify-between">
          <span class="text-gray-500">Plan</span>
          <span class="font-medium text-gray-900"><%= @user.has_active_subscription? ? "Pro" : "Free" %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500">Credits</span>
          <span class="font-medium text-gray-900"><%= @user.credits_remaining %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500">Joined</span>
          <span class="font-medium text-gray-900"><%= @user.created_at.strftime("%b %d, %Y") %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500">Resumes</span>
          <span class="font-medium text-gray-900"><%= @user.resumes.count %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500">Cover Letters</span>
          <span class="font-medium text-gray-900"><%= @user.cover_letters.count %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500">Total Spent</span>
          <span class="font-medium text-gray-900"><%= number_to_currency(@user.total_spent) %></span>
        </div>
      </div>

      <!-- Admin Actions -->
      <div class="mt-6 pt-6 border-t border-gray-100 space-y-2">
        <%= link_to toggle_admin_admin_user_path(@user), data: { turbo_method: :patch, turbo_confirm: "#{@user.admin? ? 'Remove' : 'Grant'} admin access for #{@user.full_name}?" }, class: "w-full inline-flex items-center justify-center px-4 py-2 text-sm font-medium rounded-xl transition-all #{@user.admin? ? 'bg-yellow-50 text-yellow-700 border border-yellow-200 hover:bg-yellow-100' : 'bg-purple-50 text-purple-700 border border-purple-200 hover:bg-purple-100'}" do %>
          <%= @user.admin? ? "Remove Admin" : "Make Admin" %>
        <% end %>

        <%= link_to toggle_disable_admin_user_path(@user), data: { turbo_method: :patch, turbo_confirm: "#{@user.disabled? ? 'Enable' : 'Disable'} #{@user.full_name}'s account?" }, class: "w-full inline-flex items-center justify-center px-4 py-2 text-sm font-medium rounded-xl transition-all #{@user.disabled? ? 'bg-green-50 text-green-700 border border-green-200 hover:bg-green-100' : 'bg-red-50 text-red-700 border border-red-200 hover:bg-red-100'}" do %>
          <%= @user.disabled? ? "Enable Account" : "Disable Account" %>
        <% end %>
      </div>

      <!-- Gift Credits -->
      <div class="mt-6 pt-6 border-t border-gray-100">
        <h3 class="text-sm font-semibold text-gray-900 mb-3">Gift Credits</h3>
        <%= form_with url: gift_credits_admin_user_path(@user), method: :post, class: "space-y-3" do |f| %>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Number of credits</label>
            <input type="number" name="credits" min="1" max="500" value="10" required class="w-full px-3 py-2 text-sm border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Reason (shown in email)</label>
            <input type="text" name="reason" placeholder="e.g. Welcome bonus, contest prize..." class="w-full px-3 py-2 text-sm border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
          </div>
          <button type="submit" data-turbo-confirm="Gift credits to <%= @user.full_name %>? They will receive an email notification." class="w-full inline-flex items-center justify-center px-4 py-2 text-sm font-medium rounded-xl transition-all bg-blue-50 text-blue-700 border border-blue-200 hover:bg-blue-100">
            <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/>
            </svg>
            Gift Credits
          </button>
        <% end %>
      </div>
    </div>

    <!-- Activity -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Resumes -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
          <h3 class="text-sm font-semibold text-gray-900">Resumes (<%= @resumes.count %>)</h3>
        </div>
        <% if @resumes.any? %>
          <div class="divide-y divide-gray-100">
            <% @resumes.each do |resume| %>
              <div class="px-6 py-3 flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= resume.target_role.presence || "Untitled" %></p>
                  <p class="text-xs text-gray-500"><%= resume.created_at.strftime("%b %d, %Y") %></p>
                </div>
                <span class="text-xs font-medium px-2 py-0.5 rounded-full <%= resume.status == 'optimized' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600' %>">
                  <%= resume.status.humanize %>
                </span>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="px-6 py-4 text-sm text-gray-500">No resumes yet.</p>
        <% end %>
      </div>

      <!-- Cover Letters -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
          <h3 class="text-sm font-semibold text-gray-900">Cover Letters (<%= @cover_letters.count %>)</h3>
        </div>
        <% if @cover_letters.any? %>
          <div class="divide-y divide-gray-100">
            <% @cover_letters.each do |cl| %>
              <div class="px-6 py-3 flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= cl.company_name.presence || "Untitled" %></p>
                  <p class="text-xs text-gray-500"><%= cl.created_at.strftime("%b %d, %Y") %></p>
                </div>
                <span class="text-xs font-medium px-2 py-0.5 rounded-full <%= cl.status == 'generated' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600' %>">
                  <%= cl.status.humanize %>
                </span>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="px-6 py-4 text-sm text-gray-500">No cover letters yet.</p>
        <% end %>
      </div>

      <!-- Payments -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
          <h3 class="text-sm font-semibold text-gray-900">Payments (<%= @payments.count %>)</h3>
        </div>
        <% if @payments.any? %>
          <div class="divide-y divide-gray-100">
            <% @payments.each do |payment| %>
              <div class="px-6 py-3 flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= payment.description.presence || payment.payment_type %></p>
                  <p class="text-xs text-gray-500"><%= payment.created_at.strftime("%b %d, %Y") %></p>
                </div>
                <span class="text-sm font-medium text-gray-900"><%= number_to_currency(payment.amount_cents / 100.0) %></span>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="px-6 py-4 text-sm text-gray-500">No payments yet.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
