<div class="p-6 sm:p-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Hire Messages</h1>
      <p class="text-sm text-gray-500 mt-1">
        <%= @unread_count %> unread &middot; <%= @messages.count %> total
      </p>
    </div>
  </div>

  <% if @messages.any? %>
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Sender</th>
            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Message</th>
            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
            <th class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @messages.each do |message| %>
            <tr class="<%= message.read? ? 'bg-white' : 'bg-blue-50/50' %> hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <% unless message.read? %>
                    <span class="w-2 h-2 bg-blue-500 rounded-full shrink-0"></span>
                  <% end %>
                  <div>
                    <p class="text-sm font-semibold text-gray-900 <%= 'ml-5' if message.read? %>"><%= message.name %></p>
                    <p class="text-xs text-gray-500 <%= 'ml-5' if message.read? %>"><%= message.email %></p>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4">
                <p class="text-sm text-gray-600 truncate max-w-xs"><%= truncate(message.message, length: 80) %></p>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <p class="text-sm text-gray-500"><%= time_ago_in_words(message.created_at) %> ago</p>
              </td>
              <td class="px-6 py-4 text-right whitespace-nowrap">
                <%= link_to "View", admin_hire_message_path(message), class: "text-sm text-blue-600 hover:underline font-medium" %>
                <%= link_to "Delete", admin_hire_message_path(message), data: { turbo_method: :delete, turbo_confirm: "Delete this message?" }, class: "text-sm text-red-600 hover:underline font-medium ml-3" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white rounded-xl border border-gray-200 p-12 text-center">
      <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
      </svg>
      <p class="text-gray-500 text-sm">No hire messages yet.</p>
      <p class="text-gray-400 text-xs mt-1">When someone sends a message via your blog, it will appear here.</p>
    </div>
  <% end %>
</div>
