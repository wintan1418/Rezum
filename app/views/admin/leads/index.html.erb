<div class="p-6 sm:p-8">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Leads CRM</h1>
      <p class="text-sm text-gray-500 mt-1">Email leads captured from ATS checker, landing pages, and other sources.</p>
    </div>
    <div class="mt-4 sm:mt-0 flex items-center gap-3">
      <%= link_to export_admin_leads_path(source: params[:source], format: :csv), class: "inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-200 hover:bg-gray-50 rounded-xl transition-colors" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Export CSV
      <% end %>
    </div>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 text-center">
      <p class="text-3xl font-extrabold text-gray-900"><%= @total %></p>
      <p class="text-xs text-gray-500 mt-1 font-medium">Total Leads</p>
    </div>
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 text-center">
      <p class="text-3xl font-extrabold text-green-600"><%= @today %></p>
      <p class="text-xs text-gray-500 mt-1 font-medium">Today</p>
    </div>
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 text-center">
      <p class="text-3xl font-extrabold text-blue-600"><%= @this_week %></p>
      <p class="text-xs text-gray-500 mt-1 font-medium">This Week</p>
    </div>
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 text-center">
      <p class="text-3xl font-extrabold text-purple-600"><%= @sources.length %></p>
      <p class="text-xs text-gray-500 mt-1 font-medium">Sources</p>
    </div>
  </div>

  <!-- Sources Filter -->
  <% if @sources.any? %>
    <div class="flex flex-wrap items-center gap-2 mb-6">
      <%= link_to "All", admin_leads_path, class: "px-3 py-1.5 text-xs font-semibold rounded-full transition-colors #{params[:source].blank? ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
      <% @sources.each do |source, count| %>
        <%= link_to admin_leads_path(source: source), class: "px-3 py-1.5 text-xs font-semibold rounded-full transition-colors #{params[:source] == source ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" do %>
          <%= source.humanize %> (<%= count %>)
        <% end %>
      <% end %>
    </div>
  <% end %>

  <!-- Search -->
  <div class="mb-6">
    <%= form_tag admin_leads_path, method: :get, class: "flex gap-2" do %>
      <%= hidden_field_tag :source, params[:source] if params[:source].present? %>
      <input type="text" name="q" value="<%= params[:q] %>" placeholder="Search by email..." class="flex-1 rounded-xl border border-gray-200 bg-white shadow-sm px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all hover:border-gray-300">
      <button type="submit" class="px-4 py-2.5 text-sm font-medium text-white bg-gradient-to-r from-blue-600 to-purple-600 rounded-xl shadow-sm transition-all cursor-pointer">Search</button>
    <% end %>
  </div>

  <!-- Leads Table -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <% if @leads.any? %>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-100">
              <th class="text-left py-3 px-5 text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th>
              <th class="text-left py-3 px-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Source</th>
              <th class="text-left py-3 px-4 text-xs font-semibold text-gray-500 uppercase tracking-wider hidden sm:table-cell">IP</th>
              <th class="text-left py-3 px-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
              <th class="text-right py-3 px-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
              <th class="py-3 px-4"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% @leads.each do |lead| %>
              <% is_user = User.exists?(email: lead.email) %>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="py-3 px-5">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-600 to-purple-600 flex items-center justify-center text-white text-xs font-bold shrink-0">
                      <%= lead.email.first.upcase %>
                    </div>
                    <span class="text-sm font-medium text-gray-900 truncate max-w-[200px]"><%= lead.email %></span>
                  </div>
                </td>
                <td class="py-3 px-4">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700"><%= lead.source&.humanize || "Unknown" %></span>
                </td>
                <td class="py-3 px-4 text-sm text-gray-500 hidden sm:table-cell"><%= lead.ip_address || "—" %></td>
                <td class="py-3 px-4 text-sm text-gray-500"><%= lead.created_at.strftime("%b %d, %H:%M") %></td>
                <td class="py-3 px-4 text-right">
                  <% if is_user %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700">Signed Up</span>
                  <% else %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700">Lead</span>
                  <% end %>
                </td>
                <td class="py-3 px-4 text-right">
                  <%= link_to admin_lead_path(lead), data: { turbo_method: :delete, turbo_confirm: "Delete this lead?" }, class: "text-gray-400 hover:text-red-500 transition-colors" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="p-12 text-center">
        <div class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </div>
        <h3 class="text-sm font-semibold text-gray-900 mb-1">No leads yet</h3>
        <p class="text-sm text-gray-500">Leads will appear here when visitors enter their email on the ATS checker.</p>
      </div>
    <% end %>
  </div>
</div>
