<div class="space-y-4">
  <% if slide.content["description"].present? %>
    <p class="text-gray-700"><%= slide.content["description"] %></p>
  <% end %>
  <% if slide.content["metrics"].is_a?(Array) %>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-4">
      <% slide.content["metrics"].each do |metric| %>
        <div class="text-center bg-purple-50 rounded-xl p-4 border border-purple-100">
          <p class="text-2xl font-bold text-purple-900"><%= metric["value"] %></p>
          <p class="text-xs text-purple-600 font-medium"><%= metric["label"] %></p>
          <% if metric["growth"].present? %>
            <span class="inline-flex items-center text-xs font-semibold text-green-700 mt-1"><%= metric["growth"] %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
  <% if slide.content["milestones"].is_a?(Array) %>
    <div class="mt-4">
      <h4 class="text-sm font-semibold text-gray-700 mb-2">Key Milestones</h4>
      <div class="space-y-2">
        <% slide.content["milestones"].each do |m| %>
          <div class="flex items-center space-x-3">
            <span class="text-xs font-medium text-gray-400 w-20 flex-shrink-0"><%= m["date"] %></span>
            <div class="w-2 h-2 rounded-full bg-purple-400 flex-shrink-0"></div>
            <span class="text-sm text-gray-700"><%= m["milestone"] %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
  <% if slide.content["social_proof"].present? %>
    <p class="text-sm text-gray-600 bg-gray-50 p-3 rounded-xl mt-2"><%= slide.content["social_proof"] %></p>
  <% end %>
</div>
