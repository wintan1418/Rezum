<div class="min-h-full">
  <main class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Pitch Decks</h1>
        <p class="mt-1 text-gray-500">AI-generated investor pitch decks</p>
      </div>
      <%= link_to new_pitch_deck_path, class: "inline-flex items-center px-5 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 rounded-xl shadow-sm hover:shadow transition-all" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
        </svg>
        New Pitch Deck
      <% end %>
    </div>

    <% if @pitch_decks.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @pitch_decks.each do |deck| %>
          <%= link_to pitch_deck_path(deck), class: "group bg-white rounded-2xl shadow-sm border border-gray-100 hover:shadow-md hover:border-purple-200 transition-all overflow-hidden" do %>
            <div class="h-2 bg-gradient-to-r <%= deck.completed? ? 'from-green-400 to-emerald-500' : deck.generating? ? 'from-amber-400 to-orange-500' : deck.failed? ? 'from-red-400 to-red-500' : 'from-gray-300 to-gray-400' %>"></div>
            <div class="p-5">
              <div class="flex items-center justify-between mb-3">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold
                  <%= case deck.status
                      when 'completed' then 'bg-green-100 text-green-800'
                      when 'generating' then 'bg-amber-100 text-amber-800'
                      when 'failed' then 'bg-red-100 text-red-800'
                      else 'bg-gray-100 text-gray-700'
                      end %>">
                  <%= deck.status.capitalize %>
                </span>
                <span class="text-xs text-gray-400"><%= deck.template.capitalize %></span>
              </div>
              <h3 class="text-lg font-bold text-gray-900 group-hover:text-purple-700 transition-colors truncate"><%= deck.company_name %></h3>
              <% if deck.tagline.present? %>
                <p class="text-sm text-gray-500 mt-1 truncate"><%= deck.tagline %></p>
              <% end %>
              <div class="flex items-center justify-between mt-4 text-xs text-gray-400">
                <span><%= deck.industry || "General" %></span>
                <span><%= time_ago_in_words(deck.created_at) %> ago</span>
              </div>
              <% if deck.generating? %>
                <div class="mt-3 h-1.5 bg-gray-100 rounded-full overflow-hidden">
                  <div class="h-full bg-gradient-to-r from-amber-400 to-orange-500 rounded-full animate-pulse" style="width: 60%"></div>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-12 text-center">
        <div class="w-16 h-16 rounded-full bg-purple-50 flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/>
          </svg>
        </div>
        <h3 class="text-sm font-semibold text-gray-900 mb-1">No pitch decks yet</h3>
        <p class="text-sm text-gray-500 mb-4">Create your first AI-powered pitch deck to impress investors.</p>
        <%= link_to new_pitch_deck_path, class: "inline-flex items-center px-4 py-2 text-sm font-semibold text-white bg-gradient-to-r from-purple-600 to-pink-600 rounded-lg hover:from-purple-700 hover:to-pink-700 transition-all shadow-sm" do %>
          Create Pitch Deck
        <% end %>
      </div>
    <% end %>
  </main>
</div>
