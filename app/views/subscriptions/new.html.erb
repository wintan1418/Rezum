<div class="min-h-full">
  <main class="max-w-6xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Choose Your Plan</h1>
      <p class="mt-2 text-gray-500">Unlock AI-powered tools to supercharge your job search</p>
    </div>

    <!-- Plans -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-5 max-w-5xl mx-auto mb-16">
      <% @plans.each do |plan| %>
        <div class="<%= plan[:tier] == 'premium' ? 'border-2 border-purple-400 relative shadow-lg' : 'border border-gray-200' %> rounded-2xl bg-white flex flex-col">
          <% if plan[:tier] == 'premium' && plan[:interval] == 'year' %>
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
              <span class="px-4 py-1 text-xs font-bold text-white bg-gradient-to-r from-purple-600 to-pink-600 rounded-full shadow-md whitespace-nowrap">Best Value</span>
            </div>
          <% elsif plan[:tier] == 'pro' && plan[:interval] == 'year' %>
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 relative">
              <span class="px-4 py-1 text-xs font-bold text-white bg-gradient-to-r from-blue-600 to-purple-600 rounded-full shadow-md">Popular</span>
            </div>
          <% end %>

          <div class="p-6 flex-1 flex flex-col">
            <div class="text-center mb-5">
              <div class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold mb-2
                <%= plan[:tier] == 'premium' ? 'bg-purple-100 text-purple-800' : 'bg-blue-100 text-blue-800' %>">
                <%= plan[:tier].humanize %>
              </div>
              <h3 class="text-lg font-bold text-gray-900"><%= plan[:name] %></h3>
              <div class="mt-2 flex items-baseline justify-center">
                <span class="text-2xl font-bold text-gray-900"><%= plan[:price_label] %></span>
                <span class="ml-1 text-gray-500">/<%= plan[:interval] %></span>
              </div>
              <% if plan[:interval] == 'year' %>
                <p class="mt-1 text-xs font-medium text-green-600">2 months free</p>
              <% end %>
            </div>

            <ul class="space-y-2.5 mb-6 flex-1">
              <% plan[:features].each do |feature| %>
                <li class="flex items-start text-sm text-gray-600">
                  <svg class="w-4 h-4 mr-2 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  <%= feature %>
                </li>
              <% end %>
            </ul>

            <%= form_with model: @subscription, url: subscriptions_path, method: :post, data: { turbo: false } do |f| %>
              <%= hidden_field_tag :plan_id, plan[:id] %>
              <%= f.submit "Choose #{plan[:tier].humanize}", class: "w-full px-5 py-2.5 rounded-xl text-sm font-semibold transition-all cursor-pointer #{plan[:tier] == 'premium' ? 'text-white bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 shadow-md' : 'text-gray-700 bg-gray-100 hover:bg-gray-200'}" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Full Feature Comparison -->
    <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden mb-8">
      <div class="px-6 py-5 bg-gray-50 border-b border-gray-200">
        <h3 class="text-lg font-bold text-gray-900 text-center">Full Feature Comparison</h3>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-gray-100">
              <th class="text-left py-3 px-5 text-sm font-medium text-gray-500">Feature</th>
              <th class="text-center py-3 px-4 text-sm font-medium text-gray-500">Free</th>
              <th class="text-center py-3 px-4 text-sm font-medium text-blue-600">Pro</th>
              <th class="text-center py-3 px-4 text-sm font-medium text-purple-600">Premium</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% [
              ["Resume Optimization", "2 credits", true, true],
              ["Cover Letter Generation", "1 credit each", true, true],
              ["ATS Score & Keywords", "2 credits", true, true],
              ["AI Resume Builder", "10 credits", true, "Free"],
              ["AI Pitch Decks", "30 credits each", "30 credits each", "Unlimited"],
              ["5 Professional Templates", true, true, true],
              ["PDF & DOCX Downloads", true, true, true],
              ["Job Application Tracker", true, true, true],
              ["Priority Support", false, true, true],
              ["AI Interview Prep", false, false, true],
              ["LinkedIn Optimization", false, false, true],
              ["Automated Job Scraper", false, false, true],
              ["AI Job Matching", false, false, true],
              ["Priority AI Models", false, false, true],
              ["Early Access Features", false, false, true]
            ].each do |feature, free_val, pro, premium| %>
              <tr class="hover:bg-gray-50">
                <td class="py-3 px-5 text-sm text-gray-700"><%= feature %></td>
                <td class="py-3 px-4 text-center">
                  <% if free_val == true %>
                    <svg class="w-5 h-5 text-green-500 mx-auto" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  <% elsif free_val == false %>
                    <svg class="w-5 h-5 text-gray-300 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                  <% else %>
                    <span class="text-xs text-gray-500"><%= free_val %></span>
                  <% end %>
                </td>
                <td class="py-3 px-4 text-center">
                  <% if pro %>
                    <svg class="w-5 h-5 text-green-500 mx-auto" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  <% else %>
                    <svg class="w-5 h-5 text-gray-300 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                  <% end %>
                </td>
                <td class="py-3 px-4 text-center">
                  <% if premium %>
                    <svg class="w-5 h-5 text-green-500 mx-auto" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  <% else %>
                    <svg class="w-5 h-5 text-gray-300 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Premium Feature Highlight -->
    <div class="bg-gradient-to-r from-purple-50 to-pink-50 border border-purple-200 rounded-2xl p-8 mb-8">
      <h3 class="text-lg font-bold text-gray-900 text-center mb-2">Premium Exclusive: AI-Powered Job Search</h3>
      <p class="text-sm text-gray-600 text-center mb-6">Let AI find, match, and prepare you for the perfect opportunities</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 text-sm">Job Scraper</h4>
          <p class="text-xs text-gray-500 mt-1">Auto-discover matching jobs from Google Jobs</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 text-sm">Interview Prep</h4>
          <p class="text-xs text-gray-500 mt-1">Role-specific questions with STAR answers</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-purple-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 3a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h14m-.5 15.5v-5.3a3.26 3.26 0 00-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 011.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 001.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 00-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 text-sm">LinkedIn AI</h4>
          <p class="text-xs text-gray-500 mt-1">Optimize headline, about & experience</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900 text-sm">Match Scoring</h4>
          <p class="text-xs text-gray-500 mt-1">AI scores each job against your resume</p>
        </div>
      </div>
    </div>

    <!-- Powered by Paystack badge -->
    <div class="text-center mt-8">
      <p class="text-xs text-gray-400">Secure payments powered by Paystack</p>
      <%= link_to billing_index_path, class: "text-sm text-gray-500 hover:text-gray-700 transition-colors" do %>
        &larr; Back to Billing
      <% end %>
    </div>
  </main>
</div>
