<div class="min-h-full">
  <main class="max-w-6xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Choose Your Plan</h1>
      <p class="mt-2 text-gray-500">Unlock AI-powered tools to supercharge your job search</p>
    </div>

    <!-- Plans -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-5 max-w-5xl mx-auto mb-16">
      <% @plans.each do |plan| %>
        <div class="<%= plan[:tier] == 'premium' ? 'border-2 border-purple-400 relative shadow-lg' : 'border border-gray-200' %> rounded-2xl bg-white flex flex-col">
          <% if plan[:tier] == 'premium' && plan[:interval] == 'year' %>
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
              <span class="px-4 py-1 text-xs font-bold text-white bg-gradient-to-r from-purple-600 to-pink-600 rounded-full shadow-md whitespace-nowrap">Best Value</span>
            </div>
          <% elsif plan[:tier] == 'pro' && plan[:interval] == 'year' %>
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 relative">
              <span class="px-4 py-1 text-xs font-bold text-white bg-gradient-to-r from-blue-600 to-purple-600 rounded-full shadow-md">Popular</span>
            </div>
          <% end %>

          <div class="p-6 flex-1 flex flex-col">
            <div class="text-center mb-5">
              <div class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold mb-2
                <%= plan[:tier] == 'premium' ? 'bg-purple-100 text-purple-800' : 'bg-blue-100 text-blue-800' %>">
                <%= plan[:tier].humanize %>
              </div>
              <h3 class="text-lg font-bold text-gray-900"><%= plan[:name] %></h3>
              <div class="mt-2 flex items-baseline justify-center">
                <span class="text-2xl font-bold text-gray-900"><%= plan[:price_label] %></span>
                <span class="ml-1 text-gray-500">/<%= plan[:interval] %></span>
              </div>
              <% if plan[:interval] == 'year' %>
                <p class="mt-1 text-xs font-medium text-green-600">2 months free</p>
              <% end %>
            </div>

            <ul class="space-y-2.5 mb-6 flex-1">
              <% plan[:features].each do |feature| %>
                <li class="flex items-start text-sm text-gray-600">
                  <svg class="w-4 h-4 mr-2 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  <%= feature %>
                </li>
              <% end %>
            </ul>

            <%= form_with model: @subscription, url: subscriptions_path, method: :post, local: true do |f| %>
              <%= hidden_field_tag :plan_id, plan[:id] %>
              <%= f.submit "Choose #{plan[:tier].humanize}", class: "w-full px-5 py-2.5 rounded-xl text-sm font-semibold transition-all cursor-pointer #{plan[:tier] == 'premium' ? 'text-white bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 shadow-md' : 'text-gray-700 bg-gray-100 hover:bg-gray-200'}" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Premium Feature Highlight -->
    <div class="bg-gradient-to-r from-purple-50 to-pink-50 border border-purple-200 rounded-2xl p-8 mb-8">
      <h3 class="text-lg font-bold text-gray-900 text-center mb-2">Premium Exclusive: AI Job Scraper</h3>
      <p class="text-sm text-gray-600 text-center mb-6">Automatically discover and match jobs to your resume using AI</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900">Smart Job Discovery</h4>
          <p class="text-sm text-gray-500 mt-1">Scrapes jobs from Google Jobs matching your resume and skills</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900">Match Scoring</h4>
          <p class="text-sm text-gray-500 mt-1">AI scores each job against your resume for best fit</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h4 class="font-semibold text-gray-900">Automated Scraping</h4>
          <p class="text-sm text-gray-500 mt-1">Set it and forget it -- new jobs delivered on your schedule</p>
        </div>
      </div>
    </div>

    <!-- Powered by Paystack badge -->
    <div class="text-center mt-8">
      <p class="text-xs text-gray-400">Secure payments powered by Paystack</p>
      <%= link_to billing_index_path, class: "text-sm text-gray-500 hover:text-gray-700 transition-colors" do %>
        &larr; Back to Billing
      <% end %>
    </div>
  </main>
</div>
