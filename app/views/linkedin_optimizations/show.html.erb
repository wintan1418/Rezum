<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6 flex items-center justify-between">
    <%= link_to linkedin_optimizations_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 transition-colors" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back
    <% end %>
    <%= link_to @linkedin_optimization, data: { turbo_method: :delete, turbo_confirm: 'Delete this optimization?' }, class: "text-sm text-red-500 hover:text-red-700" do %>
      Delete
    <% end %>
  </div>

  <!-- Header -->
  <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden mb-6">
    <div class="bg-gradient-to-r from-blue-600 to-cyan-600 px-6 py-5">
      <div class="flex items-center gap-3">
        <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
          <path d="M19 3a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h14m-.5 15.5v-5.3a3.26 3.26 0 00-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 011.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 001.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 00-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
        </svg>
        <div>
          <h1 class="text-xl font-bold text-white">LinkedIn Profile Optimization</h1>
          <p class="text-blue-100 mt-0.5"><%= @linkedin_optimization.target_role %></p>
        </div>
      </div>
    </div>

    <% if @linkedin_optimization.processing? %>
      <div class="p-8 text-center" data-controller="auto-refresh" data-auto-refresh-interval-value="5000">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto mb-4"></div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Optimizing your profile...</h3>
        <p class="text-sm text-gray-500">This usually takes 30-60 seconds. The page will auto-refresh.</p>
      </div>
    <% elsif @linkedin_optimization.failed? %>
      <div class="p-8 text-center">
        <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Optimization Failed</h3>
        <p class="text-sm text-gray-500 mb-4">Something went wrong. Please try again.</p>
        <%= link_to 'Try Again', new_linkedin_optimization_path, class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition-colors" %>
      </div>
    <% end %>
  </div>

  <% if @linkedin_optimization.optimized? %>
    <!-- Headline Section -->
    <% if @linkedin_optimization.optimized_headline.present? %>
      <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-900">Headline Options</h2>
          <div data-controller="clipboard">
            <button data-action="click->clipboard#copy" data-clipboard-target="source" data-clipboard-text="<%= @linkedin_optimization.optimized_headline %>" class="text-xs text-blue-600 hover:text-blue-800 font-medium">
              <span data-clipboard-target="label">Copy All</span>
            </button>
          </div>
        </div>
        <% if @linkedin_optimization.current_headline.present? %>
          <div class="mb-3 p-3 bg-gray-50 rounded-lg">
            <p class="text-xs font-medium text-gray-500 mb-1">Current:</p>
            <p class="text-sm text-gray-600"><%= @linkedin_optimization.current_headline %></p>
          </div>
        <% end %>
        <div class="space-y-2">
          <% @linkedin_optimization.optimized_headline.split("---").each_with_index do |headline, i| %>
            <div class="p-3 bg-blue-50 rounded-lg flex items-start justify-between group">
              <div class="flex items-start gap-2">
                <span class="flex-shrink-0 w-6 h-6 bg-blue-200 rounded-full flex items-center justify-center text-xs font-bold text-blue-700"><%= i + 1 %></span>
                <p class="text-sm font-medium text-blue-900"><%= headline.strip %></p>
              </div>
              <div data-controller="clipboard">
                <button data-action="click->clipboard#copy" data-clipboard-text="<%= headline.strip %>" class="opacity-0 group-hover:opacity-100 transition-opacity text-xs text-blue-600 hover:text-blue-800 whitespace-nowrap">
                  <span data-clipboard-target="label">Copy</span>
                </button>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- About Section -->
    <% if @linkedin_optimization.optimized_about.present? %>
      <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-900">About Section</h2>
          <div data-controller="clipboard">
            <button data-action="click->clipboard#copy" data-clipboard-text="<%= @linkedin_optimization.optimized_about %>" class="text-xs text-blue-600 hover:text-blue-800 font-medium">
              <span data-clipboard-target="label">Copy</span>
            </button>
          </div>
        </div>
        <% if @linkedin_optimization.current_about.present? %>
          <details class="mb-3">
            <summary class="text-xs font-medium text-gray-500 cursor-pointer hover:text-gray-700">Show original</summary>
            <div class="mt-2 p-3 bg-gray-50 rounded-lg">
              <p class="text-sm text-gray-600 whitespace-pre-line"><%= @linkedin_optimization.current_about %></p>
            </div>
          </details>
        <% end %>
        <div class="p-4 bg-green-50 rounded-lg border border-green-200">
          <p class="text-xs font-semibold text-green-700 mb-2">Optimized:</p>
          <div class="text-sm text-green-900 whitespace-pre-line"><%= @linkedin_optimization.optimized_about %></div>
        </div>
      </div>
    <% end %>

    <!-- Experience Section -->
    <% if @linkedin_optimization.optimized_experience.present? %>
      <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-900">Experience Bullets</h2>
          <div data-controller="clipboard">
            <button data-action="click->clipboard#copy" data-clipboard-text="<%= @linkedin_optimization.optimized_experience %>" class="text-xs text-blue-600 hover:text-blue-800 font-medium">
              <span data-clipboard-target="label">Copy</span>
            </button>
          </div>
        </div>
        <% if @linkedin_optimization.current_experience.present? %>
          <details class="mb-3">
            <summary class="text-xs font-medium text-gray-500 cursor-pointer hover:text-gray-700">Show original</summary>
            <div class="mt-2 p-3 bg-gray-50 rounded-lg">
              <p class="text-sm text-gray-600 whitespace-pre-line"><%= @linkedin_optimization.current_experience %></p>
            </div>
          </details>
        <% end %>
        <div class="p-4 bg-green-50 rounded-lg border border-green-200">
          <p class="text-xs font-semibold text-green-700 mb-2">Optimized:</p>
          <div class="text-sm text-green-900 whitespace-pre-line"><%= @linkedin_optimization.optimized_experience %></div>
        </div>
      </div>
    <% end %>

    <!-- Suggestions -->
    <% if @linkedin_optimization.suggestions_list.any? %>
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <h2 class="text-lg font-bold text-gray-900 mb-4">Additional Suggestions</h2>
        <div class="space-y-3">
          <% @linkedin_optimization.suggestions_list.each do |suggestion| %>
            <% priority_colors = { 'high' => 'red', 'medium' => 'yellow', 'low' => 'blue' } %>
            <% color = priority_colors[suggestion['priority']] || 'gray' %>
            <div class="flex items-start gap-3 p-3 rounded-lg bg-gray-50">
              <span class="flex-shrink-0 inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-<%= color %>-100 text-<%= color %>-700 mt-0.5">
                <%= (suggestion['priority'] || 'tip').capitalize %>
              </span>
              <div>
                <p class="text-sm text-gray-700"><%= suggestion['suggestion'] %></p>
                <% if suggestion['section'].present? %>
                  <span class="text-xs text-gray-400 mt-1 inline-block"><%= suggestion['section'].humanize %></span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
