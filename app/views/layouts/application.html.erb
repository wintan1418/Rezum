<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "RezumFit - AI Resume & Cover Letter Generator" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <% page_title = content_for(:title) || "RezumFit - AI Resume & Cover Letter Generator" %>
    <% page_description = content_for?(:meta_description) ? content_for(:meta_description) : "Optimize your resume for ATS systems and generate tailored cover letters in seconds. AI-powered tools trusted by thousands of job seekers." %>
    <% page_image = content_for?(:og_image) ? content_for(:og_image) : "#{request.base_url}/og-image.png" %>

    <meta name="description" content="<%= page_description %>">
    <link rel="canonical" href="<%= request.original_url.split('?').first %>">

    <!-- Open Graph -->
    <meta property="og:type" content="<%= content_for?(:og_type) ? content_for(:og_type) : 'website' %>">
    <meta property="og:site_name" content="RezumFit">
    <meta property="og:title" content="<%= page_title %>">
    <meta property="og:description" content="<%= page_description %>">
    <meta property="og:url" content="<%= request.original_url.split('?').first %>">
    <meta property="og:image" content="<%= page_image %>">
    <%= yield :og_extra %>

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= page_title %>">
    <meta name="twitter:description" content="<%= page_description %>">
    <meta name="twitter:image" content="<%= page_image %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT,WONK@9..144,300..900,0..100,0..1&family=Inter+Tight:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>

    <style>
      body { font-family: 'Inter Tight', 'Inter', system-ui, sans-serif; }
    </style>
  </head>

  <body class="h-full flex flex-col">
    <% public_pages = %w[articles ats_checker pages] %>
    <% if controller_name == 'home' %>
      <%# Home page has its own inline nav/footer %>
    <% elsif public_pages.include?(controller_name) %>
      <%= render 'shared/public_navigation' %>
    <% elsif user_signed_in? %>
      <%= render 'shared/navigation' %>
    <% end %>

    <%= render 'shared/flash_messages' %>

    <div class="flex-1">
      <%= yield %>
    </div>

    <% if controller_name == 'home' %>
      <%# Home page has its own inline footer %>
    <% elsif public_pages.include?(controller_name) %>
      <%= render 'shared/public_footer' %>
    <% elsif user_signed_in? %>
      <%= render 'shared/footer' %>
      <%= render 'shared/chat_widget' %>
    <% end %>
  </body>
</html>
