<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <title>Admin — RezumFit</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT,WONK@9..144,300..900,0..100,0..1&family=Inter+Tight:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <style>
      body{font-family:'Inter Tight',system-ui,sans-serif; background: var(--paper); color: var(--ink);}
      .admin-side a.active{ background: color-mix(in oklab, var(--paper) 6%, var(--ink)); color: var(--paper); }
      .admin-side a{ transition: background .15s, color .15s; }
      .admin-side a:hover{ background: color-mix(in oklab, var(--paper) 6%, var(--ink)); color: var(--paper); }
    </style>
  </head>
  <body class="h-full" style="background: var(--paper);">
    <div class="min-h-full flex">

      <!-- SIDEBAR -->
      <aside class="hidden md:flex md:w-64 md:flex-col admin-side" style="background: var(--ink); color: color-mix(in oklab, var(--paper) 80%, transparent);">
        <div class="flex flex-col flex-grow overflow-y-auto" style="padding: 0;">

          <!-- Logo -->
          <div style="display: flex; align-items: center; gap: 10px; height: 64px; flex-shrink: 0; padding: 0 20px; border-bottom: 1px solid color-mix(in oklab, var(--paper) 12%, transparent);">
            <span style="width:22px; height:22px; border:1.5px solid var(--paper); border-radius:50%; position:relative; display:inline-block;">
              <span style="position:absolute; inset:4px; background:var(--paper); border-radius:50%; clip-path: polygon(0 0,100% 0,100% 60%,40% 60%,40% 100%,0 100%); display:block;"></span>
            </span>
            <span style="font-family:'Fraunces',serif; font-weight:500; font-size:18px; letter-spacing:-0.02em; color: var(--paper); font-variation-settings:'opsz' 24;">RezumFit</span>
            <span class="font-mono-label" style="color: var(--accent); margin-left: 6px;">Admin</span>
          </div>

          <!-- Nav -->
          <nav style="flex: 1; padding: 20px 12px; display: flex; flex-direction: column; gap: 2px;">
            <% nav_items = [
              [admin_root_path, "Dashboard", "dashboard"],
              [admin_users_path, "Users", "users"],
              [admin_leads_path, "Leads CRM", "leads", (Lead.count rescue 0)],
              [admin_conversations_path, "Conversations", "conversations", (@unread_conversations || 0)],
              [admin_articles_path, "Blog Articles", "articles"],
              [admin_marketing_index_path, "Marketing", "marketing"],
              [admin_hire_messages_path, "Hire Messages", "hire_messages", (@unread_hire || 0)]
            ] %>
            <% nav_items.each do |path, label, ctrl, badge| %>
              <% active = controller_name == ctrl %>
              <%= link_to path, class: ("active" if active), style: "display: flex; align-items: center; justify-content: space-between; padding: 10px 14px; border-radius: 4px; font-size: 13.5px; font-weight: 400; text-decoration: none; color: #{active ? 'var(--paper)' : 'color-mix(in oklab, var(--paper) 70%, transparent)'};" do %>
                <span style="display: flex; align-items: center; gap: 10px;">
                  <% if active %><span style="width: 2px; height: 14px; background: var(--accent); display: inline-block;"></span><% else %><span style="width: 2px; height: 14px; display: inline-block;"></span><% end %>
                  <%= label %>
                </span>
                <% if badge && badge.to_i > 0 %>
                  <span class="font-mono-label" style="color: var(--accent); background: color-mix(in oklab, var(--accent) 14%, transparent); padding: 2px 8px; border-radius: 999px; font-size: 10px;"><%= badge %></span>
                <% end %>
              <% end %>
            <% end %>
          </nav>

          <!-- Quick links -->
          <div style="padding: 16px 12px; border-top: 1px solid color-mix(in oklab, var(--paper) 12%, transparent);">
            <%= link_to root_path(preview: 1), target: "_blank", data: { turbo: false }, style: "display: block; padding: 10px 14px; border-radius: 4px; font-size: 13px; color: color-mix(in oklab, var(--paper) 60%, transparent); text-decoration: none;" do %>
              View website ↗
            <% end %>
            <%= link_to dashboard_path, style: "display: block; padding: 10px 14px; border-radius: 4px; font-size: 13px; color: color-mix(in oklab, var(--paper) 60%, transparent); text-decoration: none;" do %>
              ← Back to app
            <% end %>

            <div style="display: flex; align-items: center; gap: 10px; padding: 14px; margin-top: 8px; border-top: 1px solid color-mix(in oklab, var(--paper) 8%, transparent);">
              <img src="<%= current_user.avatar_url(variant: :thumb) %>" alt="" style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover;">
              <div style="min-width: 0;">
                <p style="font-family:'Fraunces',serif; font-size: 14px; font-weight: 500; color: var(--paper); margin: 0; font-variation-settings:'opsz' 24;"><%= current_user.first_name %></p>
                <p class="font-mono-label" style="color: color-mix(in oklab, var(--paper) 50%, transparent); margin-top: 2px;">Admin</p>
              </div>
            </div>
          </div>
        </div>
      </aside>

      <!-- MAIN -->
      <div class="flex flex-col flex-1 min-w-0">

        <!-- Mobile header -->
        <div class="md:hidden" style="display: flex; align-items: center; justify-content: space-between; height: 56px; padding: 0 16px; background: var(--ink); color: var(--paper); border-bottom: 1px solid color-mix(in oklab, var(--paper) 10%, transparent);">
          <div style="display: flex; align-items: center; gap: 8px;">
            <span style="width:18px; height:18px; border:1.5px solid var(--paper); border-radius:50%; position:relative; display:inline-block;">
              <span style="position:absolute; inset:3px; background:var(--paper); border-radius:50%; clip-path: polygon(0 0,100% 0,100% 60%,40% 60%,40% 100%,0 100%); display:block;"></span>
            </span>
            <span style="font-family:'Fraunces',serif; font-weight:500; font-size:16px; letter-spacing:-0.02em;">Admin</span>
          </div>
          <div style="display: flex; align-items: center; gap: 4px; font-size: 12px;">
            <%= link_to "Users", admin_users_path, style: "color: color-mix(in oklab, var(--paper) 70%, transparent); padding: 4px 8px; text-decoration: none;" %>
            <%= link_to "Leads", admin_leads_path, style: "color: color-mix(in oklab, var(--paper) 70%, transparent); padding: 4px 8px; text-decoration: none;" %>
            <%= link_to "Blog", admin_articles_path, style: "color: color-mix(in oklab, var(--paper) 70%, transparent); padding: 4px 8px; text-decoration: none;" %>
            <%= link_to "Site", root_path(preview: 1), target: "_blank", data: { turbo: false }, style: "color: color-mix(in oklab, var(--paper) 50%, transparent); padding: 4px 8px; text-decoration: none;" %>
          </div>
        </div>

        <!-- Page content -->
        <main style="flex: 1; overflow-y: auto;">
          <% if flash[:notice] %>
            <div style="margin: 16px; padding: 12px 16px; background: var(--paper); border: 1px solid color-mix(in oklab, var(--accent) 30%, transparent); border-left: 3px solid var(--accent); border-radius: 4px; font-size: 14px; color: var(--ink);">
              <%= flash[:notice] %>
            </div>
          <% end %>
          <% if flash[:alert] %>
            <div style="margin: 16px; padding: 12px 16px; background: color-mix(in oklab, var(--ink) 5%, var(--paper)); border: 1px solid color-mix(in oklab, var(--ink) 25%, transparent); border-left: 3px solid var(--ink); border-radius: 4px; font-size: 14px; color: var(--ink);">
              <%= flash[:alert] %>
            </div>
          <% end %>

          <%= yield %>

          <!-- Admin slim footer -->
          <footer style="background: var(--paper); border-top: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); padding: 16px 24px; margin-top: auto; font-family: 'Inter Tight', system-ui, sans-serif;">
            <div style="display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 12px;">
              <div style="display: flex; align-items: center; gap: 10px;">
                <span style="width: 18px; height: 18px; border: 1.5px solid var(--ink); border-radius: 50%; position: relative; display: inline-block;">
                  <span style="position: absolute; inset: 3px; background: var(--ink); border-radius: 50%; clip-path: polygon(0 0,100% 0,100% 60%,40% 60%,40% 100%,0 100%); display: block;"></span>
                </span>
                <span style="font-family: 'Fraunces', serif; font-weight: 500; font-size: 14px; letter-spacing: -0.02em;">RezumFit</span>
                <span class="font-mono-label" style="color: var(--accent);">Admin</span>
                <span class="font-mono-label" style="color: var(--muted);">© <%= Date.current.year %></span>
              </div>
              <div style="display: flex; align-items: center; gap: 16px;">
                <%= link_to "View site", root_path(preview: 1), target: "_blank", data: { turbo: false }, style: "font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); text-decoration: none;" %>
                <%= link_to "Back to app", dashboard_path, style: "font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); text-decoration: none;" %>
              </div>
            </div>
          </footer>
        </main>
      </div>
    </div>
  </body>
</html>
