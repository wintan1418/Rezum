<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-100">
  <head>
    <title>Admin — ReZum</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>
  <body class="h-full">
    <div class="min-h-full flex">
      <!-- Sidebar -->
      <div class="hidden md:flex md:w-64 md:flex-col">
        <div class="flex flex-col flex-grow bg-gray-900 overflow-y-auto">
          <!-- Logo -->
          <div class="flex items-center h-16 flex-shrink-0 px-4 border-b border-gray-800">
            <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-purple-500 rounded-lg flex items-center justify-center">
              <span class="text-white font-bold text-lg">R</span>
            </div>
            <span class="ml-3 text-white font-bold text-lg">ReZum Admin</span>
          </div>

          <!-- Navigation -->
          <nav class="flex-1 px-3 py-4 space-y-1">
            <%= link_to admin_root_path, class: "flex items-center px-3 py-2.5 rounded-lg text-sm font-medium transition-colors #{controller_name == 'dashboard' ? 'bg-gray-800 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white'}" do %>
              <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
              Dashboard
            <% end %>

            <%= link_to admin_users_path, class: "flex items-center px-3 py-2.5 rounded-lg text-sm font-medium transition-colors #{controller_name == 'users' ? 'bg-gray-800 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white'}" do %>
              <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
              Users
            <% end %>

            <% unread_conversations = Conversation.open.joins(:messages).where(messages: { read: false }).where.not(messages: { user_id: current_user.id }).distinct.count %>
            <%= link_to admin_conversations_path, class: "flex items-center px-3 py-2.5 rounded-lg text-sm font-medium transition-colors #{controller_name == 'conversations' ? 'bg-gray-800 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white'}" do %>
              <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
              Conversations
              <% if unread_conversations > 0 %>
                <span class="ml-auto inline-flex items-center justify-center w-5 h-5 rounded-full bg-red-500 text-white text-xs font-bold"><%= unread_conversations %></span>
              <% end %>
            <% end %>
          </nav>

          <!-- Back to App -->
          <div class="px-3 py-4 border-t border-gray-800">
            <%= link_to dashboard_path, class: "flex items-center px-3 py-2.5 rounded-lg text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-white transition-colors" do %>
              <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12"/>
              </svg>
              Back to App
            <% end %>

            <div class="flex items-center px-3 py-2 mt-2">
              <img src="<%= current_user.avatar_url(variant: :thumb) %>" alt="" class="w-8 h-8 rounded-full object-cover">
              <div class="ml-3">
                <p class="text-sm font-medium text-white"><%= current_user.first_name %></p>
                <p class="text-xs text-gray-400">Admin</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Main Content -->
      <div class="flex flex-col flex-1 min-w-0">
        <!-- Mobile Header -->
        <div class="md:hidden flex items-center justify-between h-16 px-4 bg-gray-900 border-b border-gray-800">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-purple-500 rounded-lg flex items-center justify-center">
              <span class="text-white font-bold">R</span>
            </div>
            <span class="ml-2 text-white font-bold">Admin</span>
          </div>
          <div class="flex items-center space-x-2">
            <%= link_to admin_root_path, class: "text-gray-300 hover:text-white px-2 py-1 text-sm" do %>Dashboard<% end %>
            <%= link_to admin_users_path, class: "text-gray-300 hover:text-white px-2 py-1 text-sm" do %>Users<% end %>
            <%= link_to dashboard_path, class: "text-gray-400 hover:text-white px-2 py-1 text-sm" do %>App<% end %>
          </div>
        </div>

        <!-- Page Content -->
        <main class="flex-1 overflow-y-auto">
          <% if flash[:notice] %>
            <div class="mx-4 mt-4 px-4 py-3 rounded-xl bg-green-50 border border-green-200 text-green-800 text-sm">
              <%= flash[:notice] %>
            </div>
          <% end %>
          <% if flash[:alert] %>
            <div class="mx-4 mt-4 px-4 py-3 rounded-xl bg-red-50 border border-red-200 text-red-800 text-sm">
              <%= flash[:alert] %>
            </div>
          <% end %>

          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
