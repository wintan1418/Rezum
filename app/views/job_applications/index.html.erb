<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Job Applications</h1>
      <p class="mt-1 text-sm text-gray-500">Track and manage your job search pipeline</p>
    </div>
    <div class="mt-4 sm:mt-0 flex items-center gap-3">
      <!-- View Toggle -->
      <div class="inline-flex rounded-lg border border-gray-200 bg-white p-1">
        <%= link_to job_applications_path(view: 'kanban'), class: "px-3 py-1.5 text-sm font-medium rounded-md transition-colors #{@view == 'kanban' ? 'bg-blue-100 text-blue-700' : 'text-gray-500 hover:text-gray-700'}" do %>
          Board
        <% end %>
        <%= link_to job_applications_path(view: 'list'), class: "px-3 py-1.5 text-sm font-medium rounded-md transition-colors #{@view == 'list' ? 'bg-blue-100 text-blue-700' : 'text-gray-500 hover:text-gray-700'}" do %>
          List
        <% end %>
      </div>
      <%= link_to new_job_application_path, class: "inline-flex items-center px-4 py-2 bg-gradient-to-r from-blue-600 to-purple-600 text-white text-sm font-semibold rounded-xl shadow-sm hover:from-blue-700 hover:to-purple-700 transition-all" do %>
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Add Application
      <% end %>
    </div>
  </div>

  <!-- Stats Bar -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Total</p>
      <p class="mt-1 text-2xl font-bold text-gray-900"><%= @total %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Active</p>
      <p class="mt-1 text-2xl font-bold text-blue-600"><%= @active_count %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">This Week</p>
      <p class="mt-1 text-2xl font-bold text-purple-600"><%= @this_week %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Response Rate</p>
      <p class="mt-1 text-2xl font-bold text-green-600"><%= @response_rate %>%</p>
    </div>
  </div>

  <% if @job_applications.empty? %>
    <!-- Empty State -->
    <div class="bg-white rounded-2xl border border-gray-200 p-12 text-center">
      <div class="w-16 h-16 bg-gradient-to-br from-blue-100 to-purple-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 mb-2">No applications yet</h3>
      <p class="text-gray-500 mb-6 max-w-md mx-auto">Start tracking your job applications to stay organized and never miss a follow-up.</p>
      <%= link_to new_job_application_path, class: "inline-flex items-center px-6 py-3 bg-gradient-to-r from-blue-600 to-purple-600 text-white font-semibold rounded-xl shadow-sm hover:from-blue-700 hover:to-purple-700 transition-all" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Track Your First Application
      <% end %>
    </div>
  <% else %>
    <% if @view == 'kanban' %>
      <!-- Kanban Board -->
      <div class="overflow-x-auto pb-4" data-controller="kanban">
        <div class="flex gap-4 min-w-max">
          <% %w[wishlist applied phone_screen interview offer rejected withdrawn].each do |status| %>
            <% cards = @grouped[status] || [] %>
            <% color = { 'wishlist' => 'gray', 'applied' => 'blue', 'phone_screen' => 'yellow', 'interview' => 'purple', 'offer' => 'green', 'rejected' => 'red', 'withdrawn' => 'gray' }[status] %>
            <div class="w-72 flex-shrink-0 bg-gray-50 rounded-xl p-3 min-h-[400px] transition-colors"
                 data-kanban-target="column"
                 data-status="<%= status %>"
                 data-action="dragover->kanban#dragover dragleave->kanban#dragleave drop->kanban#drop">
              <!-- Column Header -->
              <div class="flex items-center justify-between mb-3 px-1">
                <div class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 rounded-full bg-<%= color %>-500"></span>
                  <h3 class="text-sm font-semibold text-gray-700"><%= status.humanize.titleize %></h3>
                </div>
                <span class="text-xs font-medium text-gray-400 bg-white rounded-full px-2 py-0.5" data-kanban-target="count"><%= cards.size %></span>
              </div>

              <!-- Cards -->
              <div class="space-y-2" data-kanban-target="cardList">
                <% cards.each do |app| %>
                  <div class="bg-white rounded-lg border border-gray-200 p-3 shadow-sm cursor-grab active:cursor-grabbing hover:shadow-md transition-shadow"
                       data-kanban-target="card"
                       data-job-id="<%= app.id %>"
                       data-action="dragstart->kanban#dragstart dragend->kanban#dragend">
                    <div class="flex items-start justify-between mb-2">
                      <h4 class="text-sm font-semibold text-gray-900 line-clamp-1"><%= app.company_name %></h4>
                      <% if app.needs_follow_up? %>
                        <span class="flex-shrink-0 w-2 h-2 rounded-full bg-orange-500 mt-1.5" title="Follow-up needed"></span>
                      <% end %>
                    </div>
                    <p class="text-xs text-gray-500 mb-2 line-clamp-1"><%= app.role %></p>
                    <div class="flex items-center justify-between">
                      <% if app.applied_at %>
                        <span class="text-xs text-gray-400"><%= app.applied_at.strftime('%b %d') %></span>
                      <% end %>
                      <% if app.remote? %>
                        <span class="text-xs bg-green-100 text-green-700 px-1.5 py-0.5 rounded">Remote</span>
                      <% elsif app.location.present? %>
                        <span class="text-xs text-gray-400 truncate max-w-[80px]"><%= app.location %></span>
                      <% end %>
                    </div>
                    <%= link_to job_application_path(app), class: "absolute inset-0", "aria-label": "View #{app.company_name}" do %><% end %>
                    <style>.bg-white { position: relative; }</style>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <!-- List View -->
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Company</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Role</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Applied</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Location</th>
                <th class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @job_applications.each do |app| %>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="flex items-center">
                      <div class="flex-shrink-0 w-8 h-8 bg-gradient-to-br from-<%= app.status_color %>-100 to-<%= app.status_color %>-200 rounded-lg flex items-center justify-center">
                        <span class="text-sm font-bold text-<%= app.status_color %>-600"><%= app.company_name[0].upcase %></span>
                      </div>
                      <div class="ml-3">
                        <p class="text-sm font-semibold text-gray-900"><%= app.company_name %></p>
                        <% if app.url.present? %>
                          <%= link_to 'View posting', app.url, target: '_blank', class: 'text-xs text-blue-600 hover:text-blue-800' %>
                        <% end %>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700"><%= app.role %></td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-<%= app.status_color %>-100 text-<%= app.status_color %>-700">
                      <%= app.status.humanize.titleize %>
                    </span>
                    <% if app.needs_follow_up? %>
                      <span class="ml-1 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-orange-100 text-orange-700">Follow up</span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    <%= app.applied_at&.strftime('%b %d, %Y') || '-' %>
                    <% if app.days_since_applied %>
                      <span class="text-xs text-gray-400 block"><%= app.days_since_applied %>d ago</span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    <% if app.remote? %>
                      <span class="text-green-600">Remote</span>
                    <% else %>
                      <%= app.location || '-' %>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                    <%= link_to 'View', job_application_path(app), class: 'text-blue-600 hover:text-blue-800 font-medium' %>
                    <%= link_to 'Edit', edit_job_application_path(app), class: 'ml-3 text-gray-500 hover:text-gray-700 font-medium' %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
