<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Back Link -->
  <div class="mb-6">
    <%= link_to job_applications_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 transition-colors" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Applications
    <% end %>
  </div>

  <!-- Header Card -->
  <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden mb-6">
    <div class="bg-gradient-to-r from-blue-600 to-purple-600 px-6 py-5">
      <div class="flex items-start justify-between">
        <div>
          <h1 class="text-xl font-bold text-white"><%= @job_application.company_name %></h1>
          <p class="text-blue-100 mt-1"><%= @job_application.role %></p>
        </div>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-white/20 text-white backdrop-blur-sm">
          <%= @job_application.status.humanize.titleize %>
        </span>
      </div>
    </div>

    <div class="px-6 py-5">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div>
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Applied</p>
          <p class="mt-1 text-sm font-semibold text-gray-900"><%= @job_application.applied_at&.strftime('%b %d, %Y') || 'Not set' %></p>
        </div>
        <div>
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Location</p>
          <p class="mt-1 text-sm font-semibold text-gray-900">
            <% if @job_application.remote? %>
              <span class="text-green-600">Remote</span>
            <% else %>
              <%= @job_application.location || 'Not set' %>
            <% end %>
          </p>
        </div>
        <div>
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Salary</p>
          <p class="mt-1 text-sm font-semibold text-gray-900"><%= @job_application.salary_offered.presence || 'Not specified' %></p>
        </div>
        <div>
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Follow Up</p>
          <p class="mt-1 text-sm font-semibold <%= @job_application.needs_follow_up? ? 'text-orange-600' : 'text-gray-900' %>">
            <%= @job_application.follow_up_at&.strftime('%b %d, %Y') || 'Not set' %>
            <% if @job_application.needs_follow_up? %>
              <span class="text-xs text-orange-500 block">Overdue!</span>
            <% end %>
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Contact Info -->
      <% if @job_application.contact_name.present? || @job_application.contact_email.present? %>
        <div class="bg-white rounded-xl border border-gray-200 p-5">
          <h3 class="text-sm font-semibold text-gray-900 mb-3">Contact</h3>
          <div class="space-y-2">
            <% if @job_application.contact_name.present? %>
              <p class="text-sm text-gray-700"><%= @job_application.contact_name %></p>
            <% end %>
            <% if @job_application.contact_email.present? %>
              <p class="text-sm text-gray-500"><%= @job_application.contact_email %></p>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Notes -->
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <h3 class="text-sm font-semibold text-gray-900 mb-3">Notes</h3>
        <% if @job_application.notes.present? %>
          <div class="prose prose-sm max-w-none text-gray-700">
            <%= simple_format(@job_application.notes) %>
          </div>
        <% else %>
          <p class="text-sm text-gray-400 italic">No notes yet. <%= link_to 'Add notes', edit_job_application_path(@job_application), class: 'text-blue-600 hover:text-blue-800' %></p>
        <% end %>
      </div>

      <!-- Job Posting Link -->
      <% if @job_application.url.present? %>
        <div class="bg-white rounded-xl border border-gray-200 p-5">
          <h3 class="text-sm font-semibold text-gray-900 mb-3">Job Posting</h3>
          <%= link_to @job_application.url, @job_application.url, target: '_blank', class: 'text-sm text-blue-600 hover:text-blue-800 break-all' %>
        </div>
      <% end %>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Actions -->
      <div class="bg-white rounded-xl border border-gray-200 p-5 space-y-3">
        <h3 class="text-sm font-semibold text-gray-900 mb-3">Actions</h3>
        <%= link_to edit_job_application_path(@job_application), class: "w-full inline-flex items-center justify-center px-4 py-2.5 bg-white border border-gray-200 text-sm font-medium text-gray-700 rounded-xl hover:bg-gray-50 transition-all" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
          Edit Application
        <% end %>
        <%= link_to @job_application, data: { turbo_method: :delete, turbo_confirm: 'Remove this application?' }, class: "w-full inline-flex items-center justify-center px-4 py-2.5 bg-white border border-red-200 text-sm font-medium text-red-600 rounded-xl hover:bg-red-50 transition-all" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          Delete
        <% end %>
      </div>

      <!-- Linked Documents -->
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <h3 class="text-sm font-semibold text-gray-900 mb-3">Linked Documents</h3>
        <div class="space-y-3">
          <% if @job_application.resume %>
            <%= link_to resume_path(@job_application.resume), class: "flex items-center p-3 rounded-lg border border-gray-100 hover:bg-gray-50 transition-colors" do %>
              <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center mr-3">
                <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-900">Resume</p>
                <p class="text-xs text-gray-500"><%= @job_application.resume.target_role %></p>
              </div>
            <% end %>
          <% else %>
            <p class="text-xs text-gray-400 italic">No resume linked</p>
          <% end %>

          <% if @job_application.cover_letter %>
            <%= link_to resume_cover_letter_path(@job_application.cover_letter.resume, @job_application.cover_letter), class: "flex items-center p-3 rounded-lg border border-gray-100 hover:bg-gray-50 transition-colors" do %>
              <div class="w-8 h-8 bg-purple-100 rounded-lg flex items-center justify-center mr-3">
                <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-900">Cover Letter</p>
                <p class="text-xs text-gray-500"><%= @job_application.cover_letter.company_name %></p>
              </div>
            <% end %>
          <% else %>
            <p class="text-xs text-gray-400 italic">No cover letter linked</p>
          <% end %>
        </div>
      </div>

      <!-- Timeline -->
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <h3 class="text-sm font-semibold text-gray-900 mb-3">Timeline</h3>
        <div class="space-y-3">
          <div class="flex items-start gap-3">
            <div class="w-2 h-2 rounded-full bg-blue-500 mt-1.5 flex-shrink-0"></div>
            <div>
              <p class="text-sm text-gray-700">Created</p>
              <p class="text-xs text-gray-400"><%= @job_application.created_at.strftime('%b %d, %Y at %I:%M %p') %></p>
            </div>
          </div>
          <% if @job_application.applied_at %>
            <div class="flex items-start gap-3">
              <div class="w-2 h-2 rounded-full bg-green-500 mt-1.5 flex-shrink-0"></div>
              <div>
                <p class="text-sm text-gray-700">Applied</p>
                <p class="text-xs text-gray-400"><%= @job_application.applied_at.strftime('%b %d, %Y') %></p>
              </div>
            </div>
          <% end %>
          <% if @job_application.updated_at != @job_application.created_at %>
            <div class="flex items-start gap-3">
              <div class="w-2 h-2 rounded-full bg-gray-400 mt-1.5 flex-shrink-0"></div>
              <div>
                <p class="text-sm text-gray-700">Last updated</p>
                <p class="text-xs text-gray-400"><%= @job_application.updated_at.strftime('%b %d, %Y at %I:%M %p') %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
