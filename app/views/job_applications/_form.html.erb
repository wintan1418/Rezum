<%= form_with(model: job_application, class: "space-y-8") do |form| %>
  <% if job_application.errors.any? %>
    <div class="rounded-xl bg-red-50 border border-red-200 p-4">
      <div class="flex items-start gap-3">
        <svg class="h-5 w-5 text-red-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
        </svg>
        <div>
          <h3 class="text-sm font-medium text-red-800"><%= pluralize(job_application.errors.count, "error") %> prevented saving:</h3>
          <ul class="mt-1 text-sm text-red-700 list-disc pl-5 space-y-0.5">
            <% job_application.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Job Details Section -->
  <div class="space-y-5">
    <div class="flex items-center gap-2 pb-2 border-b border-gray-100">
      <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      <h3 class="text-sm font-semibold text-gray-800">Job Details</h3>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= form.label :company_name, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.text_field :company_name, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300", placeholder: "e.g., Google" %>
      </div>
      <div>
        <%= form.label :role, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.text_field :role, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300", placeholder: "e.g., Software Engineer" %>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= form.label :status, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.select :status, JobApplication.statuses.keys.map { |s| [s.humanize.titleize, s] }, {}, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300" %>
      </div>
      <div>
        <%= form.label :applied_at, "Date Applied", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.date_field :applied_at, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300" %>
      </div>
    </div>

    <div>
      <%= form.label :url, "Job Posting URL", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
      <%= form.url_field :url, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300", placeholder: "https://..." %>
    </div>
  </div>

  <!-- Location & Compensation Section -->
  <div class="space-y-5">
    <div class="flex items-center gap-2 pb-2 border-b border-gray-100">
      <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      <h3 class="text-sm font-semibold text-gray-800">Location & Compensation</h3>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= form.label :location, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.text_field :location, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300", placeholder: "e.g., San Francisco, CA" %>
      </div>
      <div class="flex items-end pb-1.5">
        <label class="flex items-center gap-2.5 cursor-pointer group">
          <%= form.check_box :remote, class: "rounded border-gray-300 text-blue-600 shadow-sm focus:ring-blue-500 h-4.5 w-4.5" %>
          <span class="text-sm font-medium text-gray-700 group-hover:text-gray-900">Remote position</span>
        </label>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= form.label :salary_offered, "Salary / Compensation", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.text_field :salary_offered, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300", placeholder: "e.g., $120k-$150k" %>
      </div>
      <div>
        <%= form.label :follow_up_at, "Follow Up Date", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.date_field :follow_up_at, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300" %>
      </div>
    </div>
  </div>

  <!-- Contact & Documents Section -->
  <div class="space-y-5">
    <div class="flex items-center gap-2 pb-2 border-b border-gray-100">
      <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      <h3 class="text-sm font-semibold text-gray-800">Contact & Documents</h3>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= form.label :contact_name, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.text_field :contact_name, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300", placeholder: "Recruiter / Hiring Manager" %>
      </div>
      <div>
        <%= form.label :contact_email, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.email_field :contact_email, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300", placeholder: "recruiter@company.com" %>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= form.label :resume_id, "Linked Resume", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.select :resume_id, @resumes.map { |r| ["#{r.target_role} (#{r.created_at.strftime('%b %d')})", r.id] }, { include_blank: "None" }, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300" %>
      </div>
      <div>
        <%= form.label :cover_letter_id, "Linked Cover Letter", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= form.select :cover_letter_id, @cover_letters.map { |cl| ["#{cl.company_name} (#{cl.created_at.strftime('%b %d')})", cl.id] }, { include_blank: "None" }, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300" %>
      </div>
    </div>
  </div>

  <!-- Notes Section -->
  <div class="space-y-5">
    <div class="flex items-center gap-2 pb-2 border-b border-gray-100">
      <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
      <h3 class="text-sm font-semibold text-gray-800">Notes</h3>
    </div>

    <div>
      <%= form.text_area :notes, rows: 4, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300 resize-y", placeholder: "Interview notes, key requirements, things to prepare..." %>
    </div>
  </div>

  <!-- Submit -->
  <div class="flex items-center justify-end gap-3 pt-6 border-t border-gray-200">
    <%= link_to 'Cancel', job_applications_path, class: "px-5 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 hover:border-gray-300 transition-all" %>
    <%= form.submit job_application.persisted? ? 'Update Application' : 'Track Application', class: "px-6 py-2.5 bg-gradient-to-r from-blue-600 to-blue-700 text-white text-sm font-semibold rounded-xl shadow-sm hover:from-blue-700 hover:to-blue-800 hover:shadow transition-all cursor-pointer" %>
  </div>
<% end %>
