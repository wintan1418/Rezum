<div class="min-h-full">
  <main class="max-w-3xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
    <!-- Breadcrumb -->
    <div class="flex items-center space-x-2 text-sm text-gray-500 mb-6">
      <%= link_to "Job Scraper", scraped_jobs_path, class: "hover:text-gray-700" %>
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
      </svg>
      <span><%= @scraped_job.role %></span>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
      <div class="p-6 border-b border-gray-200">
        <div class="flex items-start justify-between">
          <div>
            <h1 class="text-2xl font-bold text-gray-900"><%= @scraped_job.role %></h1>
            <p class="text-lg text-gray-700 mt-1"><%= @scraped_job.company_name %></p>

            <div class="flex flex-wrap items-center gap-3 mt-3">
              <!-- Match Score -->
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-bold
                <%= case @scraped_job.match_color
                    when 'green' then 'bg-green-100 text-green-800'
                    when 'yellow' then 'bg-yellow-100 text-yellow-800'
                    when 'red' then 'bg-red-100 text-red-800'
                    else 'bg-gray-100 text-gray-800'
                    end %>">
                <%= @scraped_job.match_score %>% match
              </span>

              <!-- Status -->
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
                <%= case @scraped_job.status_color
                    when 'blue' then 'bg-blue-100 text-blue-800'
                    when 'yellow' then 'bg-yellow-100 text-yellow-800'
                    when 'green' then 'bg-green-100 text-green-800'
                    else 'bg-gray-100 text-gray-800'
                    end %>">
                <%= @scraped_job.status.humanize %>
              </span>

              <% if @scraped_job.remote? %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-50 text-green-700">Remote</span>
              <% end %>
            </div>
          </div>

          <% if @scraped_job.url.present? %>
            <a href="<%= @scraped_job.url %>" target="_blank" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
              Apply Now
            </a>
          <% end %>
        </div>
      </div>

      <!-- Details -->
      <div class="p-6 border-b border-gray-200 grid grid-cols-2 md:grid-cols-4 gap-4">
        <% if @scraped_job.location.present? %>
          <div>
            <dt class="text-xs font-medium text-gray-500 uppercase">Location</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @scraped_job.location %></dd>
          </div>
        <% end %>
        <% if @scraped_job.salary_range.present? %>
          <div>
            <dt class="text-xs font-medium text-gray-500 uppercase">Salary</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @scraped_job.salary_range %></dd>
          </div>
        <% end %>
        <% if @scraped_job.job_type.present? %>
          <div>
            <dt class="text-xs font-medium text-gray-500 uppercase">Type</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @scraped_job.job_type.humanize %></dd>
          </div>
        <% end %>
        <div>
          <dt class="text-xs font-medium text-gray-500 uppercase">Source</dt>
          <dd class="mt-1 text-sm text-gray-900"><%= @scraped_job.source.humanize %></dd>
        </div>
      </div>

      <!-- Description -->
      <% if @scraped_job.description.present? %>
        <div class="p-6 border-b border-gray-200">
          <h3 class="text-sm font-semibold text-gray-900 mb-3">Job Description</h3>
          <div class="prose prose-sm max-w-none text-gray-700">
            <%= simple_format(@scraped_job.description) %>
          </div>
        </div>
      <% end %>

      <!-- Tags -->
      <% if @scraped_job.tags_list.any? %>
        <div class="p-6 border-b border-gray-200">
          <h3 class="text-sm font-semibold text-gray-900 mb-3">Tags</h3>
          <div class="flex flex-wrap gap-2">
            <% @scraped_job.tags_list.each do |tag| %>
              <span class="px-2.5 py-1 bg-gray-100 text-gray-700 rounded-full text-sm"><%= tag %></span>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Notes -->
      <div class="p-6 border-b border-gray-200">
        <h3 class="text-sm font-semibold text-gray-900 mb-3">Notes</h3>
        <%= form_with model: @scraped_job, local: true, class: "space-y-3" do |f| %>
          <%= f.text_area :notes, rows: 3, class: "w-full px-3 py-2.5 border border-gray-200 rounded-xl text-sm shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none transition-all hover:border-gray-300", placeholder: "Add your notes about this job..." %>
          <%= f.submit "Save Notes", class: "px-4 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-200 cursor-pointer" %>
        <% end %>
      </div>

      <!-- Actions -->
      <div class="p-6 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <% case @scraped_job.status %>
          <% when 'new' %>
            <%= button_to scraped_job_path(@scraped_job), method: :patch, params: { scraped_job: { status: 'saved' } }, class: "inline-flex items-center px-4 py-2 bg-yellow-50 text-yellow-700 border border-yellow-200 rounded-lg text-sm font-medium hover:bg-yellow-100" do %>
              Save Job
            <% end %>
          <% when 'saved' %>
            <%= button_to scraped_job_path(@scraped_job), method: :patch, params: { scraped_job: { status: 'applied' } }, class: "inline-flex items-center px-4 py-2 bg-green-50 text-green-700 border border-green-200 rounded-lg text-sm font-medium hover:bg-green-100" do %>
              Mark as Applied
            <% end %>
          <% end %>
        </div>

        <%= button_to scraped_job_path(@scraped_job), method: :delete, class: "text-sm text-red-600 hover:text-red-800" do %>
          Hide this job
        <% end %>
      </div>
    </div>
  </main>
</div>
