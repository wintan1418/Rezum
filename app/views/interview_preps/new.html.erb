<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <%= link_to interview_preps_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 transition-colors group" do %>
      <svg class="w-4 h-4 mr-1.5 transition-transform group-hover:-translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Interview Preps
    <% end %>
  </div>

  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="px-6 py-5 bg-gradient-to-r from-blue-600 to-purple-600">
      <h1 class="text-lg font-bold text-white">New Interview Prep</h1>
      <p class="mt-1 text-sm text-blue-100">Get AI-generated questions and answer frameworks tailored to your interview</p>
    </div>

    <div class="p-6">
      <%= form_with(model: @interview_prep, class: "space-y-6") do |form| %>
        <% if @interview_prep.errors.any? %>
          <div class="rounded-xl bg-red-50 border border-red-200 p-4">
            <div class="flex items-start gap-3">
              <svg class="h-5 w-5 text-red-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
              </svg>
              <ul class="text-sm text-red-700 list-disc pl-5 space-y-0.5">
                <% @interview_prep.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        <% end %>

        <!-- Target Role & Company -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <%= form.label :target_role, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= form.text_field :target_role, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300", placeholder: "e.g., Software Engineer", required: true %>
          </div>
          <div>
            <%= form.label :company_name, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= form.text_field :company_name, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300", placeholder: "e.g., Google" %>
          </div>
        </div>

        <!-- Job Description -->
        <div>
          <%= form.label :job_description, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= form.text_area :job_description, rows: 6, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300 resize-y", placeholder: "Paste the job description here for more targeted questions..." %>
          <p class="mt-1.5 text-xs text-gray-400">Optional but recommended for better results</p>
        </div>

        <!-- Linked Resume -->
        <div>
          <%= form.label :resume_id, "Use Resume", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= form.select :resume_id, @resumes.map { |r| ["#{r.target_role} (#{r.created_at.strftime('%b %d')})", r.id] }, { include_blank: "No resume" }, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300" %>
          <p class="mt-1.5 text-xs text-gray-400">Linking a resume helps generate more personalized questions</p>
        </div>

        <!-- Linked Job Application -->
        <% if @job_applications.any? %>
          <div>
            <%= form.label :job_application_id, "Linked Application", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= form.select :job_application_id, @job_applications.map { |ja| ["#{ja.company_name} - #{ja.role}", ja.id] }, { include_blank: "None" }, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300" %>
          </div>
        <% end %>

        <!-- AI Provider -->
        <div>
          <%= form.label :provider, "AI Provider", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= form.select :provider, [['OpenAI GPT-4', 'openai'], ['Anthropic Claude', 'anthropic'], ['Google Gemini', 'google']], {}, class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300" %>
        </div>

        <!-- Cost Notice -->
        <div class="bg-gradient-to-r from-blue-50 to-purple-50 rounded-xl p-4 border border-blue-100">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-blue-100 flex items-center justify-center flex-shrink-0">
              <svg class="h-4 w-4 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
              </svg>
            </div>
            <p class="text-sm text-blue-700">This will use <strong>3 credits</strong>. You have <strong><%= current_user.credits_remaining %> credits</strong> remaining.</p>
          </div>
        </div>

        <!-- Submit -->
        <div class="flex items-center justify-end gap-3 pt-5 border-t border-gray-200">
          <%= link_to 'Cancel', interview_preps_path, class: "px-5 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 hover:border-gray-300 transition-all" %>
          <%= form.submit 'Generate Interview Prep', class: "px-6 py-2.5 bg-gradient-to-r from-blue-600 to-blue-700 text-white text-sm font-semibold rounded-xl shadow-sm hover:from-blue-700 hover:to-blue-800 hover:shadow transition-all cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
