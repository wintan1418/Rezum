<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <!-- Header -->
  <div class="text-center mb-12">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900">Career Blog</h1>
    <p class="mt-3 text-lg text-gray-500 max-w-2xl mx-auto">Expert tips and guides to help you land your dream job</p>
  </div>

  <!-- Category Filters -->
  <div class="flex flex-wrap justify-center gap-2 mb-10">
    <%= link_to 'All', articles_path, class: "px-4 py-2 rounded-full text-sm font-medium transition-colors #{params[:category].blank? ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
    <% @categories.each do |cat| %>
      <%= link_to cat.humanize.titleize, articles_path(category: cat), class: "px-4 py-2 rounded-full text-sm font-medium transition-colors #{params[:category] == cat ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
    <% end %>
  </div>

  <% if @articles.empty? %>
    <div class="text-center py-12">
      <p class="text-gray-500">No articles yet. Check back soon!</p>
    </div>
  <% else %>
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      <% @articles.each do |article| %>
        <%= link_to article_path(article), class: "group block bg-white rounded-2xl border border-gray-200 overflow-hidden hover:shadow-lg transition-all" do %>
          <% if article.featured_image_url.present? %>
            <div class="aspect-video bg-gray-100 overflow-hidden">
              <img src="<%= article.featured_image_url %>" alt="<%= article.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
            </div>
          <% else %>
            <div class="aspect-video bg-gradient-to-br from-<%= article.category_color %>-100 to-<%= article.category_color %>-200 flex items-center justify-center">
              <svg class="w-12 h-12 text-<%= article.category_color %>-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
            </div>
          <% end %>

          <div class="p-5">
            <div class="flex items-center gap-2 mb-3">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-<%= article.category_color %>-100 text-<%= article.category_color %>-700">
                <%= article.category_label %>
              </span>
              <span class="text-xs text-gray-400"><%= article.reading_time %> min read</span>
            </div>
            <h2 class="text-lg font-bold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-2"><%= article.title %></h2>
            <% if article.excerpt.present? %>
              <p class="mt-2 text-sm text-gray-500 line-clamp-3"><%= article.excerpt %></p>
            <% end %>
            <div class="mt-4 flex items-center justify-between text-xs text-gray-400">
              <span><%= article.published_at&.strftime('%b %d, %Y') %></span>
              <% if article.author.present? %>
                <span>By <%= article.author %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <!-- CTA for non-logged-in users -->
  <% unless user_signed_in? %>
    <div class="mt-16 bg-gradient-to-r from-blue-600 to-purple-600 rounded-2xl p-8 sm:p-12 text-center">
      <h2 class="text-2xl font-bold text-white mb-3">Ready to optimize your resume?</h2>
      <p class="text-blue-100 mb-6 max-w-lg mx-auto">Join thousands of professionals using AI to craft perfect resumes and cover letters.</p>
      <%= link_to 'Get Started Free', new_user_registration_path, class: "inline-flex items-center px-8 py-3 bg-white text-blue-600 font-bold rounded-xl shadow-lg hover:shadow-xl transition-all" %>
    </div>
  <% end %>
</div>
