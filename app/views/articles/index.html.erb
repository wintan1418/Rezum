<% content_for :title, "Career Blog — Resume tips, ATS guides & interview advice | RezumFit" %>
<% content_for :meta_description, "Expert career advice, resume writing tips, ATS optimization guides, and interview preparation strategies to help you land your dream job." %>

<div style="background: var(--paper); min-height: 100vh; color: var(--ink); font-family: 'Inter Tight', system-ui, sans-serif;">
  <div class="max-w-6xl mx-auto" style="padding: 64px 24px 80px;">

    <!-- Header -->
    <div style="text-align: center; margin-bottom: 56px;">
      <span class="font-mono-label" style="display: inline-block; color: var(--accent); margin-bottom: 18px;">RezumFit · Blog</span>
      <h1 class="font-display" style="font-size: clamp(56px, 8vw, 120px); line-height: 0.95; letter-spacing: -0.045em;">
        Career <em>blog</em>.
      </h1>
      <p style="font-family: 'Fraunces', serif; font-style: italic; font-weight: 300; font-size: 21px; color: var(--muted); max-width: 50ch; margin: 22px auto 0; line-height: 1.4;">
        Expert tips, guides, and strategies to help you land your dream job faster.
      </p>
    </div>

    <!-- Category filters -->
    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; margin-bottom: 48px; padding-bottom: 32px; border-bottom: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);">
      <% all_active = params[:category].blank? %>
      <%= link_to "All", articles_path,
          style: "padding: 8px 18px; border-radius: 999px; font-size: 13px; text-decoration: none; #{all_active ? 'background: var(--ink); color: var(--paper); border: 1px solid var(--ink);' : 'background: var(--paper); color: var(--ink); border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent);'}" %>
      <% @categories.each do |cat| %>
        <% active = params[:category] == cat %>
        <% label = cat.humanize.titleize %>
        <%= link_to label, articles_path(category: cat),
            style: "padding: 8px 18px; border-radius: 999px; font-size: 13px; text-decoration: none; #{active ? 'background: var(--ink); color: var(--paper); border: 1px solid var(--ink);' : 'background: var(--paper); color: var(--ink); border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent);'}" %>
      <% end %>
    </div>

    <% if @articles.empty? %>
      <div style="text-align: center; padding: 80px 24px; background: var(--paper); border: 1px dashed color-mix(in oklab, var(--ink) 18%, transparent); border-radius: 8px;">
        <span class="font-mono-label" style="color: var(--muted);">Empty</span>
        <h3 class="font-display" style="font-size: 32px; margin-top: 8px;">No articles <em>yet</em>.</h3>
        <p style="font-family: 'Fraunces', serif; font-style: italic; color: var(--muted); margin-top: 8px;">Check back soon for career tips and resume advice.</p>
      </div>
    <% else %>

      <!-- Featured -->
      <% featured = @articles.first %>
      <% if params[:category].blank? %>
        <%= link_to article_path(featured), style: "display: block; margin-bottom: 56px; background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent); border-radius: 8px; overflow: hidden; text-decoration: none; color: var(--ink); transition: border-color .15s, transform .15s;", onmouseover: "this.style.borderColor='var(--ink)'", onmouseout: "this.style.borderColor='color-mix(in oklab, var(--ink) 14%, transparent)'" do %>
          <div style="display: grid; grid-template-columns: 1fr 1fr;" class="featured-grid">
            <% if featured.featured_image_url.present? %>
              <div style="aspect-ratio: 4/3; background: var(--paper-2); overflow: hidden;">
                <img src="<%= featured.featured_image_url %>" alt="<%= featured.title %>" style="width: 100%; height: 100%; object-fit: cover;">
              </div>
            <% else %>
              <div style="aspect-ratio: 4/3; background: var(--ink); display: flex; align-items: center; justify-content: center;">
                <span class="font-display" style="font-size: 80px; color: var(--accent); font-style: italic;"><%= featured.category_label.first.upcase %></span>
              </div>
            <% end %>
            <div style="padding: 40px 36px; display: flex; flex-direction: column; justify-content: center;">
              <div style="display: flex; align-items: center; gap: 14px; margin-bottom: 14px;">
                <span class="font-mono-label" style="color: var(--accent);"><%= featured.category_label %></span>
                <span class="font-mono-label" style="color: var(--muted);"><%= featured.reading_time %> min read</span>
              </div>
              <h2 class="font-display" style="font-size: clamp(28px, 3vw, 40px); line-height: 1.05;"><%= featured.title %></h2>
              <% if featured.excerpt.present? %>
                <p style="font-family: 'Fraunces', serif; font-style: italic; font-weight: 300; font-size: 17px; color: var(--muted); margin-top: 14px; line-height: 1.5;"><%= featured.excerpt.truncate(180) %></p>
              <% end %>
              <div style="display: flex; align-items: center; gap: 16px; margin-top: 20px; font-size: 12px; color: var(--muted);">
                <span><%= featured.published_at&.strftime("%b %d, %Y") %></span>
                <% if featured.author.present? %><span>By <%= featured.author %></span><% end %>
              </div>
              <div style="margin-top: 24px;">
                <span style="display: inline-flex; align-items: center; gap: 8px; font-size: 14px; color: var(--ink); border-bottom: 1px solid var(--ink); padding-bottom: 1px;">
                  Read article →
                </span>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>

      <!-- Article grid -->
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;" class="article-grid">
        <% articles_to_show = params[:category].blank? ? @articles.offset(1) : @articles %>
        <% articles_to_show.each do |article| %>
          <%= link_to article_path(article), style: "display: block; background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 8px; overflow: hidden; text-decoration: none; color: var(--ink); transition: all .15s;", onmouseover: "this.style.borderColor='var(--ink)'; this.style.transform='translateY(-2px)'", onmouseout: "this.style.borderColor='color-mix(in oklab, var(--ink) 12%, transparent)'; this.style.transform='translateY(0)'" do %>
            <% if article.featured_image_url.present? %>
              <div style="aspect-ratio: 16/9; background: var(--paper-2); overflow: hidden;">
                <img src="<%= article.featured_image_url %>" alt="<%= article.title %>" style="width: 100%; height: 100%; object-fit: cover;">
              </div>
            <% else %>
              <div style="aspect-ratio: 16/9; background: var(--ink); display: flex; align-items: center; justify-content: center;">
                <span class="font-display" style="font-size: 56px; color: var(--accent); font-style: italic;"><%= article.category_label.first.upcase %></span>
              </div>
            <% end %>

            <div style="padding: 22px 22px 24px;">
              <div style="display: flex; align-items: center; gap: 14px; margin-bottom: 12px;">
                <span class="font-mono-label" style="color: var(--accent);"><%= article.category_label %></span>
                <span class="font-mono-label" style="color: var(--muted);"><%= article.reading_time %> min</span>
              </div>
              <h2 class="font-display" style="font-size: 21px; line-height: 1.15; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= article.title %></h2>
              <% if article.excerpt.present? %>
                <p style="font-family: 'Fraunces', serif; font-style: italic; font-weight: 300; font-size: 14px; color: var(--muted); margin-top: 10px; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;"><%= article.excerpt %></p>
              <% end %>
              <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 18px; font-size: 11px; color: var(--muted); font-family: 'JetBrains Mono', monospace; letter-spacing: 0.04em;">
                <span><%= article.published_at&.strftime("%b %d, %Y") %></span>
                <% if article.author.present? %><span>By <%= article.author %></span><% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <!-- CTA -->
    <% unless user_signed_in? %>
      <div style="margin-top: 80px; background: var(--ink); color: var(--paper); border-radius: 8px; padding: 64px 48px; text-align: center;">
        <span class="font-mono-label" style="color: var(--accent);">Apply the tips</span>
        <h2 class="font-display" style="font-size: clamp(36px, 5vw, 64px); line-height: 1; color: var(--paper); margin-top: 14px;">
          Ready to <em>optimize</em> your resume?
        </h2>
        <p style="font-family: 'Fraunces', serif; font-style: italic; font-weight: 300; font-size: 19px; color: color-mix(in oklab, var(--paper) 70%, transparent); max-width: 48ch; margin: 18px auto 32px; line-height: 1.4;">
          Put these tips into action. Use AI to craft the perfect resume and land more interviews.
        </p>
        <div style="display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;">
          <%= link_to "Get started — free", new_user_registration_path, class: "btn-accent" %>
          <%= link_to "Check ATS score", ats_checker_path, class: "btn-outline", style: "color: var(--paper); border-color: color-mix(in oklab, var(--paper) 35%, transparent);" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
  @media (max-width: 960px){
    .article-grid{grid-template-columns: repeat(2, 1fr) !important;}
    .featured-grid{grid-template-columns: 1fr !important;}
  }
  @media (max-width: 600px){
    .article-grid{grid-template-columns: 1fr !important;}
  }
</style>
