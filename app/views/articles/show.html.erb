<% content_for :title, @article.meta_title.presence || "#{@article.title} | RezumFit Blog" %>
<% content_for :meta_description, @article.meta_description.presence || @article.excerpt.presence || truncate(strip_tags(@article.content), length: 160) %>
<% content_for :og_type, "article" %>
<% content_for :og_image, @article.featured_image_url if @article.featured_image_url.present? %>
<% content_for :og_extra do %>
  <meta property="article:published_time" content="<%= @article.published_at&.iso8601 %>">
  <meta property="article:author" content="<%= @article.author %>">
  <meta property="article:section" content="<%= @article.category_label %>">
<% end %>
<% content_for :head do %>
  <script type="application/ld+json">
  <%= raw({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": @article.title,
    "description": @article.meta_description.presence || @article.excerpt.presence || truncate(strip_tags(@article.content), length: 160),
    "image": @article.featured_image_url.presence || "#{request.base_url}/icon.png",
    "datePublished": @article.published_at&.iso8601,
    "dateModified": @article.updated_at&.iso8601,
    "author": { "@type": "Person", "name": @article.author.presence || "RezumFit Team" },
    "publisher": { "@type": "Organization", "name": "RezumFit", "logo": { "@type": "ImageObject", "url": "#{request.base_url}/icon.png" } },
    "mainEntityOfPage": { "@type": "WebPage", "@id": request.original_url }
  }.to_json) %>
  </script>
  <script type="application/ld+json">
  <%= raw({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": root_url },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": articles_url },
      { "@type": "ListItem", "position": 3, "name": @article.title }
    ]
  }.to_json) %>
  </script>
  <style>
    .article-prose{ font-family: 'Fraunces', Georgia, serif; font-size: 19px; line-height: 1.7; color: var(--ink); font-weight: 400; }
    .article-prose h2{ font-family: 'Fraunces', serif; font-size: 32px; font-weight: 500; letter-spacing: -0.02em; line-height: 1.15; margin: 48px 0 16px; font-variation-settings: 'opsz' 60; }
    .article-prose h3{ font-family: 'Fraunces', serif; font-size: 24px; font-weight: 500; letter-spacing: -0.015em; line-height: 1.2; margin: 36px 0 12px; font-variation-settings: 'opsz' 36; }
    .article-prose h4{ font-family: 'Fraunces', serif; font-size: 19px; font-weight: 500; margin: 28px 0 10px; }
    .article-prose p{ margin: 0 0 22px; }
    .article-prose a{ color: var(--ink); text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 3px; text-decoration-thickness: 1.5px; }
    .article-prose a:hover{ color: var(--accent); }
    .article-prose strong{ font-weight: 500; color: var(--ink); }
    .article-prose em{ font-style: italic; }
    .article-prose ul, .article-prose ol{ margin: 0 0 22px; padding-left: 24px; }
    .article-prose li{ margin-bottom: 8px; }
    .article-prose blockquote{ border-left: 2px solid var(--accent); padding: 4px 0 4px 24px; margin: 28px 0; font-style: italic; color: var(--graphite); font-size: 22px; line-height: 1.5; }
    .article-prose code{ font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 0.9em; padding: 2px 6px; background: var(--paper-2); border-radius: 4px; }
    .article-prose pre{ background: var(--ink); color: var(--paper); padding: 18px 22px; border-radius: 6px; overflow-x: auto; font-size: 14px; margin: 22px 0; }
    .article-prose pre code{ background: transparent; padding: 0; color: inherit; }
    .article-prose img{ max-width: 100%; border-radius: 6px; margin: 28px 0; }
    .article-prose hr{ border: 0; border-top: 1px solid color-mix(in oklab, var(--ink) 14%, transparent); margin: 36px 0; }
  </style>
<% end %>

<div style="background: var(--paper); min-height: 100vh; color: var(--ink); font-family: 'Inter Tight', system-ui, sans-serif;">
  <div class="max-w-3xl mx-auto" style="padding: 48px 24px 80px;">

    <!-- Breadcrumb -->
    <nav style="display: flex; align-items: center; gap: 10px; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); margin-bottom: 36px;">
      <%= link_to "Blog", articles_path, style: "color: var(--ink); text-decoration: none;" %>
      <span>/</span>
      <span><%= @article.category_label %></span>
    </nav>

    <article>
      <!-- Header -->
      <header style="margin-bottom: 40px;">
        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 18px;">
          <span class="font-mono-label" style="color: var(--accent);"><%= @article.category_label %></span>
          <span class="font-mono-label" style="color: var(--muted);"><%= @article.reading_time %> min read</span>
        </div>

        <h1 class="font-display" style="font-size: clamp(40px, 5.5vw, 72px); line-height: 1; letter-spacing: -0.04em;"><%= @article.title %></h1>

        <% if @article.excerpt.present? %>
          <p style="font-family: 'Fraunces', serif; font-style: italic; font-weight: 300; font-size: 21px; color: var(--muted); margin-top: 22px; line-height: 1.4;"><%= @article.excerpt %></p>
        <% end %>

        <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 32px; padding-top: 24px; border-top: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); flex-wrap: wrap; gap: 14px;">
          <div style="display: flex; align-items: center; gap: 18px;">
            <% if @article.author.present? %>
              <div style="display: flex; align-items: center; gap: 10px;">
                <div style="width: 32px; height: 32px; background: var(--ink); color: var(--paper); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Fraunces', serif; font-size: 14px; font-weight: 500;"><%= @article.author.first(1).upcase %></div>
                <span style="font-family: 'Fraunces', serif; font-size: 15px; font-weight: 500; color: var(--ink); font-variation-settings: 'opsz' 24;"><%= @article.author %></span>
              </div>
            <% end %>
            <% if @article.published_at %>
              <time datetime="<%= @article.published_at.iso8601 %>" class="font-mono-label" style="color: var(--muted);"><%= @article.published_at.strftime("%b %d, %Y") %></time>
            <% end %>
          </div>

          <!-- Share -->
          <div style="display: flex; align-items: center; gap: 8px;">
            <span class="font-mono-label" style="color: var(--muted);">Share</span>
            <a href="https://twitter.com/intent/tweet?text=<%= ERB::Util.url_encode(@article.title) %>&url=<%= ERB::Util.url_encode(request.original_url) %>" target="_blank" rel="noopener noreferrer" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent); border-radius: 6px; color: var(--ink); transition: all .15s;" onmouseover="this.style.background='var(--ink)'; this.style.color='var(--paper)'" onmouseout="this.style.background='transparent'; this.style.color='var(--ink)'">
              <svg style="width: 14px; height: 14px;" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= ERB::Util.url_encode(request.original_url) %>" target="_blank" rel="noopener noreferrer" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent); border-radius: 6px; color: var(--ink); transition: all .15s;" onmouseover="this.style.background='var(--ink)'; this.style.color='var(--paper)'" onmouseout="this.style.background='transparent'; this.style.color='var(--ink)'">
              <svg style="width: 14px; height: 14px;" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          </div>
        </div>
      </header>

      <% if @article.featured_image_url.present? %>
        <div style="margin-bottom: 40px; border-radius: 6px; overflow: hidden; border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);">
          <img src="<%= @article.featured_image_url %>" alt="<%= @article.title %>" style="width: 100%; display: block;" loading="lazy">
        </div>
      <% end %>

      <!-- Content -->
      <div class="article-prose">
        <%= sanitize @article.content, tags: %w[h1 h2 h3 h4 h5 h6 p br a ul ol li strong em b i u s del blockquote pre code img hr div span table thead tbody tr th td figure figcaption action-text-attachment], attributes: %w[href src alt class id target rel width height sgid content-type url filename filesize] %>
      </div>

      <!-- Tags -->
      <% if @article.tags_list.any? %>
        <div style="margin-top: 40px; padding-top: 24px; border-top: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
          <span class="font-mono-label">Tags</span>
          <% @article.tags_list.each do |tag| %>
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 11px; padding: 4px 10px; background: var(--paper-2); color: var(--ink); border-radius: 999px; letter-spacing: 0.04em;"><%= tag %></span>
          <% end %>
        </div>
      <% end %>
    </article>

    <!-- Author -->
    <div style="margin-top: 56px; padding-top: 32px; border-top: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);" data-controller="hire-modal">
      <div style="background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 8px; padding: 32px;">
        <span class="font-mono-label" style="color: var(--accent);">Author</span>
        <div style="display: flex; gap: 24px; margin-top: 14px; flex-wrap: wrap;">
          <%= image_tag "wintan-author.jpg", alt: "Wintan", style: "width: 96px; height: 96px; border-radius: 6px; object-fit: cover; object-position: top; flex-shrink: 0;" %>
          <div style="flex: 1; min-width: 240px;">
            <h3 class="font-display" style="font-size: 26px; line-height: 1.05;">Wintan</h3>
            <p style="font-family: 'Fraunces', serif; font-style: italic; font-weight: 300; color: var(--muted); font-size: 14px; margin-top: 4px;">
              Ruby on Rails Developer · AI Enthusiast · Creator of <a href="https://rezumfit.com" style="color: var(--ink); text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 2px;">RezumFit</a>
            </p>
            <p style="font-size: 14px; color: var(--ink); line-height: 1.6; margin-top: 16px;">
              Ruby on Rails developer and AI enthusiast based in Nigeria with global remote experience. I specialize in full-stack Rails development, AI/ML integrations (OpenAI, Claude, Gemini), and building products that solve real problems. Husband, proud father of two (and counting), and the mind behind RezumFit. Open to freelance, contract, and full-time opportunities.
            </p>
            <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 18px;">
              <button type="button" data-action="click->hire-modal#open" class="btn-accent" style="padding: 9px 16px; font-size: 12px;">
                Hire me
              </button>
              <a href="https://github.com/wintan1418" target="_blank" rel="noopener noreferrer" class="btn-outline" style="padding: 8px 14px; font-size: 12px;">GitHub</a>
              <a href="https://www.linkedin.com/in/wintan" target="_blank" rel="noopener noreferrer" class="btn-outline" style="padding: 8px 14px; font-size: 12px;">LinkedIn</a>
            </div>
          </div>
        </div>
      </div>

      <%= render "hire_messages/modal" %>
    </div>

    <!-- Related -->
    <% if @related_articles.any? %>
      <div style="margin-top: 56px; padding-top: 32px; border-top: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);">
        <span class="font-mono-label" style="color: var(--accent);">Read next</span>
        <h2 class="font-display" style="font-size: 32px; line-height: 1.05; margin: 8px 0 24px;">You might also <em>like</em>.</h2>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px;" class="related-grid">
          <% @related_articles.each do |article| %>
            <%= link_to article_path(article), style: "display: block; padding: 22px; background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 6px; text-decoration: none; color: var(--ink); transition: all .15s;", onmouseover: "this.style.borderColor='var(--ink)'", onmouseout: "this.style.borderColor='color-mix(in oklab, var(--ink) 12%, transparent)'" do %>
              <span class="font-mono-label" style="color: var(--accent); display: block; margin-bottom: 10px;"><%= article.category_label %></span>
              <h3 class="font-display" style="font-size: 17px; line-height: 1.2; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;"><%= article.title %></h3>
              <p class="font-mono-label" style="margin-top: 12px; color: var(--muted);"><%= article.reading_time %> min read</p>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- CTA -->
    <% unless user_signed_in? %>
      <div style="margin-top: 56px; background: var(--ink); color: var(--paper); border-radius: 8px; padding: 40px 32px; text-align: center;">
        <span class="font-mono-label" style="color: var(--accent);">Apply the tips</span>
        <h2 class="font-display" style="font-size: 32px; line-height: 1.05; color: var(--paper); margin-top: 8px;">
          Put these tips into <em>action</em>.
        </h2>
        <p style="font-family: 'Fraunces', serif; font-style: italic; font-weight: 300; color: color-mix(in oklab, var(--paper) 70%, transparent); font-size: 16px; max-width: 40ch; margin: 12px auto 24px;">
          Use AI to optimize your resume and land more interviews. It's free to start.
        </p>
        <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
          <%= link_to "Start free", new_user_registration_path, class: "btn-accent" %>
          <%= link_to "Check ATS score", ats_checker_path, class: "btn-outline", style: "color: var(--paper); border-color: color-mix(in oklab, var(--paper) 35%, transparent);" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
  @media (max-width: 720px){
    .related-grid{grid-template-columns: 1fr !important;}
  }
</style>
