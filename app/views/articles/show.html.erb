<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <!-- Back -->
  <div class="mb-8">
    <%= link_to articles_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 transition-colors" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Blog
    <% end %>
  </div>

  <!-- Article Header -->
  <article>
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-<%= @article.category_color %>-100 text-<%= @article.category_color %>-700">
          <%= @article.category_label %>
        </span>
        <span class="text-sm text-gray-400"><%= @article.reading_time %> min read</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight"><%= @article.title %></h1>
      <div class="mt-4 flex items-center gap-4 text-sm text-gray-500">
        <% if @article.author.present? %>
          <span>By <strong><%= @article.author %></strong></span>
        <% end %>
        <% if @article.published_at %>
          <time datetime="<%= @article.published_at.iso8601 %>"><%= @article.published_at.strftime('%B %d, %Y') %></time>
        <% end %>
      </div>
    </header>

    <% if @article.featured_image_url.present? %>
      <div class="mb-8 rounded-2xl overflow-hidden">
        <img src="<%= @article.featured_image_url %>" alt="<%= @article.title %>" class="w-full">
      </div>
    <% end %>

    <!-- Article Content -->
    <div class="prose prose-lg max-w-none prose-headings:font-bold prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl">
      <%= raw @article.content %>
    </div>

    <!-- Tags -->
    <% if @article.tags_list.any? %>
      <div class="mt-8 pt-6 border-t border-gray-200">
        <div class="flex flex-wrap gap-2">
          <% @article.tags_list.each do |tag| %>
            <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-sm"><%= tag %></span>
          <% end %>
        </div>
      </div>
    <% end %>
  </article>

  <!-- Related Articles -->
  <% if @related_articles.any? %>
    <div class="mt-12 pt-8 border-t border-gray-200">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Related Articles</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        <% @related_articles.each do |article| %>
          <%= link_to article_path(article), class: "group block bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md transition-shadow" do %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-<%= article.category_color %>-100 text-<%= article.category_color %>-700 mb-2">
              <%= article.category_label %>
            </span>
            <h3 class="text-sm font-bold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-2"><%= article.title %></h3>
            <p class="mt-1 text-xs text-gray-400"><%= article.reading_time %> min read</p>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- CTA -->
  <% unless user_signed_in? %>
    <div class="mt-12 bg-gradient-to-r from-blue-600 to-purple-600 rounded-2xl p-8 text-center">
      <h2 class="text-xl font-bold text-white mb-2">Put these tips into action</h2>
      <p class="text-blue-100 mb-4">Use AI to optimize your resume and land more interviews.</p>
      <%= link_to 'Start Free', new_user_registration_path, class: "inline-flex items-center px-6 py-2.5 bg-white text-blue-600 font-bold rounded-xl shadow-lg hover:shadow-xl transition-all" %>
    </div>
  <% end %>
</div>
