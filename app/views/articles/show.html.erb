<% content_for :title, @article.meta_title.presence || "#{@article.title} | RezumFit Blog" %>
<% content_for :meta_description, @article.meta_description.presence || @article.excerpt.presence || truncate(strip_tags(@article.content), length: 160) %>

<div class="bg-white">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-400 mb-8">
      <%= link_to "Blog", articles_path, class: "hover:text-gray-600 transition-colors" %>
      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
      <span class="text-gray-500 truncate"><%= @article.category_label %></span>
    </nav>

    <!-- Article Header -->
    <article>
      <header class="mb-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold <%= @article.category_badge_classes %>"><%= @article.category_label %></span>
          <span class="text-sm text-gray-400"><%= @article.reading_time %> min read</span>
        </div>

        <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 leading-tight tracking-tight"><%= @article.title %></h1>

        <% if @article.excerpt.present? %>
          <p class="mt-4 text-lg text-gray-500 leading-relaxed"><%= @article.excerpt %></p>
        <% end %>

        <div class="mt-6 flex items-center justify-between">
          <div class="flex items-center gap-4 text-sm text-gray-500">
            <% if @article.author.present? %>
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-purple-500 rounded-full flex items-center justify-center">
                  <span class="text-white text-xs font-bold"><%= @article.author.first(1).upcase %></span>
                </div>
                <span class="font-medium text-gray-700"><%= @article.author %></span>
              </div>
            <% end %>
            <% if @article.published_at %>
              <time datetime="<%= @article.published_at.iso8601 %>" class="text-gray-400"><%= @article.published_at.strftime("%B %d, %Y") %></time>
            <% end %>
          </div>

          <!-- Share Buttons -->
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-400 hidden sm:inline">Share:</span>
            <a href="https://twitter.com/intent/tweet?text=<%= ERB::Util.url_encode(@article.title) %>&url=<%= ERB::Util.url_encode(request.original_url) %>" target="_blank" rel="noopener noreferrer" class="w-8 h-8 flex items-center justify-center rounded-lg bg-gray-100 hover:bg-blue-50 text-gray-500 hover:text-blue-500 transition-colors" title="Share on X">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= ERB::Util.url_encode(request.original_url) %>" target="_blank" rel="noopener noreferrer" class="w-8 h-8 flex items-center justify-center rounded-lg bg-gray-100 hover:bg-blue-50 text-gray-500 hover:text-blue-600 transition-colors" title="Share on LinkedIn">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          </div>
        </div>
      </header>

      <!-- Divider -->
      <hr class="border-gray-100 mb-8">

      <% if @article.featured_image_url.present? %>
        <div class="mb-10 rounded-2xl overflow-hidden shadow-sm">
          <img src="<%= @article.featured_image_url %>" alt="<%= @article.title %>" class="w-full" loading="lazy">
        </div>
      <% end %>

      <!-- Article Content -->
      <div class="prose prose-lg max-w-none
                  prose-headings:font-bold prose-headings:tracking-tight
                  prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
                  prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
                  prose-p:text-gray-600 prose-p:leading-relaxed
                  prose-a:text-blue-600 prose-a:font-medium prose-a:no-underline hover:prose-a:underline
                  prose-strong:text-gray-900
                  prose-ul:text-gray-600 prose-ol:text-gray-600
                  prose-li:marker:text-gray-400
                  prose-blockquote:border-blue-500 prose-blockquote:bg-blue-50 prose-blockquote:rounded-r-lg prose-blockquote:py-1 prose-blockquote:not-italic
                  prose-img:rounded-xl prose-img:shadow-sm
                  prose-code:bg-gray-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:before:content-none prose-code:after:content-none">
        <%= sanitize @article.content, tags: %w[h1 h2 h3 h4 h5 h6 p br a ul ol li strong em b i u s blockquote pre code img hr div span table thead tbody tr th td figure figcaption], attributes: %w[href src alt class id target rel width height] %>
      </div>

      <!-- Tags -->
      <% if @article.tags_list.any? %>
        <div class="mt-10 pt-6 border-t border-gray-100">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="text-xs font-medium text-gray-400 uppercase tracking-wider">Tags:</span>
            <% @article.tags_list.each do |tag| %>
              <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-medium"><%= tag %></span>
            <% end %>
          </div>
        </div>
      <% end %>
    </article>

    <!-- Related Articles -->
    <% if @related_articles.any? %>
      <div class="mt-14 pt-8 border-t border-gray-200">
        <h2 class="text-xl font-bold text-gray-900 mb-6">You might also like</h2>
        <div class="grid gap-6 sm:grid-cols-3">
          <% @related_articles.each do |article| %>
            <%= link_to article_path(article), class: "group block bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200" do %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold <%= article.category_badge_classes %> mb-3"><%= article.category_label %></span>
              <h3 class="text-sm font-bold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-2 leading-snug"><%= article.title %></h3>
              <p class="mt-2 text-xs text-gray-400"><%= article.reading_time %> min read</p>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- CTA -->
    <% unless user_signed_in? %>
      <div class="mt-14 bg-gradient-to-r from-blue-600 to-purple-600 rounded-2xl p-8 text-center">
        <h2 class="text-xl font-bold text-white mb-2">Put these tips into action</h2>
        <p class="text-blue-100 mb-5 max-w-md mx-auto">Use AI to optimize your resume and land more interviews. It's free to start.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-3">
          <%= link_to "Start Free", new_user_registration_path, class: "inline-flex items-center justify-center px-6 py-2.5 bg-white text-blue-600 font-bold rounded-xl shadow-lg hover:shadow-xl transition-all" %>
          <%= link_to "Check ATS Score", ats_checker_path, class: "inline-flex items-center justify-center px-6 py-2.5 bg-white/10 text-white font-semibold rounded-xl border border-white/20 hover:bg-white/20 transition-all" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
