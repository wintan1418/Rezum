<div class="min-h-full">
  <main class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Billing & Usage</h1>
        <p class="mt-1 text-gray-500">Manage your subscription, credits, and payment history</p>
      </div>
      <% if @subscription && @subscription.active? %>
        <%= link_to subscription_path(@subscription), class: "mt-4 sm:mt-0 inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-200 hover:bg-gray-50 rounded-xl transition-colors" do %>
          Manage Subscription
        <% end %>
      <% else %>
        <%= link_to new_subscription_path, class: "mt-4 sm:mt-0 inline-flex items-center px-5 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 rounded-xl shadow-sm transition-all" do %>
          Upgrade to Pro
        <% end %>
      <% end %>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Main Column -->
      <div class="lg:col-span-2 space-y-6">
        <!-- Current Plan Card -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="bg-gradient-to-r from-blue-600 to-purple-600 px-6 py-4">
            <h3 class="text-base font-semibold text-white">Current Plan</h3>
          </div>
          <div class="p-6">
            <% if @subscription && @subscription.active? %>
              <div class="flex items-center justify-between">
                <div>
                  <h4 class="text-xl font-bold text-gray-900"><%= @subscription.plan_name %></h4>
                  <p class="text-gray-500 text-sm"><%= @pricing[:symbol] %><%= @pricing[:currency] == "NGN" && !@pricing[:display_currency] ? (@subscription.plan_price * 1000).to_i.to_s.reverse.gsub(/(\d{3})(?=\d)/, '\1,').reverse : (@subscription.plan_price * 1000 / 1_600.0).round %> per <%= @subscription.billing_cycle %></p>
                  <div class="mt-2 flex items-center gap-3">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700">
                      <%= @subscription.status.humanize %>
                    </span>
                    <% if @subscription.cancel_at_period_end? %>
                      <span class="text-sm text-orange-600 font-medium">Cancels <%= @subscription.current_period_end.strftime("%b %d, %Y") %></span>
                    <% else %>
                      <span class="text-sm text-gray-500">Renews <%= @subscription.current_period_end.strftime("%b %d, %Y") %></span>
                    <% end %>
                  </div>
                </div>
                <div class="text-right">
                  <p class="text-3xl font-bold text-green-600">&infin;</p>
                  <p class="text-xs text-gray-500">Unlimited usage</p>
                </div>
              </div>
            <% else %>
              <div class="flex items-center justify-between">
                <div>
                  <h4 class="text-xl font-bold text-gray-900">Free Plan</h4>
                  <p class="text-gray-500 text-sm">Pay-per-use credits</p>
                  <span class="inline-flex items-center mt-2 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">Free Tier</span>
                </div>
                <div class="text-right">
                  <p class="text-3xl font-bold <%= @credits_remaining > 0 ? 'text-green-600' : 'text-red-500' %>"><%= @credits_remaining %></p>
                  <p class="text-xs text-gray-500">Credits remaining</p>
                </div>
              </div>
              <div class="mt-5 p-4 bg-gradient-to-r from-blue-50 to-purple-50 rounded-xl border border-blue-100">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="text-sm font-semibold text-gray-900">Upgrade to Pro</p>
                    <p class="text-xs text-gray-500 mt-0.5">Unlimited generations starting at <%= @pricing[:symbol] %><%= @pricing[:display_currency] ? "29" : "29,000" %>/mo</p>
                  </div>
                  <%= link_to new_subscription_path, class: "inline-flex items-center px-4 py-2 text-xs font-semibold text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 rounded-lg shadow-sm transition-all" do %>
                    Upgrade
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Purchase Credits -->
        <% unless @subscription && @subscription.active? %>
          <div class="bg-white rounded-xl shadow-sm border border-gray-100">
            <div class="px-6 py-4 border-b border-gray-100">
              <h3 class="text-base font-semibold text-gray-900">Purchase Credits</h3>
            </div>
            <div class="p-6">
              <% tiers = @pricing[:tiers] %>
              <% sym = @pricing[:symbol] %>
              <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: color-mix(in oklab, var(--ink) 12%, transparent); border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 8px; overflow: hidden;" class="credits-grid">
                <% tiers.each do |tier| %>
                  <% is_popular = tier[:badge] == "Most Popular" %>
                  <div style="display: flex; flex-direction: column; padding: 24px 20px; min-height: 280px; <%= is_popular ? 'background: var(--ink); color: var(--paper);' : 'background: var(--paper); color: var(--ink);' %>">
                    <!-- Eyebrow with badge inline -->
                    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; min-height: 16px;">
                      <span style="font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: <%= is_popular ? 'color-mix(in oklab, var(--paper) 60%, transparent)' : 'var(--muted)' %>;">
                        <%= tier[:label] || "#{tier[:credits]} Pack" %>
                      </span>
                      <% if tier[:badge].present? %>
                        <span style="font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.08em; color: var(--accent);"><%= tier[:badge] %></span>
                      <% end %>
                    </div>

                    <!-- Credits numeral -->
                    <div style="font-family: 'Fraunces', serif; font-size: 56px; font-weight: 400; letter-spacing: -0.04em; line-height: 0.9; font-variation-settings: 'opsz' 144;">
                      <%= tier[:credits] %>
                    </div>
                    <span style="font-family: 'Fraunces', serif; font-style: italic; font-weight: 300; font-size: 14px; color: <%= is_popular ? 'color-mix(in oklab, var(--paper) 60%, transparent)' : 'var(--muted)' %>; margin-top: 4px;">credits</span>

                    <!-- Price -->
                    <div style="margin-top: 18px;">
                      <div style="font-family: 'Fraunces', serif; font-size: 28px; font-weight: 500; letter-spacing: -0.02em; font-variation-settings: 'opsz' 36;">
                        <% if is_popular %>
                          <em style="font-style: italic; color: var(--accent);"><%= sym %><%= tier[:display] %></em>
                        <% else %>
                          <%= sym %><%= tier[:display] %>
                        <% end %>
                      </div>
                      <div style="font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.04em; color: <%= is_popular ? 'color-mix(in oklab, var(--paper) 55%, transparent)' : 'var(--muted)' %>; margin-top: 4px;">
                        <%= sym %><%= tier[:per_credit] %> / credit
                      </div>
                    </div>

                    <!-- Buy button -->
                    <div style="margin-top: auto; padding-top: 20px;">
                      <%= form_with url: purchase_credits_billing_index_path, method: :post, local: true, data: { turbo: false } do |f| %>
                        <%= hidden_field_tag :credits, tier[:credits] %>
                        <% if is_popular %>
                          <%= f.submit "Buy now", class: "btn-accent", style: "width: 100%; justify-content: center; padding: 12px 18px; font-size: 13px; cursor: pointer; border: none;" %>
                        <% else %>
                          <%= f.submit "Buy now", class: "btn-outline", style: "width: 100%; justify-content: center; padding: 11px 17px; font-size: 13px; cursor: pointer;" %>
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>

              <style>
                @media (max-width: 960px){ .credits-grid{grid-template-columns: repeat(2, 1fr) !important;} }
                @media (max-width: 480px){ .credits-grid{grid-template-columns: 1fr !important;} }
              </style>

              <div class="mt-4 p-3 bg-gray-50 rounded-lg border border-gray-100">
                <p class="text-xs font-medium text-gray-700 mb-1">Credit Usage:</p>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-1 text-xs text-gray-500">
                  <span>Resume Optimization: 2 credits</span>
                  <span>Cover Letter: 1 credit</span>
                  <span>Interview Prep: 3 credits</span>
                  <span>LinkedIn Optimization: 2 credits</span>
                  <span>AI Resume Builder: 10 credits</span>
                  <span class="font-medium text-purple-600">AI Pitch Deck: 30 credits</span>
                </div>
              </div>
              <p class="mt-3 text-center text-xs text-gray-400">Credits never expire</p>
            </div>
          </div>
        <% end %>

        <!-- What's Included -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
          <div class="px-6 py-4 border-b border-gray-100">
            <h3 class="text-base font-semibold text-gray-900">What's Included</h3>
          </div>
          <div class="p-6">
            <% if @subscription && @subscription.active? %>
              <% if @subscription.plan_id&.include?("premium") %>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  <% [
                    "Unlimited resume optimizations",
                    "Unlimited cover letters",
                    "Unlimited AI Pitch Decks",
                    "ATS scoring & keywords",
                    "AI Resume Builder",
                    "5 professional templates",
                    "PDF & DOCX downloads",
                    "Job Application Tracker",
                    "AI Interview Prep (STAR)",
                    "LinkedIn Optimization",
                    "Automated Job Scraper",
                    "AI job matching & scoring",
                    "Priority AI models",
                    "Priority support",
                    "Early access to new features"
                  ].each do |perk| %>
                    <div class="flex items-center gap-2">
                      <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                      </svg>
                      <span class="text-sm text-gray-700"><%= perk %></span>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  <% [
                    "Unlimited resume optimizations",
                    "Unlimited cover letters",
                    "AI Pitch Decks (30 credits each)",
                    "ATS scoring & keywords",
                    "AI Resume Builder",
                    "5 professional templates",
                    "PDF & DOCX downloads",
                    "Job Application Tracker",
                    "Priority support"
                  ].each do |perk| %>
                    <div class="flex items-center gap-2">
                      <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                      </svg>
                      <span class="text-sm text-gray-700"><%= perk %></span>
                    </div>
                  <% end %>
                </div>
                <div class="mt-4 p-3 bg-purple-50 rounded-lg border border-purple-100">
                  <p class="text-xs font-medium text-purple-800 mb-1">Upgrade to Premium for:</p>
                  <p class="text-xs text-purple-600">Interview Prep, LinkedIn Optimization, Job Scraper, Priority AI models</p>
                  <%= link_to "Upgrade", new_subscription_path, class: "inline-block mt-2 text-xs font-semibold text-purple-700 hover:text-purple-900" %>
                </div>
              <% end %>
            <% else %>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <% [
                  ["Resume optimization", true],
                  ["Cover letter generation", true],
                  ["ATS scoring", true],
                  ["AI Resume Builder", true],
                  ["PDF & DOCX downloads", true],
                  ["5 professional templates", true],
                  ["Interview Prep", false],
                  ["LinkedIn Optimization", false],
                  ["Job Scraper", false],
                  ["Priority AI models", false]
                ].each do |perk, available| %>
                  <div class="flex items-center gap-2">
                    <% if available %>
                      <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                      </svg>
                      <span class="text-sm text-gray-700"><%= perk %> <span class="text-xs text-gray-400">(uses credits)</span></span>
                    <% else %>
                      <svg class="w-4 h-4 text-gray-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                      </svg>
                      <span class="text-sm text-gray-400"><%= perk %> <span class="text-xs">(Pro/Premium)</span></span>
                    <% end %>
                  </div>
                <% end %>
              </div>
              <div class="mt-4 text-center">
                <%= link_to new_subscription_path, class: "inline-flex items-center px-4 py-2 text-xs font-semibold text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 rounded-lg transition-all" do %>
                  Unlock All Features
                <% end %>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Recent Payments -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
          <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
            <h3 class="text-base font-semibold text-gray-900">Recent Payments</h3>
            <%= link_to history_billing_index_path, class: "text-sm text-blue-600 hover:text-blue-800 font-medium" do %>
              View All
            <% end %>
          </div>
          <% if @payments.any? %>
            <div class="divide-y divide-gray-100">
              <% @payments.each do |payment| %>
                <div class="px-6 py-4 flex items-center justify-between hover:bg-gray-50 transition-colors">
                  <div class="flex items-center space-x-3">
                    <% if payment.successful? %>
                      <div class="w-8 h-8 rounded-full bg-green-50 flex items-center justify-center">
                        <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                      </div>
                    <% else %>
                      <div class="w-8 h-8 rounded-full bg-gray-50 flex items-center justify-center">
                        <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
                      </div>
                    <% end %>
                    <div>
                      <p class="text-sm font-medium text-gray-900"><%= payment.description_display %></p>
                      <p class="text-xs text-gray-500"><%= payment.created_at.strftime("%b %d, %Y") %></p>
                    </div>
                  </div>
                  <div class="text-right">
                    <p class="text-sm font-semibold text-gray-900"><%= payment.amount_display %></p>
                    <p class="text-xs <%= payment.successful? ? 'text-green-600' : 'text-gray-500' %>"><%= payment.status.humanize %></p>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="px-6 py-12 text-center">
              <p class="text-sm text-gray-500">No payments yet</p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Usage Summary -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h3 class="text-base font-semibold text-gray-900 mb-4">Usage Summary</h3>
          <div class="space-y-4">
            <div>
              <p class="text-sm text-gray-500">Total Spent</p>
              <p class="text-2xl font-bold text-gray-900"><%= @pricing[:symbol] %><%= @pricing[:display_currency] ? (@total_spent / 1_600.0).round : number_with_delimiter(@total_spent.to_i) %></p>
            </div>
            <div>
              <p class="text-sm text-gray-500">Credits Remaining</p>
              <p class="text-2xl font-bold <%= @credits_remaining > 0 ? 'text-green-600' : 'text-red-500' %>"><%= @credits_remaining %></p>
            </div>
            <div>
              <p class="text-sm text-gray-500">Account Status</p>
              <% if @subscription && @subscription.active? %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700">Pro</span>
              <% elsif current_user.trial_active? %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-blue-100 text-blue-700">Trial</span>
              <% else %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">Free</span>
              <% end %>
            </div>
            <% if @subscription && @subscription.active? %>
              <div>
                <p class="text-sm text-gray-500">Next Billing</p>
                <p class="text-sm font-medium text-gray-900"><%= @subscription.current_period_end.strftime("%b %d, %Y") %></p>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Quick Actions -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h3 class="text-base font-semibold text-gray-900 mb-4">Quick Actions</h3>
          <div class="space-y-2">
            <%= link_to history_billing_index_path, class: "flex items-center px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 rounded-lg transition-colors" do %>
              <svg class="w-4 h-4 mr-2.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
              Payment History
            <% end %>
            <% unless @subscription && @subscription.active? %>
              <%= link_to new_subscription_path, class: "flex items-center px-3 py-2 text-sm text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" do %>
                <svg class="w-4 h-4 mr-2.5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
                Upgrade to Pro
              <% end %>
            <% end %>
            <%= link_to resumes_path, class: "flex items-center px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 rounded-lg transition-colors" do %>
              <svg class="w-4 h-4 mr-2.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              Back to Resumes
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
