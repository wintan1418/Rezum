<div class="space-y-4">
  <% Array(section.content_data['entries']).each_with_index do |entry, i| %>
    <div class="p-4 bg-gray-50 rounded-lg space-y-3">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">Job Title</label>
          <input type="text" name="sections[<%= section.id %>][content][entries][<%= i %>][title]" value="<%= entry['title'] %>" class="w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm transition-all hover:border-gray-300" placeholder="e.g., Software Engineer">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">Company</label>
          <input type="text" name="sections[<%= section.id %>][content][entries][<%= i %>][company]" value="<%= entry['company'] %>" class="w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm transition-all hover:border-gray-300" placeholder="e.g., Google">
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Dates</label>
        <input type="text" name="sections[<%= section.id %>][content][entries][<%= i %>][dates]" value="<%= entry['dates'] %>" class="w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm transition-all hover:border-gray-300" placeholder="e.g., Jan 2022 - Present">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Key Achievements (one per line)</label>
        <textarea name="sections[<%= section.id %>][content][entries][<%= i %>][bullets_text]" rows="4" class="w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm transition-all hover:border-gray-300" placeholder="Led a team of 5 engineers&#10;Increased revenue by 25%&#10;Built and deployed microservices"><%= Array(entry['bullets']).join("\n") %></textarea>
      </div>
    </div>
  <% end %>
</div>
