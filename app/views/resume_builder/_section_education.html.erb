<div class="space-y-4">
  <% Array(section.content_data['entries']).each_with_index do |entry, i| %>
    <div class="p-4 bg-gray-50 rounded-lg space-y-3">
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Degree</label>
        <input type="text" name="sections[<%= section.id %>][content][entries][<%= i %>][degree]" value="<%= entry['degree'] %>" class="w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm transition-all hover:border-gray-300" placeholder="e.g., B.S. Computer Science">
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">School</label>
          <input type="text" name="sections[<%= section.id %>][content][entries][<%= i %>][school]" value="<%= entry['school'] %>" class="w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm transition-all hover:border-gray-300" placeholder="e.g., MIT">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">Dates</label>
          <input type="text" name="sections[<%= section.id %>][content][entries][<%= i %>][dates]" value="<%= entry['dates'] %>" class="w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm transition-all hover:border-gray-300" placeholder="e.g., 2018 - 2022">
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Additional Details</label>
        <input type="text" name="sections[<%= section.id %>][content][entries][<%= i %>][details]" value="<%= entry['details'] %>" class="w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm transition-all hover:border-gray-300" placeholder="GPA, honors, relevant coursework...">
      </div>
    </div>
  <% end %>
</div>
