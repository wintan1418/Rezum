<div class="space-y-4">
  <% Array(section.content_data['entries']).each_with_index do |entry, i| %>
    <div class="p-4 bg-gray-50 rounded-lg space-y-3">
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Project Name</label>
        <input type="text" name="sections[<%= section.id %>][content][entries][<%= i %>][name]" value="<%= entry['name'] %>" class="w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm transition-all hover:border-gray-300" placeholder="e.g., E-commerce Platform">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Description</label>
        <textarea name="sections[<%= section.id %>][content][entries][<%= i %>][description]" rows="2" class="w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm transition-all hover:border-gray-300" placeholder="Brief description of the project and your role..."><%= entry['description'] %></textarea>
      </div>
    </div>
  <% end %>
</div>
