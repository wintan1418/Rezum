<div style="background: var(--paper); min-height: 100vh; color: var(--ink); font-family: 'Inter Tight', system-ui, sans-serif;">
  <main class="max-w-4xl mx-auto" style="padding: 32px 24px 64px;">

    <!-- Header -->
    <div style="padding-bottom: 28px; border-bottom: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); margin-bottom: 28px;">
      <%= link_to "← All cover letters", cover_letters_path, class: "font-mono-label", style: "display: inline-block; margin-bottom: 10px;" %>

      <div style="display: flex; align-items: end; justify-content: space-between; gap: 24px; flex-wrap: wrap;">
        <div style="min-width: 0;">
          <h1 class="font-display" style="font-size: clamp(28px, 4vw, 42px);">
            <%= @cover_letter.company_name.presence || "Cover letter" %><% if @cover_letter.target_role.present? %> — <em><%= @cover_letter.target_role %></em><% end %>
          </h1>
          <div style="display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin-top: 12px;">
            <% if @cover_letter.content.present? %>
              <span class="font-mono-label"><%= @word_count %> words</span>
              <span class="font-mono-label"><%= @read_time %> read</span>
            <% end %>
            <span class="font-mono-label"><%= time_ago_in_words(@cover_letter.created_at) %> ago</span>
            <span class="font-mono-label" style="<%= case @cover_letter.status
                  when 'generated' then 'color: var(--accent);'
                  when 'failed' then 'color: #B3261E;'
                  else 'color: var(--ink);'
                  end %>"><%= @cover_letter.status.humanize %></span>
          </div>
        </div>

        <!-- Actions -->
        <div style="display: flex; align-items: center; gap: 10px; flex-wrap: wrap; flex-shrink: 0;">
          <%= link_to "Edit", edit_resume_cover_letter_path(@resume, @cover_letter), class: "btn-outline" %>
          <%= link_to "Preview", preview_resume_cover_letter_path(@resume, @cover_letter), target: "_blank", class: "btn-outline" %>

          <% if @cover_letter.content.present? %>
            <!-- Download dropdown -->
            <div class="relative inline-block text-left" data-controller="dropdown">
              <button type="button" class="btn-outline" data-action="click->dropdown#toggle">
                Download
                <svg style="width: 12px; height: 12px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <div data-dropdown-target="menu"
                   class="hidden absolute right-0 z-10 mt-2 w-44 origin-top-right card-paper"
                   style="box-shadow: 0 8px 24px color-mix(in oklab, var(--ink) 14%, transparent); overflow: hidden;">
                <%= link_to "PDF", download_resume_cover_letter_path(@resume, @cover_letter, format: :pdf), style: "display: block; padding: 11px 16px; font-size: 14px; color: var(--ink); text-decoration: none;", class: "hover:bg-[var(--paper-2)]" %>
                <div class="hairline"></div>
                <%= link_to "Word", download_resume_cover_letter_path(@resume, @cover_letter, format: :docx), style: "display: block; padding: 11px 16px; font-size: 14px; color: var(--ink); text-decoration: none;", class: "hover:bg-[var(--paper-2)]" %>
                <div class="hairline"></div>
                <%= link_to "Text", download_resume_cover_letter_path(@resume, @cover_letter, format: :txt), style: "display: block; padding: 11px 16px; font-size: 14px; color: var(--ink); text-decoration: none;", class: "hover:bg-[var(--paper-2)]" %>
              </div>
            </div>
          <% end %>

          <% if @cover_letter.generated? && @variations.empty? && @parent.nil? %>
            <%= link_to "Generate 3 variations", generate_variations_resume_cover_letter_path(@resume, @cover_letter), data: { turbo_method: :post }, class: "btn-ink" %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Variation switcher -->
    <% if @variations.any? || @parent.present? %>
      <% original = @parent || @cover_letter %>
      <% family = (@parent ? original.variations.recent : @variations).sort_by(&:created_at) %>
      <% strategy_labels = [ "Results-driven", "Culture-fit", "Problem-solver" ] %>
      <div style="display: flex; align-items: end; gap: 4px; overflow-x: auto; border-bottom: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); margin-bottom: 24px;">
        <% current = @cover_letter %>
        <%= link_to resume_cover_letter_path(original.resume, original),
            class: "font-mono-label",
            style: "flex-shrink: 0; padding: 8px 14px 10px; text-decoration: none; #{original == current ? 'color: var(--ink); border-bottom: 2px solid var(--accent); margin-bottom: -1px;' : ''}" do %>
          Original
        <% end %>
        <% family.each_with_index do |variation, i| %>
          <%= link_to resume_cover_letter_path(variation.resume, variation),
              class: "font-mono-label",
              style: "flex-shrink: 0; padding: 8px 14px 10px; text-decoration: none; white-space: nowrap; #{variation == current ? 'color: var(--ink); border-bottom: 2px solid var(--accent); margin-bottom: -1px;' : ''}" do %>
            Variation <%= i + 1 %><%= " · #{strategy_labels[i]}" if i < strategy_labels.size %>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <!-- Content -->
    <%= render "content", cover_letter: @cover_letter, resume: @resume %>
  </main>
</div>

<!-- Turbo Stream for real-time updates -->
<%= turbo_stream_from "cover_letter_#{@cover_letter.id}" %>
