<div id="cover_letter_content">
  <% if cover_letter.generating? %>
    <!-- Generating state -->
    <div class="card-paper" style="padding: 56px 32px; text-align: center;"
         data-controller="auto-refresh generation-animation"
         data-auto-refresh-url-value="<%= resume_cover_letter_path(resume, cover_letter) %>"
         data-auto-refresh-interval-value="3000">

      <span class="font-mono-label" style="color: var(--accent);">Generating</span>

      <h3 data-generation-animation-target="typewriter"
          style="font-family:'Fraunces',Georgia,serif; font-style: italic; font-weight: 400; font-variation-settings:'opsz' 40; font-size: clamp(22px, 3vw, 28px); letter-spacing: -0.01em; line-height: 1.2; max-width: 480px; margin: 14px auto 32px;">
        Writing your cover letter…
      </h3>

      <!-- 3-step progress (targets required by generation_animation_controller) -->
      <div style="display: flex; align-items: flex-start; justify-content: center; gap: 8px; max-width: 380px; margin: 0 auto 28px;">
        <div data-generation-animation-target="step" data-step="1" style="display: flex; flex-direction: column; align-items: center; gap: 8px; flex-shrink: 0;">
          <div class="w-6 h-6 rounded-full bg-blue-500 text-white flex items-center justify-center transition-all duration-500" style="font-size: 11px;">1</div>
          <span class="font-mono-label text-blue-600 font-medium">Analyzing</span>
        </div>
        <div class="hairline" style="flex: 1; margin-top: 12px;"></div>
        <div data-generation-animation-target="step" data-step="2" style="display: flex; flex-direction: column; align-items: center; gap: 8px; flex-shrink: 0;">
          <div class="w-6 h-6 rounded-full bg-gray-300 text-gray-500 flex items-center justify-center transition-all duration-500" style="font-size: 11px;">2</div>
          <span class="font-mono-label text-gray-500">Writing</span>
        </div>
        <div class="hairline" style="flex: 1; margin-top: 12px;"></div>
        <div data-generation-animation-target="step" data-step="3" style="display: flex; flex-direction: column; align-items: center; gap: 8px; flex-shrink: 0;">
          <div class="w-6 h-6 rounded-full bg-gray-300 text-gray-500 flex items-center justify-center transition-all duration-500" style="font-size: 11px;">3</div>
          <span class="font-mono-label text-gray-500">Finalizing</span>
        </div>
      </div>

      <p data-generation-animation-target="statusText" style="font-size: 14px; color: var(--ink);">
        Analyzing your resume and job requirements...
      </p>
      <p data-generation-animation-target="subText" style="font-size: 12.5px; color: var(--muted); margin-top: 4px;">
        Reading through your experience to craft the right narrative
      </p>

      <p class="font-mono-label" style="margin-top: 24px;">
        <span data-generation-animation-target="timer">Estimated time: 30–45 seconds</span>
      </p>
    </div>

  <% elsif cover_letter.failed? %>
    <!-- Failed state -->
    <div class="card-paper" style="padding: 48px 32px; text-align: center;">
      <span class="font-mono-label" style="color: #B3261E;">Generation failed</span>
      <h3 class="font-display" style="font-size: 26px; margin-top: 10px;">Something went wrong.</h3>
      <p style="color: var(--muted); font-size: 15px; margin: 12px auto 24px; max-width: 400px;">
        We hit an error while writing this letter. Your credit wasn't wasted — try again.
      </p>
      <%= link_to "Try again", regenerate_resume_cover_letter_path(resume, cover_letter), data: { turbo_method: :post }, class: "btn-ink", style: "margin: 0 auto;" %>
    </div>

  <% elsif cover_letter.content.present? %>
    <!-- Letter -->
    <div class="card-paper" data-controller="clipboard">
      <!-- Meta row -->
      <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap; padding: 16px 28px; border-bottom: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);">
        <span class="font-mono-label"><%= cover_letter.company_name %></span>
        <% if cover_letter.target_role.present? %>
          <span class="font-mono-label"><%= cover_letter.target_role %></span>
        <% end %>
        <% if cover_letter.hiring_manager_name.present? %>
          <span class="font-mono-label">To <%= cover_letter.hiring_manager_name %></span>
        <% end %>
        <span class="font-mono-label"><%= cover_letter.display_tone %></span>
        <span class="font-mono-label"><%= cover_letter.display_length %></span>
        <button type="button" data-action="clipboard#copy" class="font-mono-label"
                style="margin-left: auto; background: none; border: none; cursor: pointer; color: var(--accent);">
          <span data-clipboard-target="feedback">Copy text</span>
        </button>
      </div>

      <!-- Letter body -->
      <div style="padding: 32px 28px;" data-clipboard-target="source">
        <%= simple_format(cover_letter.content, style: "font-size: 16px; line-height: 1.7; color: var(--ink); margin-bottom: 1em;") %>
      </div>
    </div>

  <% else %>
    <!-- Draft state -->
    <div class="card-paper" style="padding: 48px 32px; text-align: center;">
      <span class="font-mono-label">Draft</span>
      <h3 class="font-display" style="font-size: 26px; margin-top: 10px;">Not written yet.</h3>
      <p style="color: var(--muted); font-size: 15px; margin: 12px auto 24px; max-width: 400px;">
        This cover letter is still a draft. Generate it to get a letter grounded in your resume.
      </p>
      <%= link_to "Generate cover letter →", regenerate_resume_cover_letter_path(resume, cover_letter), data: { turbo_method: :post }, class: "btn-accent", style: "margin: 0 auto;" %>
    </div>
  <% end %>
</div>
