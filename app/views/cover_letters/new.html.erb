<div style="background: var(--paper); min-height: 100vh; color: var(--ink); font-family: 'Inter Tight', system-ui, sans-serif;">
  <main class="max-w-3xl mx-auto" style="padding: 32px 24px 64px;">

    <!-- Header -->
    <div style="padding-bottom: 28px; border-bottom: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); margin-bottom: 36px;">
      <% if @resume %>
        <%= link_to "← Back to resume", resume_path(@resume), class: "font-mono-label", style: "display: inline-block; margin-bottom: 10px;" %>
      <% else %>
        <%= link_to "← All cover letters", cover_letters_path, class: "font-mono-label", style: "display: inline-block; margin-bottom: 10px;" %>
      <% end %>
      <h1 class="font-display" style="font-size: clamp(32px, 4.5vw, 48px);">
        New cover <em>letter</em>.
      </h1>
      <p style="color: var(--muted); font-size: 15px; margin-top: 8px; font-family:'Fraunces',serif; font-style: italic; font-weight: 300; font-variation-settings:'opsz' 24;">
        <% if @resume %>
          Written from your <%= @resume.target_role %> resume — takes about 30 seconds.
        <% else %>
          Pick a resume, name the company, and we do the writing.
        <% end %>
      </p>
    </div>

    <% if @resume.nil? && @resumes.blank? %>
      <!-- No resumes to write from -->
      <div class="card-paper" style="padding: 48px 32px; text-align: center;">
        <span class="font-mono-label">One step first</span>
        <h2 class="font-display" style="font-size: 28px; margin-top: 10px;">Upload a resume</h2>
        <p style="color: var(--muted); font-size: 15px; margin: 14px auto 24px; max-width: 380px;">
          Cover letters are written from a resume, so we never invent experience you don't have.
        </p>
        <%= link_to "Upload a resume", new_resume_path, class: "btn-accent", style: "margin: 0 auto;" %>
      </div>
    <% else %>
      <%= form_with model: (@resume ? [@resume, @cover_letter] : @cover_letter), local: true do |f| %>

        <!-- Errors -->
        <% if @cover_letter.errors.any? %>
          <div class="card-paper" style="border-left: 3px solid var(--accent); padding: 16px 20px; margin-bottom: 24px;">
            <span class="font-mono-label" style="color: var(--accent);">Please fix</span>
            <ul style="margin-top: 8px; font-size: 14px; color: var(--ink); list-style: disc; padding-left: 18px;">
              <% @cover_letter.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="card-paper" style="padding: 32px;">

          <% if @resume.nil? %>
            <!-- Resume picker (standalone flow) -->
            <div style="margin-bottom: 24px;">
              <label class="font-mono-label" for="cover_letter_resume_id" style="display: block; margin-bottom: 8px;">Resume to write from</label>
              <%= f.collection_select :resume_id, @resumes, :id,
                  ->(r) { "#{r.target_role.presence || "Resume ##{r.id}"} — #{r.created_at.strftime('%b %-d, %Y')}" },
                  { prompt: "Choose a resume" },
                  { class: "input-ink", required: true } %>
              <p style="font-size: 12px; color: var(--muted); margin-top: 6px;">Showing your <%= @resumes.first&.optimized? ? "optimized" : "recent" %> resumes.</p>
            </div>
            <div class="hairline" style="margin-bottom: 24px;"></div>
          <% end %>

          <!-- Company / role / hiring manager -->
          <div class="grid grid-cols-1 sm:grid-cols-2" style="gap: 20px;">
            <div>
              <label class="font-mono-label" for="cover_letter_company_name" style="display: block; margin-bottom: 8px;">Company</label>
              <%= f.text_field :company_name, class: "input-ink", required: true, placeholder: "e.g. Stripe" %>
            </div>
            <div>
              <label class="font-mono-label" for="cover_letter_target_role" style="display: block; margin-bottom: 8px;">Job title</label>
              <%= f.text_field :target_role, class: "input-ink", placeholder: "e.g. Senior Software Engineer" %>
            </div>
            <div class="sm:col-span-2">
              <label class="font-mono-label" for="cover_letter_hiring_manager_name" style="display: block; margin-bottom: 8px;">Hiring manager <span style="text-transform: none; letter-spacing: 0;">(optional)</span></label>
              <%= f.text_field :hiring_manager_name, class: "input-ink", placeholder: "If you know who's reading it" %>
            </div>
          </div>

          <div class="hairline" style="margin: 28px 0 24px;"></div>

          <!-- Tone + length -->
          <div class="grid grid-cols-1 sm:grid-cols-2" style="gap: 20px;">
            <div>
              <label class="font-mono-label" for="cover_letter_tone" style="display: block; margin-bottom: 8px;">Tone</label>
              <%= f.select :tone,
                  options_for_select([
                    [ "Professional & Formal", "professional" ],
                    [ "Friendly & Approachable", "friendly" ],
                    [ "Confident & Assertive", "confident" ],
                    [ "Casual & Conversational", "casual" ],
                    [ "Enthusiastic & Energetic", "enthusiastic" ]
                  ], @cover_letter.tone || "professional"),
                  {}, { class: "input-ink" } %>
            </div>
            <div>
              <label class="font-mono-label" for="cover_letter_length" style="display: block; margin-bottom: 8px;">Length</label>
              <%= f.select :length,
                  options_for_select([
                    [ "Short (200–250 words)", "short" ],
                    [ "Medium (300–400 words)", "medium" ],
                    [ "Long (450–600 words)", "long" ]
                  ], @cover_letter.length || "medium"),
                  {}, { class: "input-ink" } %>
            </div>
          </div>

          <div class="hairline" style="margin: 28px 0 24px;"></div>

          <!-- Job description -->
          <label class="font-mono-label" for="job_description" style="display: block; margin-bottom: 8px;">Job description</label>
          <textarea name="job_description" id="job_description" rows="8" class="input-ink"
                    placeholder="Paste the job posting (recommended)"
                    style="resize: vertical; line-height: 1.6;"><%= @resume&.job_description %></textarea>
          <p style="font-size: 12px; color: var(--muted); margin-top: 6px;">
            <% if @resume&.job_description.present? %>
              Prefilled from this resume's job description — edit it if you're targeting a different posting.
            <% else %>
              The more of the posting we can read, the more targeted the letter.
            <% end %>
          </p>

          <div class="hairline" style="margin: 28px 0 24px;"></div>

          <!-- Credits + submit -->
          <div style="display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;">
            <p style="font-size: 12px; color: var(--muted);">
              Uses 1 credit.
              <% if current_user.can_generate? %>
                <% if current_user.has_active_subscription? %>
                  Covered by your subscription.
                <% elsif current_user.credits_remaining > 0 %>
                  <%= current_user.credits_remaining %> remaining.
                <% end %>
              <% else %>
                You're out of credits — <%= link_to "upgrade to continue", new_subscription_path, style: "color: var(--accent); text-decoration: underline;" %>.
              <% end %>
            </p>
            <% if current_user.can_generate? %>
              <%= f.submit "Generate cover letter →", class: "btn-accent", data: { disable_with: "Generating…" } %>
            <% else %>
              <%= link_to "Upgrade to generate", new_subscription_path, class: "btn-ink" %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  </main>
</div>
