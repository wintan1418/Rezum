<div class="min-h-full">
  <main class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Cover Letters</h1>
        <p class="mt-1 text-gray-500">AI-generated cover letters tailored for each job</p>
      </div>
      <% if current_user.resumes.any? %>
        <%= link_to new_resume_cover_letter_path(current_user.resumes.recent.first), class: "mt-4 sm:mt-0 inline-flex items-center px-5 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 rounded-xl shadow-sm transition-all" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
          </svg>
          New Cover Letter
        <% end %>
      <% else %>
        <%= link_to new_resume_path, class: "mt-4 sm:mt-0 inline-flex items-center px-5 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 rounded-xl shadow-sm transition-all" do %>
          Upload Resume First
        <% end %>
      <% end %>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
        <p class="text-2xl font-bold text-gray-900"><%= @cover_letters.count %></p>
        <p class="text-sm text-gray-500">Total letters</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
        <p class="text-2xl font-bold text-green-600"><%= @cover_letters.select(&:generated?).count %></p>
        <p class="text-sm text-gray-500">Generated</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
        <p class="text-2xl font-bold text-purple-600"><%= @cover_letters.map(&:company_name).uniq.count %></p>
        <p class="text-sm text-gray-500">Companies</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
        <p class="text-2xl font-bold text-blue-600"><%= @cover_letters.map(&:target_role).uniq.count %></p>
        <p class="text-sm text-gray-500">Roles</p>
      </div>
    </div>

    <% if @cover_letters.any? %>
      <!-- Card Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        <% @cover_letters.each do |cl| %>
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-gray-200 transition-all group">
            <div class="p-5">
              <!-- Header -->
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center space-x-3 min-w-0">
                  <div class="w-10 h-10 rounded-lg bg-purple-50 flex-shrink-0 flex items-center justify-center">
                    <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                  </div>
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-gray-900 truncate"><%= cl.company_name %></p>
                    <p class="text-xs text-gray-500 truncate"><%= cl.target_role %></p>
                  </div>
                </div>
                <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium flex-shrink-0
                  <%= case cl.status
                      when 'draft' then 'bg-gray-100 text-gray-700'
                      when 'generating' then 'bg-yellow-100 text-yellow-700'
                      when 'generated' then 'bg-green-100 text-green-700'
                      when 'failed' then 'bg-red-100 text-red-700'
                      else 'bg-gray-100 text-gray-700'
                      end %>">
                  <%= cl.status.humanize %>
                </span>
              </div>

              <!-- Tone & Length badges -->
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs font-medium text-gray-500 bg-gray-50 px-2 py-0.5 rounded"><%= cl.display_tone %></span>
                <span class="text-xs font-medium text-gray-500 bg-gray-50 px-2 py-0.5 rounded"><%= cl.display_length %></span>
              </div>

              <!-- Content Preview -->
              <% if cl.content.present? %>
                <p class="text-xs text-gray-500 leading-relaxed line-clamp-3 mb-4"><%= truncate(cl.content, length: 150) %></p>
              <% else %>
                <p class="text-xs text-gray-400 italic mb-4">Content not generated yet</p>
              <% end %>

              <!-- Meta -->
              <p class="text-xs text-gray-400 mb-3"><%= time_ago_in_words(cl.created_at) %> ago</p>

              <!-- Actions -->
              <div class="flex items-center gap-2 pt-3 border-t border-gray-100">
                <%= link_to resume_cover_letter_path(cl.resume, cl), class: "flex-1 inline-flex justify-center items-center px-3 py-1.5 text-xs font-medium text-purple-700 bg-purple-50 hover:bg-purple-100 rounded-lg transition-colors" do %>
                  View
                <% end %>
                <% if cl.generated? %>
                  <%= link_to download_resume_cover_letter_path(cl.resume, cl, format: :pdf), target: "_blank", class: "inline-flex justify-center items-center px-2 py-1.5 text-xs text-gray-500 hover:text-green-600 rounded-lg transition-colors" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                    </svg>
                  <% end %>
                <% end %>
                <%= link_to resume_cover_letter_path(cl.resume, cl), data: { turbo_method: :delete, turbo_confirm: 'Delete this cover letter?' }, class: "inline-flex justify-center items-center px-2 py-1.5 text-xs text-gray-400 hover:text-red-600 rounded-lg transition-colors" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- Empty State -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-16 text-center">
        <div class="w-20 h-20 rounded-2xl bg-purple-50 flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">No cover letters yet</h3>
        <p class="text-gray-500 mb-6 max-w-sm mx-auto">Generate personalized cover letters tailored to each job posting with AI.</p>
        <% if current_user.resumes.any? %>
          <%= link_to new_resume_cover_letter_path(current_user.resumes.recent.first), class: "inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 rounded-xl shadow-sm transition-all" do %>
            Create Your First Cover Letter
          <% end %>
        <% else %>
          <%= link_to new_resume_path, class: "inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 rounded-xl shadow-sm transition-all" do %>
            Upload a Resume First
          <% end %>
        <% end %>
      </div>
    <% end %>
  </main>
</div>
