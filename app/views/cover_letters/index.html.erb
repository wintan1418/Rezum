<div style="background: var(--paper); min-height: 100vh; color: var(--ink); font-family: 'Inter Tight', system-ui, sans-serif;">
  <main class="max-w-7xl mx-auto" style="padding: 32px 24px 64px;">

    <!-- Header -->
    <div style="display: flex; align-items: end; justify-content: space-between; gap: 24px; flex-wrap: wrap; padding-bottom: 28px; border-bottom: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); margin-bottom: 36px;">
      <div>
        <span class="font-mono-label">Correspondence</span>
        <h1 class="font-display" style="font-size: clamp(36px, 5vw, 56px); margin-top: 6px;">
          Cover <em>letters</em>.
        </h1>
        <p style="color: var(--muted); font-size: 15px; margin-top: 8px; font-family:'Fraunces',serif; font-style: italic; font-weight: 300; font-variation-settings:'opsz' 24;">
          One letter per job, written from your actual resume.
        </p>
      </div>
      <% if current_user.resumes.any? %>
        <%= link_to new_cover_letter_path, class: "btn-accent", style: "flex-shrink: 0;" do %>
          <svg style="width: 14px; height: 14px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m6-6H6"/></svg>
          New cover letter
        <% end %>
      <% else %>
        <%= link_to "Upload a resume first", new_resume_path, class: "btn-outline", style: "flex-shrink: 0;" %>
      <% end %>
    </div>

    <!-- Stat row -->
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 6px; overflow: hidden; margin-bottom: 48px;">
      <% [
        ["Letters", @cover_letters.size.to_s, "Drafted on RezumFit"],
        ["Generated", @cover_letters.count { |cl| cl.generated? }.to_s, "Ready to send"],
        ["Companies", @companies_count.to_s, "Applied to"]
      ].each_with_index do |(label, value, sub), i| %>
        <div style="padding: 20px 24px; <%= 'border-left: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);' if i > 0 %>">
          <span class="font-mono-label"><%= label %></span>
          <div class="font-display" style="font-size: 36px; margin-top: 4px;"><%= value %></div>
          <p style="font-size: 12px; color: var(--muted); margin-top: 2px;"><%= sub %></p>
        </div>
      <% end %>
    </div>

    <% if @cover_letters.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        <% @cover_letters.each do |cl| %>
          <div class="card-paper" style="padding: 22px; display: flex; flex-direction: column;">
            <!-- Company / role / status -->
            <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;">
              <div style="min-width: 0;">
                <p style="font-size: 17px; font-weight: 500; letter-spacing: -0.01em; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= cl.company_name.presence || "Untitled" %></p>
                <p style="font-size: 13px; color: var(--muted); margin-top: 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= cl.target_role %></p>
              </div>
              <span class="font-mono-label" style="flex-shrink: 0; <%= case cl.status
                    when 'generated' then 'color: var(--accent);'
                    when 'generating' then 'color: var(--ink);'
                    when 'failed' then 'color: #B3261E;'
                    else ''
                    end %>"><%= cl.status.humanize %></span>
            </div>

            <!-- Tone / length / variations chips -->
            <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-top: 12px;">
              <span class="font-mono-label" style="padding: 4px 10px; border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent); border-radius: 999px;"><%= cl.display_tone %></span>
              <span class="font-mono-label" style="padding: 4px 10px; border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent); border-radius: 999px;"><%= cl.display_length %></span>
              <% if cl.variations.size > 0 %>
                <span class="font-mono-label" style="padding: 4px 10px; background: var(--accent-soft); border: 1px solid transparent; border-radius: 999px; color: var(--ink);"><%= pluralize(cl.variations.size, "variation") %></span>
              <% end %>
            </div>

            <!-- Preview -->
            <% if cl.content.present? %>
              <p class="line-clamp-2" style="font-size: 13.5px; color: var(--muted); line-height: 1.6; margin-top: 14px;"><%= truncate(cl.content, length: 160) %></p>
            <% else %>
              <p style="font-size: 13.5px; color: var(--muted); font-family:'Fraunces',serif; font-style: italic; margin-top: 14px;">Not generated yet.</p>
            <% end %>

            <!-- Meta + actions -->
            <div style="margin-top: auto; padding-top: 16px;">
              <p class="font-mono-label" style="margin-bottom: 12px;"><%= time_ago_in_words(cl.created_at) %> ago</p>
              <div class="hairline" style="margin-bottom: 14px;"></div>
              <div style="display: flex; align-items: center; gap: 16px;">
                <%= link_to "View →", resume_cover_letter_path(cl.resume, cl), class: "font-mono-label", style: "color: var(--accent);" %>
                <% if cl.generated? %>
                  <%= link_to "Download", download_resume_cover_letter_path(cl.resume, cl, format: :pdf), class: "font-mono-label", style: "color: var(--ink);" %>
                <% end %>
                <%= link_to "Delete", resume_cover_letter_path(cl.resume, cl), data: { turbo_method: :delete, turbo_confirm: "Delete this cover letter?" }, class: "font-mono-label", style: "margin-left: auto;" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- Empty state -->
      <div class="card-paper" style="padding: 64px 32px; text-align: center; max-width: 560px; margin: 0 auto;">
        <span class="font-mono-label">Nothing here yet</span>
        <h2 class="font-display" style="font-size: 30px; margin-top: 10px;">Your first letter is <em>one job posting</em> away.</h2>
        <p style="color: var(--muted); font-size: 15px; margin: 14px auto 24px; max-width: 380px;">
          Pick a resume, paste the posting, and we draft a letter grounded in your real experience.
        </p>
        <% if current_user.resumes.any? %>
          <%= link_to "Write my first cover letter", new_cover_letter_path, class: "btn-accent", style: "margin: 0 auto;" %>
        <% else %>
          <%= link_to "Upload a resume first", new_resume_path, class: "btn-ink", style: "margin: 0 auto;" %>
        <% end %>
      </div>
    <% end %>
  </main>
</div>
