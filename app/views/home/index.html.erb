  <!-- ============================================================
       EXIT POPUP — editorial styled
       ============================================================ -->
  <% unless user_signed_in? %>
    <div id="exit-popup" class="exit-pop" role="dialog" aria-labelledby="exit-pop-title" aria-modal="true">
      <div class="panel">
        <button class="close" type="button" onclick="document.getElementById('exit-popup').classList.remove('show')">CLOSE ✕</button>
        <span class="eyebrow">Before you go</span>
        <h3 id="exit-pop-title">Your resume might be <em>getting rejected</em> right now.</h3>
        <p>Check your ATS score in under 30 seconds. Free. No sign-up. No credit card. Just upload and see where you stand.</p>
        <div style="margin-top:24px;display:flex;flex-direction:column;gap:12px">
          <%= link_to ats_checker_path, class: "btn-primary", style: "background:var(--accent);color:#fff;justify-content:center;text-align:center" do %>
            Check my ATS score — free
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          <% end %>
          <div style="text-align:center;padding-top:16px;border-top:1px solid color-mix(in oklab, var(--ink) 12%, transparent);margin-top:8px">
            <p class="mono" style="color:var(--muted);margin-bottom:12px">Or join the community</p>
            <a href="https://t.me/+MaJ-KpCG_OFkZTA0" target="_blank" rel="noopener" class="btn-ghost" style="display:inline-flex;justify-content:center">Join Telegram — free</a>
          </div>
        </div>
      </div>
    </div>

    <script>
      (function(){
        var key = "rezumfit_exit_seen_v3";
        if (sessionStorage.getItem(key)) return;
        var pop = document.getElementById("exit-popup");
        if (!pop) return;
        function show(){
          if (sessionStorage.getItem(key)) return;
          sessionStorage.setItem(key, "1");
          pop.classList.add("show");
        }
        setTimeout(show, 12000);
        document.addEventListener("mouseout", function(e){
          if (!e.toElement && !e.relatedTarget && e.clientY < 10) show();
        });
        pop.addEventListener("click", function(e){
          if (e.target === pop) pop.classList.remove("show");
        });
        document.addEventListener("keydown", function(e){
          if (e.key === "Escape") pop.classList.remove("show");
        });
      })();
    </script>
  <% end %>

  <!-- Pricing currency swap (NGN ↔ USD by timezone) -->
  <script>
    (function(){
      try {
        var nigerianTZ = ["Africa/Lagos"];
        var tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
        var isNigeria = nigerianTZ.indexOf(tz) !== -1;
        if (isNigeria) {
          document.querySelectorAll("[data-pricing-target='price']").forEach(function(el){
            var ngn = el.getAttribute("data-price-ngn");
            if (ngn) el.textContent = ngn;
          });
        }
      } catch(e){}
    })();
  </script>

