<% content_for :title, "RezumFit — A resume, tailored." %>
<% content_for :meta_description, "RezumFit reads the listing, rewrites your resume, and returns a document that beats the ATS — without losing the voice that made it yours." %>

<% content_for :head do %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "RezumFit",
    "url": "<%= root_url %>",
    "logo": "<%= "#{request.base_url}/icon.png" %>",
    "description": "AI-powered resume optimization and cover letter generation platform.",
    "sameAs": ["https://github.com/wintan1418"]
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "RezumFit",
    "url": "<%= root_url %>",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "offers": {"@type": "Offer", "price": "0", "priceCurrency": "USD", "description": "Free tier with 2 credits. Pro plans start at $29/month."},
    "description": "Optimize your resume for ATS systems and generate tailored cover letters in seconds."
  }
  </script>
<% end %>

<div class="editorial">

  <!-- ============================================================
       NAV
       ============================================================ -->
  <nav class="top">
    <div class="wrap row">
      <%= link_to root_path, class: "mark", aria: { label: "RezumFit" } do %>
        <span class="glyph"></span>
        <span>RezumFit</span>
      <% end %>
      <div class="links">
        <%= link_to "ATS Checker", ats_checker_path, style: "color:var(--accent)" %>
        <a href="#features">Features</a>
        <a href="#how-it-works">How it works</a>
        <%= link_to "Blog", articles_path %>
        <a href="#pricing">Pricing</a>
        <a href="#faq">FAQ</a>
      </div>
      <div class="cta">
        <% if user_signed_in? %>
          <%= link_to "Dashboard", dashboard_path %>
          <%= link_to "New resume", new_resume_path, class: "btn" %>
        <% else %>
          <%= link_to "Sign in", new_user_session_path %>
          <%= link_to "Start free", new_user_registration_path, class: "btn" %>
        <% end %>
      </div>
    </div>
  </nav>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <header class="hero" data-screen-label="01 Hero">
    <div class="wrap">
      <div class="hero-eyebrow">
        <span class="dot"></span>
        <span class="mono">AI-powered career tools · Free to start</span>
      </div>

      <h1>
        Is your resume<br>
        <span class="ampline">getting <em>rejected</em>&thinsp;?</span>
      </h1>

      <div class="sub">
        <p class="lede">75% of resumes are rejected by ATS before a human ever sees them. RezumFit reads the listing, rewrites your draft, and returns a document that passes — without losing the voice that made it yours.</p>
        <div class="actions">
          <div class="pair">
            <%= link_to ats_checker_path, class: "btn-primary" do %>
              Check my ATS score — free
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            <% end %>
            <%= link_to "Or tailor a draft", new_user_registration_path, class: "btn-ghost" %>
          </div>
          <span class="mono" style="color:var(--muted)">No credit card · Free report in &lt; 30s · GPT-4 + Claude + Gemini</span>
        </div>
      </div>
    </div>

    <!-- Trusted by — companies our users target -->
    <div class="marquee" aria-hidden="true">
      <div class="track">
        <span class="mono" style="color:var(--muted);font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.12em;text-transform:uppercase;font-style:normal">Trusted by professionals at</span><span class="dot">✦</span>
        <span>Google</span><span class="dot">✦</span>
        <span>Microsoft</span><span class="dot">✦</span>
        <span>Amazon</span><span class="dot">✦</span>
        <span>Meta</span><span class="dot">✦</span>
        <span>Deloitte</span><span class="dot">✦</span>
        <span>PwC</span><span class="dot">✦</span>
        <span>Stripe</span><span class="dot">✦</span>
        <span>Andela</span><span class="dot">✦</span>
        <span>Flutterwave</span><span class="dot">✦</span>
        <span>McKinsey</span><span class="dot">✦</span>
        <span class="mono" style="color:var(--muted);font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.12em;text-transform:uppercase;font-style:normal">Trusted by professionals at</span><span class="dot">✦</span>
        <span>Google</span><span class="dot">✦</span>
        <span>Microsoft</span><span class="dot">✦</span>
        <span>Amazon</span><span class="dot">✦</span>
        <span>Meta</span><span class="dot">✦</span>
        <span>Deloitte</span><span class="dot">✦</span>
        <span>PwC</span><span class="dot">✦</span>
        <span>Stripe</span><span class="dot">✦</span>
        <span>Andela</span><span class="dot">✦</span>
        <span>Flutterwave</span><span class="dot">✦</span>
        <span>McKinsey</span><span class="dot">✦</span>
      </div>
    </div>
  </header>

  <!-- ============================================================
       STATS BAR
       ============================================================ -->
  <section data-screen-label="02 Numbers">
    <div class="wrap">
      <div class="stats">
        <div class="stat">
          <div class="n"><em>+47</em></div>
          <div class="l">Avg ATS score boost</div>
          <div class="d">After a single RezumFit pass</div>
        </div>
        <div class="stat">
          <div class="n">30<em>s</em></div>
          <div class="l">Median draft time</div>
          <div class="d">From paste to polished</div>
        </div>
        <div class="stat">
          <div class="n">3<em>×</em></div>
          <div class="l">Recruiter callbacks</div>
          <div class="d">vs. an untailored resume</div>
        </div>
