        <!-- SVG pattern overlay -->
        <div class="absolute inset-0 opacity-5">
          <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg"><defs><pattern id="cta-grid" width="32" height="32" patternUnits="userSpaceOnUse"><path d="M 32 0 L 0 0 0 32" fill="none" stroke="white" stroke-width="0.5"/></pattern></defs><rect width="100%" height="100%" fill="url(#cta-grid)"/></svg>
        </div>

        <h2 class="text-3xl sm:text-4xl font-bold text-white relative z-10">Ready to land your dream job?</h2>
        <p class="mt-4 text-lg text-blue-100 max-w-xl mx-auto relative z-10">Join thousands of professionals using AI to optimize their resumes, ace interviews, and get more offers.</p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4 relative z-10">
          <%= link_to new_user_registration_path, class: "inline-flex items-center px-8 py-4 text-base font-semibold text-blue-700 bg-white hover:bg-blue-50 rounded-xl shadow-lg hover:shadow-xl transition-all" do %>
            Get Started Free
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          <% end %>
          <a href="#pricing" class="inline-flex items-center px-6 py-3.5 text-base font-medium text-white/90 hover:text-white border border-white/30 hover:border-white/50 rounded-xl transition-all">
            View Pricing
          </a>
        </div>
        <p class="mt-5 text-sm text-blue-200 relative z-10">No credit card required. 2 free credits included.</p>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- FOOTER                                       -->
  <!-- ============================================ -->
  <%= render 'shared/public_footer' %>

<script>
  // Detect visitor location and swap pricing display
  (function() {
    var nigerianTimezones = ["Africa/Lagos"];
    var tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
    var isNigeria = nigerianTimezones.indexOf(tz) !== -1;

    // Default is NGN (already rendered). Only swap if international.
    if (!isNigeria) {
      var els = document.querySelectorAll("[data-pricing-target='price']");
      els.forEach(function(el) {
        var usd = el.getAttribute("data-price-usd");
        if (usd) {
          el.textContent = usd;
        }
      });
    }
  })();
</script>
</body>
</html>
