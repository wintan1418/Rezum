          ["★★★★★", "As a career changer, I struggled to position my experience. RezumFit rewrote my resume to highlight transferable skills. Got my dream job within 3 weeks.", "Jessica P.", "Marketing Director", "JP"],
          ["★★★★★", "Fresh out of uni with zero interview calls. After RezumFit optimized my resume, I got 4 interviews in one week. The ATS keyword matching is a game changer.", "Amara O.", "Recent Graduate", "AO"],
          ["★★★★☆", "Switching from teaching to tech seemed impossible. RezumFit translated my classroom skills into corporate language. I'm now a UX Researcher at a Fortune 500.", "David M.", "Career Changer → UX Researcher", "DM"],
          ["★★★★★", "Even at the executive level, ATS matters. RezumFit optimized my VP resume in seconds and the interview prep feature helped me nail the behavioural questions.", "Linda T.", "VP of Operations", "LT"]
        ].each do |(stars, body, name, role, init)| %>
          <div class="step" style="min-height:auto;padding:36px 32px">
            <span class="mono" style="color:var(--accent);letter-spacing:.2em"><%= stars %></span>
            <p style="font-family:'Fraunces',serif;font-size:16px;font-weight:300;font-variation-settings:'opsz' 24;line-height:1.5;color:var(--ink);max-width:none;margin-top:0;font-style:italic">"<%= body %>"</p>
            <div style="display:flex;align-items:center;gap:12px;margin-top:auto;padding-top:24px;border-top:1px solid color-mix(in oklab, var(--ink) 10%, transparent)">
              <div style="width:36px;height:36px;border-radius:50%;background:var(--ink);color:var(--paper);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:500"><%= init %></div>
              <div>
                <p style="font-family:'Fraunces',serif;font-size:15px;font-weight:500;letter-spacing:-0.01em;font-variation-settings:'opsz' 24;color:var(--ink);margin:0"><%= name %></p>
                <p class="mono" style="color:var(--muted);margin-top:2px"><%= role %></p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <!-- ============================================================
       TRUST BADGES — 4
       ============================================================ -->
  <section data-screen-label="16 Trust">
    <div class="wrap">
      <div class="stats stats-4" style="padding:40px 0">
        <% [
          ["SSL Encrypted", "256-bit encryption · end to end"],
          ["Data Privacy", "Your documents, never trained on"],
          ["95% Satisfaction", "From verified user surveys"],
          ["Cancel Anytime", "No commitments, no contracts"]
        ].each_with_index do |(title, body), i| %>
          <div class="stat">
            <div class="mono" style="color:var(--accent)">Trust 0<%= i + 1 %></div>
            <div style="font-family:'Fraunces',serif;font-size:24px;letter-spacing:-0.02em;font-weight:500;font-variation-settings:'opsz' 36;margin-top:14px"><%= title %></div>
            <div style="color:var(--muted);font-size:13px;margin-top:6px;font-family:'Inter Tight';font-style:normal;line-height:1.5"><%= body %></div>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FAQ
       ============================================================ -->
  <section id="faq" data-screen-label="17 FAQ">
    <div class="wrap">
      <div class="faq">
        <h2>Reasonable <em>questions,</em><br>asked often.</h2>
        <div class="list">
          <% if defined?(FaqHelper) && FaqHelper.const_defined?(:FAQ_ITEMS) && FaqHelper::FAQ_ITEMS.any? %>
            <% FaqHelper::FAQ_ITEMS.each_with_index do |faq, index| %>
              <details<%= ' open' if index == 0 %>>
                <summary><%= faq[:question] %></summary>
                <p><%= faq[:answer] %></p>
              </details>
            <% end %>
          <% else %>
            <details open>
              <summary>Will it sound like me, or like ChatGPT?</summary>
              <p>RezumFit is trained to preserve voice. We treat your resume as authoritative source material — we re-order, re-emphasise, and tighten, but never invent experience or replace your phrasing with generic filler.</p>
            </details>
            <details>
              <summary>Is the model reading my resume to train itself?</summary>
              <p>No. Your documents are processed in-session and never used as training data. Drafts are encrypted at rest and you can purge your library at any time from settings.</p>
            </details>
            <details>
              <summary>What about ATS — applicant tracking systems?</summary>
              <p>Every export passes a structural check: clean headings, parseable dates, no hidden tables. We score readability against the major ATS engines and flag anything brittle before you send.</p>
            </details>
            <details>
              <summary>Can I bring my own template?</summary>
              <p>Yes. Upload a DOCX or share a Figma file. RezumFit fills your tailored draft into your existing layout — typography, hierarchy and all.</p>
            </details>
            <details>
              <summary>Does it write cover letters?</summary>
              <p>Yes — included on the Pro and Premium plans. Same philosophy: it studies the listing and your voice, then drafts something you'd actually have written on a good Tuesday.</p>
            </details>
            <details>
              <summary>How does pricing work? Do credits expire?</summary>
              <p>One credit equals one resume optimization. Credits never expire and you only buy what you need — no monthly bill to remember to cancel.</p>
            </details>
          <% end %>
        </div>
      </div>
    </div>
  </section>

