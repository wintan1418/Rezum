<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="scroll-smooth">
<head>
  <title>ReZum - AI-Powered Resume & Cover Letter Generator</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="description" content="Optimize your resume for ATS systems and generate tailored cover letters in seconds. AI-powered tools trusted by thousands of job seekers.">
  <meta name="keywords" content="resume optimizer, ATS score, cover letter generator, AI resume, job application">

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="icon" href="/icon.png" type="image/png">

  <style>
    body { font-family: 'Inter', sans-serif; overflow-x: hidden; }
  </style>
</head>

<body class="bg-white">

  <!-- ============================================ -->
  <!-- NAVBAR                                       -->
  <!-- ============================================ -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-transparent transition-all duration-300" data-controller="navbar-scroll mobile-menu">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16 sm:h-20">
        <!-- Logo -->
        <a href="#" class="flex items-center space-x-2">
          <div class="w-9 h-9 bg-gradient-to-br from-blue-600 to-purple-600 rounded-xl flex items-center justify-center shadow-lg">
            <span class="text-white font-bold text-lg">R</span>
          </div>
          <span class="text-xl font-bold text-gray-900">ReZum</span>
        </a>

        <!-- Desktop Links -->
        <div class="hidden md:flex items-center space-x-8">
          <a href="#features" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Features</a>
          <a href="#how-it-works" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">How It Works</a>
          <a href="#pricing" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Pricing</a>
          <a href="#faq" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">FAQ</a>
        </div>

        <!-- Auth Buttons -->
        <div class="hidden md:flex items-center space-x-3">
          <%= link_to "Sign In", new_user_session_path, class: "text-sm font-medium text-gray-700 hover:text-gray-900 px-4 py-2 transition-colors" %>
          <%= link_to new_user_registration_path, class: "text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 px-5 py-2.5 rounded-xl shadow-md hover:shadow-lg transition-all" do %>
            Get Started Free
          <% end %>
        </div>

        <!-- Mobile Hamburger -->
        <button type="button" data-action="click->mobile-menu#toggle" class="md:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100">
          <svg data-mobile-menu-target="openIcon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg data-mobile-menu-target="closeIcon" class="hidden w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div data-mobile-menu-target="menu" class="hidden md:hidden bg-white border-t border-gray-100 shadow-lg">
      <div class="px-4 py-4 space-y-2">
        <a href="#features" class="block px-4 py-2.5 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50">Features</a>
        <a href="#how-it-works" class="block px-4 py-2.5 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50">How It Works</a>
        <a href="#pricing" class="block px-4 py-2.5 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50">Pricing</a>
        <a href="#faq" class="block px-4 py-2.5 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50">FAQ</a>
        <div class="pt-3 border-t border-gray-100 space-y-2">
          <%= link_to "Sign In", new_user_session_path, class: "block px-4 py-2.5 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50" %>
          <%= link_to "Get Started Free", new_user_registration_path, class: "block px-4 py-2.5 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-purple-600 text-center" %>
        </div>
      </div>
    </div>
  </nav>


  <!-- ============================================ -->
  <!-- HERO                                         -->
  <!-- ============================================ -->
  <section class="relative pt-28 sm:pt-36 pb-20 sm:pb-28 overflow-hidden">
    <!-- Background Blobs -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-blue-100 rounded-full opacity-40 blur-3xl blob-animate"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-purple-100 rounded-full opacity-40 blur-3xl blob-animate" style="animation-delay: -4s;"></div>
      <div class="absolute top-1/2 left-1/2 w-64 h-64 bg-pink-100 rounded-full opacity-30 blur-3xl blob-animate" style="animation-delay: -8s;"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left: Copy -->
        <div>
          <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-gradient-to-r from-blue-50 to-purple-50 border border-blue-100/60 mb-6 shadow-sm">
            <span class="w-2 h-2 bg-green-400 rounded-full mr-2 animate-pulse"></span>
            <span class="text-xs font-semibold bg-gradient-to-r from-blue-700 to-purple-700 bg-clip-text text-transparent">AI-Powered Career Tools</span>
            <span class="mx-2 text-gray-300">|</span>
            <span class="text-xs font-medium text-gray-500">Free to start</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 leading-tight tracking-tight">
            Land interviews with
            <span class="gradient-text">AI-optimized</span>
            resumes
          </h1>

          <p class="mt-6 text-lg sm:text-xl text-gray-600 leading-relaxed max-w-lg">
            Upload your resume, paste a job description, and get an ATS-optimized version with a tailored cover letter in under 30 seconds.
          </p>

          <div class="mt-8 flex flex-col sm:flex-row gap-4">
            <%= link_to new_user_registration_path, class: "inline-flex items-center justify-center px-7 py-3.5 text-base font-semibold text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 rounded-xl shadow-lg hover:shadow-xl transition-all" do %>
              Get Started Free
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            <% end %>
            <a href="#how-it-works" class="inline-flex items-center justify-center px-7 py-3.5 text-base font-semibold text-gray-700 bg-white border border-gray-200 hover:border-gray-300 hover:bg-gray-50 rounded-xl transition-all">
              See How It Works
            </a>
          </div>

          <!-- Trust Stats -->
          <div class="mt-10 flex flex-wrap items-center gap-6 text-sm text-gray-500">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="font-medium">No credit card required</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="font-medium">3 free optimizations</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="font-medium">GPT-4 + Claude + Gemini</span>
            </div>
          </div>
        </div>

        <!-- Right: Mock UI -->
        <div class="relative hero-float hidden lg:block">
          <div class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-6 max-w-md ml-auto">
            <!-- Mock Header -->
            <div class="flex items-center justify-between mb-5">
              <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold">ATS Score</p>
                <p class="text-3xl font-bold text-green-600 mt-1">89%</p>
              </div>
              <div class="w-16 h-16 relative">
                <svg class="w-16 h-16 -rotate-90" viewBox="0 0 36 36">
                  <path class="text-gray-100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="currentColor" stroke-width="3"/>
                  <path class="text-green-500" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="currentColor" stroke-width="3" stroke-dasharray="89, 100" stroke-linecap="round"/>
                </svg>
              </div>
            </div>

            <!-- Mock Keywords -->
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Matched Keywords</p>
            <div class="flex flex-wrap gap-1.5 mb-5">
              <span class="px-2 py-0.5 bg-green-50 text-green-700 text-xs font-medium rounded-md">React.js</span>
              <span class="px-2 py-0.5 bg-green-50 text-green-700 text-xs font-medium rounded-md">TypeScript</span>
              <span class="px-2 py-0.5 bg-green-50 text-green-700 text-xs font-medium rounded-md">Node.js</span>
              <span class="px-2 py-0.5 bg-green-50 text-green-700 text-xs font-medium rounded-md">AWS</span>
              <span class="px-2 py-0.5 bg-blue-50 text-blue-700 text-xs font-medium rounded-md">CI/CD</span>
              <span class="px-2 py-0.5 bg-blue-50 text-blue-700 text-xs font-medium rounded-md">Agile</span>
            </div>

            <!-- Mock Resume Preview -->
            <div class="bg-gray-50 rounded-lg p-4 space-y-2">
              <div class="h-3 bg-gray-200 rounded w-3/4"></div>
              <div class="h-2 bg-gray-200 rounded w-full"></div>
              <div class="h-2 bg-gray-200 rounded w-5/6"></div>
              <div class="h-2 bg-gray-200 rounded w-4/6"></div>
              <div class="h-3 bg-gray-200 rounded w-2/4 mt-3"></div>
              <div class="h-2 bg-gray-200 rounded w-full"></div>
              <div class="h-2 bg-gray-200 rounded w-3/4"></div>
            </div>
          </div>

          <!-- Floating Badge: Bottom Left -->
          <div class="absolute -bottom-4 -left-4 bg-white rounded-xl shadow-lg border border-gray-100 px-4 py-3 flex items-center space-x-2">
            <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center">
              <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-gray-900">Resume Optimized</p>
              <p class="text-xs text-gray-500">+47 ATS points</p>
            </div>
          </div>

          <!-- Floating Badge: Top Left -->
          <div class="absolute -top-2 -left-6 bg-white rounded-xl shadow-lg border border-gray-100 px-3.5 py-2.5 flex items-center space-x-2" style="animation: heroFloat 8s ease-in-out infinite; animation-delay: -3s;">
            <div class="w-7 h-7 rounded-full bg-purple-100 flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-gray-900">Cover Letter</p>
              <p class="text-xs text-gray-500">Generated in 15s</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- STATS BAR                                    -->
  <!-- ============================================ -->
  <section class="py-12 bg-white border-y border-gray-100" data-controller="scroll-reveal">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center" data-scroll-reveal-target="item">
        <div>
          <p class="text-3xl sm:text-4xl font-extrabold text-gray-900">47+</p>
          <p class="text-sm text-gray-500 mt-1 font-medium">Avg ATS score boost</p>
        </div>
        <div>
          <p class="text-3xl sm:text-4xl font-extrabold text-gray-900">30s</p>
          <p class="text-sm text-gray-500 mt-1 font-medium">Average processing time</p>
        </div>
        <div>
          <p class="text-3xl sm:text-4xl font-extrabold text-gray-900">3x</p>
          <p class="text-sm text-gray-500 mt-1 font-medium">More interview callbacks</p>
        </div>
        <div>
          <p class="text-3xl sm:text-4xl font-extrabold text-gray-900">95%</p>
          <p class="text-sm text-gray-500 mt-1 font-medium">User satisfaction rate</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- SOCIAL PROOF                                 -->
  <!-- ============================================ -->
  <section class="py-10 bg-gray-50 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-center text-xs font-semibold text-gray-400 uppercase tracking-wider mb-6">Trusted by professionals at leading companies</p>
      <div class="flex flex-wrap justify-center items-center gap-x-14 gap-y-6">
        <span class="text-xl font-bold text-gray-300 tracking-tight hover:text-gray-400 transition-colors">Google</span>
        <span class="text-xl font-bold text-gray-300 tracking-tight hover:text-gray-400 transition-colors">Microsoft</span>
        <span class="text-xl font-bold text-gray-300 tracking-tight hover:text-gray-400 transition-colors">Amazon</span>
        <span class="text-xl font-bold text-gray-300 tracking-tight hover:text-gray-400 transition-colors">Meta</span>
        <span class="text-xl font-bold text-gray-300 tracking-tight hover:text-gray-400 transition-colors">Deloitte</span>
        <span class="text-xl font-bold text-gray-300 tracking-tight hover:text-gray-400 transition-colors">PwC</span>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- HOW IT WORKS                                 -->
  <!-- ============================================ -->
  <section id="how-it-works" class="py-20 sm:py-28" data-controller="scroll-reveal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-scroll-reveal-target="item">
        <p class="text-sm font-semibold text-blue-600 uppercase tracking-wider mb-3">How It Works</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Three steps to your dream job</h2>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">No complicated setup. Upload, optimize, and start applying with confidence.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
        <!-- Step 1 -->
        <div class="relative text-center" data-scroll-reveal-target="item">
          <div class="w-14 h-14 rounded-2xl bg-blue-100 flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
            </svg>
          </div>
          <span class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-2 text-xs font-bold text-blue-600 bg-blue-50 px-2.5 py-0.5 rounded-full">1</span>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Upload Your Resume</h3>
          <p class="text-gray-600">Upload your existing resume as PDF, DOCX, or paste the text directly. Add the job posting URL or description.</p>
          <!-- Connector (hidden on mobile) -->
          <div class="hidden md:block absolute top-7 left-full w-full h-px border-t-2 border-dashed border-gray-200 -translate-x-1/2"></div>
        </div>

        <!-- Step 2 -->
        <div class="relative text-center" data-scroll-reveal-target="item">
          <div class="w-14 h-14 rounded-2xl bg-purple-100 flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <span class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-2 text-xs font-bold text-purple-600 bg-purple-50 px-2.5 py-0.5 rounded-full">2</span>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">AI Optimizes It</h3>
          <p class="text-gray-600">Our AI analyzes the job requirements, optimizes your resume for ATS systems, and generates a matching cover letter.</p>
          <div class="hidden md:block absolute top-7 left-full w-full h-px border-t-2 border-dashed border-gray-200 -translate-x-1/2"></div>
        </div>

        <!-- Step 3 -->
        <div class="relative text-center" data-scroll-reveal-target="item">
          <div class="w-14 h-14 rounded-2xl bg-green-100 flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <span class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-2 text-xs font-bold text-green-600 bg-green-50 px-2.5 py-0.5 rounded-full">3</span>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Land the Interview</h3>
          <p class="text-gray-600">Download your polished resume and cover letter as PDF or DOCX, apply with confidence, and get more callbacks.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- FEATURES                                     -->
  <!-- ============================================ -->
  <section id="features" class="py-20 sm:py-28 bg-gray-50" data-controller="scroll-reveal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-scroll-reveal-target="item">
        <p class="text-sm font-semibold text-blue-600 uppercase tracking-wider mb-3">Features</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">Everything you need to land the job</h2>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">Powerful AI tools designed to give your application the edge it deserves.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        <!-- Feature 1: ATS Optimization -->
        <div class="bg-white rounded-2xl p-7 hover-lift border border-gray-100" data-scroll-reveal-target="item">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center mb-5 shadow-sm">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">ATS Optimization</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Get a compatibility score and optimize your resume to pass applicant tracking systems that screen 75% of applications.</p>
        </div>

        <!-- Feature 2: AI Cover Letters -->
        <div class="bg-white rounded-2xl p-7 hover-lift border border-gray-100" data-scroll-reveal-target="item">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500 to-purple-600 flex items-center justify-center mb-5 shadow-sm">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">AI Cover Letters</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Generate personalized cover letters that match the job posting, with customizable tone and length. Get multiple variations instantly.</p>
        </div>

        <!-- Feature 3: Smart Keywords -->
