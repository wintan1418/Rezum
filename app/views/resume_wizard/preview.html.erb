<div class="min-h-screen bg-gray-50">
  <main class="max-w-4xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Your Resume is Ready!</h1>
        <p class="mt-1 text-sm text-gray-500">
          <% if @unlocked %>
            Your AI-generated resume for <strong><%= @resume.target_role %></strong>
          <% else %>
            Preview your AI-generated resume below
          <% end %>
        </p>
      </div>
      <% if @unlocked %>
        <div class="mt-4 sm:mt-0 flex items-center gap-3">
          <%= link_to edit_resume_builder_path(@resume), class: "inline-flex items-center px-4 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-200 hover:bg-gray-50 rounded-xl transition-colors" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            Edit in Builder
          <% end %>
          <%= link_to download_resume_path(@resume), class: "inline-flex items-center px-4 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 rounded-xl shadow-sm transition-all" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            Download
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Resume Preview -->
    <div class="relative">
      <% if @unlocked %>
        <!-- Full Preview — Unlocked -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-10">
          <%= raw @preview_html %>
        </div>
      <% else %>
        <!-- Blurred Preview — Locked -->
        <div class="relative rounded-2xl overflow-hidden">
          <div class="bg-white p-6 sm:p-10 select-none pointer-events-none" style="filter: blur(4px); -webkit-filter: blur(4px);">
            <%= raw @preview_html %>
          </div>

          <!-- Upsell Overlay -->
          <div class="absolute inset-0 bg-gradient-to-b from-white/40 via-white/80 to-white/95 flex items-center justify-center">
            <div class="text-center px-6 max-w-md">
              <!-- Checkmark -->
              <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-5">
                <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
              </div>

              <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mb-2">Your resume looks great!</h2>
              <p class="text-gray-500 text-sm mb-6">Unlock to download, edit, and keep it forever.</p>

              <!-- Perks -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-6 text-left">
                <div class="flex items-center gap-2.5 bg-white/80 rounded-lg px-3 py-2.5 border border-gray-100">
                  <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-sm text-gray-700">Full resume preview</span>
                </div>
                <div class="flex items-center gap-2.5 bg-white/80 rounded-lg px-3 py-2.5 border border-gray-100">
                  <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-sm text-gray-700">PDF & DOCX download</span>
                </div>
                <div class="flex items-center gap-2.5 bg-white/80 rounded-lg px-3 py-2.5 border border-gray-100">
                  <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-sm text-gray-700">Edit in resume builder</span>
                </div>
                <div class="flex items-center gap-2.5 bg-white/80 rounded-lg px-3 py-2.5 border border-gray-100">
                  <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-sm text-gray-700">Kept permanently</span>
                </div>
              </div>

              <!-- CTAs -->
              <div class="space-y-3">
                <!-- Unlock with Credits -->
                <%= link_to unlock_resume_wizard_path(@resume), data: { turbo_method: :post, turbo_confirm: "Use 10 credits to unlock this resume?" }, class: "w-full inline-flex justify-center items-center px-6 py-3.5 text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 rounded-xl shadow-sm transition-all" do %>
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z"/>
                  </svg>
                  Unlock with 10 Credits
                  <span class="ml-2 text-xs opacity-75">(You have <%= current_user.credits_remaining %>)</span>
                <% end %>

                <!-- Upgrade to Premium -->
                <%= link_to new_subscription_path, class: "w-full inline-flex justify-center items-center px-6 py-3 text-sm font-medium text-purple-700 bg-purple-50 border border-purple-200 hover:bg-purple-100 rounded-xl transition-colors" do %>
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                  </svg>
                  Upgrade to Premium — Unlimited Free
                <% end %>

                <!-- Buy Credits -->
                <% if current_user.credits_remaining < 10 %>
                  <%= link_to billing_index_path, class: "w-full inline-flex justify-center items-center px-6 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors" do %>
                    Need more credits? Buy a credit pack
                  <% end %>
                <% end %>
              </div>

              <% if @resume.expires_at.present? %>
                <div class="mt-4 px-3 py-2 bg-amber-50 border border-amber-200 rounded-lg">
                  <p class="text-xs font-medium text-amber-700">
                    <svg class="w-3.5 h-3.5 inline mr-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
                    This resume will be deleted in <strong><%= distance_of_time_in_words_to_now(@resume.expires_at) %></strong>. Unlock to keep it permanently.
                  </p>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Back link -->
    <div class="mt-6 text-center">
      <%= link_to resumes_path, class: "text-sm text-gray-500 hover:text-gray-700 font-medium" do %>
        &larr; Back to My Resumes
      <% end %>
    </div>
  </main>
</div>
