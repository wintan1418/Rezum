<div class="max-w-2xl mx-auto px-4 py-6 sm:py-8" data-controller="resume-wizard" data-resume-wizard-submit-url-value="<%= resume_wizard_index_path %>">
  <!-- Header Card -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 mb-6 p-4 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <%= link_to resumes_path, class: "text-gray-400 hover:text-gray-600 transition-colors" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      <% end %>
      <img src="/icon.svg" alt="RezumFit" class="w-9 h-9 rounded-xl">
      <div>
        <h1 class="text-sm font-semibold text-gray-900">Resume Builder</h1>
        <p class="text-xs text-gray-400">AI-powered chat wizard</p>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <span class="text-xs text-gray-400" data-resume-wizard-target="progressText">0%</span>
      <div class="w-20 h-1.5 bg-gray-100 rounded-full overflow-hidden">
        <div class="h-full bg-gradient-to-r from-blue-600 to-purple-600 rounded-full transition-all duration-500" style="width: 0%" data-resume-wizard-target="progress"></div>
      </div>
    </div>
  </div>

  <!-- LinkedIn Import Option -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 mb-6 overflow-hidden" data-controller="toggle">
    <button type="button" data-action="click->toggle#toggle" class="w-full px-5 py-4 flex items-center justify-between hover:bg-gray-50 transition-colors">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg class="w-4.5 h-4.5 text-blue-600" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </div>
        <div class="text-left">
          <p class="text-sm font-semibold text-gray-900">Have a LinkedIn profile?</p>
          <p class="text-xs text-gray-500">Import your profile to skip the chat and build faster</p>
        </div>
      </div>
      <svg class="w-5 h-5 text-gray-400 transition-transform" data-toggle-target="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </button>
    <div class="hidden px-5 pb-5" data-toggle-target="content">
      <div class="bg-gray-50 rounded-xl p-3 mb-3">
        <p class="text-xs text-gray-500">Go to your LinkedIn profile &rarr; Select all (Ctrl+A) &rarr; Copy (Ctrl+C) &rarr; Paste below</p>
      </div>
      <%= form_with url: import_linkedin_resumes_path, method: :post, local: true do |f| %>
        <%= f.text_area :linkedin_text,
            rows: 6,
            class: "w-full rounded-xl border border-gray-200 bg-white shadow-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none text-sm py-2.5 px-3.5 transition-all hover:border-gray-300 text-xs",
            placeholder: "Paste your full LinkedIn profile text here..." %>
        <div class="mt-2 flex justify-end">
          <%= f.submit "Import & Build Resume",
              class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-xl shadow-sm hover:bg-blue-700 transition-all cursor-pointer",
              data: { disable_with: "Importing..." } %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Chat Container -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden" style="min-height: 500px;">
    <!-- Chat Messages -->
    <div class="px-4 sm:px-6 py-5 space-y-4 overflow-y-auto" data-resume-wizard-target="messages" style="max-height: 60vh; min-height: 350px;">
      <!-- Messages added dynamically by Stimulus -->
    </div>

    <!-- Input Area -->
    <div class="border-t border-gray-100 bg-gray-50 px-4 sm:px-6 py-4" data-resume-wizard-target="inputArea">
      <!-- Input shown dynamically by Stimulus -->
    </div>
  </div>
</div>

<style>
  .animate-fade-in {
    animation: fadeIn 0.3s ease-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-shake {
    animation: shake 0.4s ease-in-out;
  }
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    75% { transform: translateX(6px); }
  }
</style>
