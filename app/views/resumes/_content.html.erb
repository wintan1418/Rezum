<div id="resume_content">
  <% if resume.processing? %>
    <!-- Processing -->
    <div class="card-paper" style="padding: 40px; text-align: center;"
         data-controller="auto-refresh"
         data-auto-refresh-url-value="<%= resume_path(resume) %>"
         data-auto-refresh-interval-value="3000">
      <span class="font-mono-label" style="color: var(--accent);">Optimizing</span>
      <p class="font-display" style="font-size: 24px; margin-top: 12px;">
        Rewriting your resume <em>against the job.</em>
      </p>
      <p style="color: var(--muted); font-size: 14px; margin-top: 12px;">
        Keyword integration, achievement bullets, and a fact-check pass. Usually 30–60 seconds — this page updates itself.
      </p>
      <div style="margin: 24px auto 0; width: 160px; height: 2px; background: var(--paper-2); overflow: hidden; border-radius: 999px;">
        <div style="width: 40%; height: 100%; background: var(--accent); animation: tailor-slide 1.2s ease-in-out infinite alternate;"></div>
      </div>
      <style>@keyframes tailor-slide { from { transform: translateX(-40px); } to { transform: translateX(160px); } }</style>
    </div>

  <% elsif resume.failed? %>
    <!-- Failed -->
    <div class="card-paper" style="padding: 32px; border-left: 3px solid var(--accent);">
      <span class="font-mono-label">Optimization failed</span>
      <p style="font-size: 15px; margin: 10px 0 18px; color: var(--graphite);">
        Something went wrong while optimizing. Your original resume is untouched — try again.
      </p>
      <%= button_to "Try again", optimize_resume_path(resume), method: :post, class: "btn-ink" %>
    </div>

  <% elsif resume.optimized? && resume.optimized_content.present? %>
    <!-- Before/After -->
    <div class="card-paper" data-controller="view-toggle" style="background: #FBFBFC;">
      <div style="padding: 18px 24px; display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; border-bottom: 1px solid color-mix(in oklab, var(--ink) 10%, transparent);">
        <span class="font-mono-label">Before & after</span>
        <div style="display: inline-flex; border: 1px solid color-mix(in oklab, var(--ink) 15%, transparent); border-radius: 999px; padding: 3px;">
          <button type="button" data-view-toggle-target="button" data-mode="side-by-side" data-action="click->view-toggle#switch"
                  class="bg-blue-600 text-white" style="padding: 6px 14px; font-size: 12px; border-radius: 999px; border: none; cursor: pointer;">Side by side</button>
          <button type="button" data-view-toggle-target="button" data-mode="full-width" data-action="click->view-toggle#switch"
                  class="bg-white text-gray-700" style="padding: 6px 14px; font-size: 12px; border-radius: 999px; border: none; cursor: pointer;">Optimized only</button>
          <button type="button" data-view-toggle-target="button" data-mode="diff" data-action="click->view-toggle#switch"
                  class="bg-white text-gray-700" style="padding: 6px 14px; font-size: 12px; border-radius: 999px; border: none; cursor: pointer;">Changes</button>
        </div>
      </div>

      <div style="padding: 24px;">
        <!-- Side by side -->
        <div data-view-toggle-target="view" data-mode="side-by-side" class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div>
            <span class="font-mono-label">Original</span>
            <div style="margin-top: 10px; font-size: 13px; line-height: 1.6; color: var(--muted); white-space: pre-wrap; max-height: 560px; overflow-y: auto;"><%= resume.original_content %></div>
          </div>
          <div style="border-left: 2px solid var(--accent); padding-left: 20px;">
            <span class="font-mono-label" style="color: var(--accent);">Optimized</span>
            <div style="margin-top: 10px; font-size: 14px; line-height: 1.65; color: var(--ink); white-space: pre-wrap; max-height: 560px; overflow-y: auto;"><%= resume.optimized_content %></div>
          </div>
        </div>

        <!-- Optimized only -->
        <div data-view-toggle-target="view" data-mode="full-width" class="hidden">
          <div style="font-size: 15px; line-height: 1.7; white-space: pre-wrap;"><%= resume.optimized_content %></div>
          <details style="margin-top: 24px;">
            <summary class="font-mono-label" style="cursor: pointer;">Show original</summary>
            <div style="margin-top: 12px; font-size: 13px; line-height: 1.6; color: var(--muted); white-space: pre-wrap;"><%= resume.original_content %></div>
          </details>
        </div>

        <!-- Diff -->
        <div data-view-toggle-target="view" data-mode="diff" class="hidden">
          <div style="display: flex; gap: 16px; margin-bottom: 14px;" class="font-mono-label">
            <span style="color: #067647;">■ Added</span>
            <span style="color: #B42318;">■ Removed</span>
            <span>■ Unchanged</span>
          </div>
          <div class="font-mono text-xs" style="line-height: 1.6; max-height: 640px; overflow-y: auto;">
            <%= raw @diff_html %>
          </div>
        </div>
      </div>
    </div>

  <% else %>
    <!-- Not yet optimized -->
    <div class="card-ink" style="padding: 28px; margin-bottom: 24px;">
      <span class="font-mono-label" style="color: var(--accent-soft);">Next step</span>
      <p class="font-display" style="font-size: 22px; margin-top: 8px; color: var(--paper);">
        <% if resume.job_description.blank? %>
          Add the job description, <em style="color: var(--accent-soft);">then optimize.</em>
        <% else %>
          Ready to <em style="color: var(--accent-soft);">optimize.</em>
        <% end %>
      </p>
      <p style="font-size: 14px; margin-top: 10px; color: color-mix(in oklab, var(--paper) 75%, transparent);">
        <% if resume.job_description.blank? %>
          We tailor every bullet to the posting, score it against ATS criteria, and show you exactly what changed.
        <% else %>
          You'll get tailored bullets, an ATS score, a keyword gap table, and a before/after view. Uses <%= CreditPolicy::RESUME_OPTIMIZATION %> credits.
        <% end %>
      </p>
      <div style="margin-top: 18px;">
        <% if resume.job_description.blank? %>
          <%= link_to "Add job description", edit_resume_path(resume), class: "btn-accent" %>
        <% else %>
          <%= button_to "Optimize now", optimize_resume_path(resume), method: :post, class: "btn-accent" %>
        <% end %>
      </div>
    </div>

    <div class="card-paper" style="padding: 24px; background: #FBFBFC;">
      <span class="font-mono-label">Original resume</span>
      <% if resume.original_content.present? %>
        <div style="margin-top: 14px; font-size: 14px; line-height: 1.65; white-space: pre-wrap;"><%= resume.original_content %></div>
      <% else %>
        <p style="margin-top: 14px; font-size: 14px; color: var(--muted);">No content yet — upload a file or paste your resume text.</p>
      <% end %>
    </div>
  <% end %>
</div>
