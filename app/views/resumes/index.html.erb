<div class="min-h-full">
  <main class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">My Resumes</h1>
        <p class="mt-1 text-gray-500">Manage and optimize your resumes with AI</p>
      </div>
      <%= link_to new_resume_path, class: "mt-4 sm:mt-0 inline-flex items-center px-5 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 rounded-xl shadow-sm transition-all" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
        </svg>
        Upload Resume
      <% end %>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-3 gap-4 sm:gap-6 mb-8">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
        <p class="text-2xl font-bold text-gray-900"><%= @resumes.count %></p>
        <p class="text-sm text-gray-500">Total resumes</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
        <p class="text-2xl font-bold text-green-600"><%= @optimized_count %></p>
        <p class="text-sm text-gray-500">Optimized</p>
      </div>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
        <p class="text-2xl font-bold text-blue-600">
          <% if @total_ats_score %><%= @total_ats_score %>%<% else %>--<% end %>
        </p>
        <p class="text-sm text-gray-500">Avg ATS score</p>
      </div>
    </div>

    <% if @resumes.any? %>
      <!-- Filter Bar -->
      <div class="flex items-center gap-2 mb-6" data-controller="filter">
        <button data-action="click->filter#filter" data-filter-target="button" data-status="all" class="px-3.5 py-1.5 rounded-lg text-sm font-medium bg-blue-600 text-white transition-colors">All</button>
        <button data-action="click->filter#filter" data-filter-target="button" data-status="draft" class="px-3.5 py-1.5 rounded-lg text-sm font-medium bg-white text-gray-700 hover:bg-gray-50 border border-gray-200 transition-colors">Draft</button>
        <button data-action="click->filter#filter" data-filter-target="button" data-status="optimized" class="px-3.5 py-1.5 rounded-lg text-sm font-medium bg-white text-gray-700 hover:bg-gray-50 border border-gray-200 transition-colors">Optimized</button>
        <button data-action="click->filter#filter" data-filter-target="button" data-status="processing" class="px-3.5 py-1.5 rounded-lg text-sm font-medium bg-white text-gray-700 hover:bg-gray-50 border border-gray-200 transition-colors">Processing</button>

        <!-- Card Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mt-4 w-full col-span-full">
          <% @resumes.each do |resume| %>
            <div data-filter-target="card" data-status="<%= resume.status %>" class="bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-gray-200 transition-all group">
              <div class="p-5">
                <!-- Header -->
                <div class="flex items-start justify-between mb-3">
                  <div class="flex items-center space-x-3 min-w-0">
                    <div class="w-10 h-10 rounded-lg flex-shrink-0 flex items-center justify-center
                      <%= resume.optimized? ? 'bg-green-50' : 'bg-blue-50' %>">
                      <svg class="w-5 h-5 <%= resume.optimized? ? 'text-green-600' : 'text-blue-600' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                      </svg>
                    </div>
                    <div class="min-w-0">
                      <p class="text-sm font-semibold text-gray-900 truncate"><%= resume.target_role || "Resume" %></p>
                      <p class="text-xs text-gray-500"><%= time_ago_in_words(resume.created_at) %> ago</p>
                    </div>
                  </div>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium flex-shrink-0
                    <%= case resume.status
                        when 'draft' then 'bg-gray-100 text-gray-700'
                        when 'processing' then 'bg-yellow-100 text-yellow-700'
                        when 'optimized' then 'bg-green-100 text-green-700'
                        when 'failed' then 'bg-red-100 text-red-700'
                        else 'bg-gray-100 text-gray-700'
                        end %>">
                    <%= resume.status.humanize %>
                  </span>
                </div>

                <!-- Meta -->
                <div class="flex items-center gap-4 text-xs text-gray-500 mb-4">
                  <% if resume.industry.present? %>
                    <span><%= resume.industry.humanize %></span>
                  <% end %>
                  <% if resume.cover_letters.any? %>
                    <span><%= resume.cover_letters.size %> cover letter<%= resume.cover_letters.size == 1 ? '' : 's' %></span>
                  <% end %>
                </div>

                <!-- ATS Score -->
                <% if resume.ats_score.present? %>
                  <div class="mb-4">
                    <div class="flex items-center justify-between text-xs mb-1">
                      <span class="text-gray-500">ATS Score</span>
                      <span class="font-semibold <%= case resume.ats_score_color
                          when 'green' then 'text-green-600'
                          when 'yellow' then 'text-yellow-600'
                          when 'red' then 'text-red-600'
                          else 'text-gray-600' end %>"><%= resume.ats_score %>%</span>
                    </div>
                    <div class="bg-gray-100 rounded-full h-1.5">
                      <div class="h-1.5 rounded-full transition-all <%= case resume.ats_score_color
                          when 'green' then 'bg-green-500'
                          when 'yellow' then 'bg-yellow-500'
                          when 'red' then 'bg-red-500'
                          else 'bg-gray-400' end %>" style="width: <%= resume.ats_score %>%"></div>
                    </div>
                  </div>
                <% end %>

                <!-- Actions -->
                <div class="flex items-center gap-2 pt-3 border-t border-gray-100">
                  <%= link_to resume_path(resume), class: "flex-1 inline-flex justify-center items-center px-3 py-1.5 text-xs font-medium text-blue-700 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors" do %>
                    View
                  <% end %>
                  <% unless resume.optimized? %>
                    <%= link_to optimize_resume_path(resume), data: { turbo_method: :post }, class: "flex-1 inline-flex justify-center items-center px-3 py-1.5 text-xs font-medium text-white bg-gradient-to-r from-green-600 to-blue-600 hover:from-green-700 hover:to-blue-700 rounded-lg transition-colors" do %>
                      Optimize
                    <% end %>
                  <% end %>
                  <%= link_to resume_path(resume), data: { turbo_method: :delete, turbo_confirm: 'Delete this resume?' }, class: "inline-flex justify-center items-center px-2 py-1.5 text-xs text-gray-400 hover:text-red-600 rounded-lg transition-colors" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <!-- Empty State -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-16 text-center">
        <div class="w-20 h-20 rounded-2xl bg-blue-50 flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">No resumes yet</h3>
        <p class="text-gray-500 mb-6 max-w-sm mx-auto">Upload your first resume and let our AI optimize it for ATS systems to increase your interview chances.</p>
        <%= link_to new_resume_path, class: "inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 rounded-xl shadow-sm transition-all" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
          </svg>
          Upload Your First Resume
        <% end %>
      </div>
    <% end %>
  </main>
</div>
