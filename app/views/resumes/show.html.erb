<div style="background: var(--paper); min-height: 100vh; color: var(--ink); font-family: 'Inter Tight', system-ui, sans-serif;">
  <main class="max-w-7xl mx-auto" style="padding: 32px 24px 64px;">

    <!-- Header -->
    <div style="padding-bottom: 28px; border-bottom: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); margin-bottom: 32px;">
      <%= link_to "← Resumes", resumes_path, class: "font-mono-label", style: "display: inline-block; margin-bottom: 10px;" %>
      <div style="display: flex; align-items: end; justify-content: space-between; gap: 24px; flex-wrap: wrap;">
        <div>
          <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
            <h1 class="font-display" style="font-size: clamp(30px, 4vw, 44px);"><%= @resume.target_role %></h1>
            <span class="font-mono-label" style="padding: 5px 12px; border-radius: 999px; <%= @resume.optimized? ? 'background: var(--accent-soft); color: var(--ink);' : 'border: 1px solid color-mix(in oklab, var(--ink) 15%, transparent);' %>">
              <%= @resume.status %>
            </span>
          </div>
          <p style="color: var(--muted); font-size: 14px; margin-top: 8px;">
            Created <%= time_ago_in_words(@resume.created_at) %> ago
            <% if @resume.industry.present? %> · <%= @resume.industry.humanize %><% end %>
            <% if @resume.file.attached? %> · <%= @resume.file.filename %><% end %>
          </p>
        </div>

        <!-- Actions: one primary, clear hierarchy -->
        <div style="display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
          <% if @resume.optimized? && @resume.job_description.present? %>
            <%= link_to "Tailoring Studio →", tailor_resume_path(@resume), class: "btn-accent" %>
          <% elsif @resume.job_description.blank? %>
            <%= link_to "Add job description", edit_resume_path(@resume), class: "btn-accent" %>
          <% elsif !@resume.processing? %>
            <%= button_to "Optimize resume", optimize_resume_path(@resume), method: :post, class: "btn-accent" %>
          <% end %>

          <%= link_to "Edit", edit_resume_path(@resume), class: "btn-outline" %>

          <% if @resume.resume_sections.visible.any? %>
            <%= link_to "Design & preview", edit_resume_builder_path(@resume), class: "btn-outline" %>
          <% end %>

          <div style="position: relative;" data-controller="dropdown">
            <button class="btn-outline" data-action="dropdown#toggle" type="button">
              Download
              <svg style="width: 12px; height: 12px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="hidden card-paper" data-dropdown-target="menu"
                 style="position: absolute; right: 0; top: calc(100% + 6px); min-width: 170px; background: #FBFBFC; z-index: 20; padding: 6px; box-shadow: 0 8px 24px color-mix(in oklab, var(--ink) 12%, transparent);">
              <% { "pdf" => "PDF", "docx" => "Word (DOCX)", "txt" => "Plain text" }.each do |fmt, label| %>
                <%= link_to label, download_resume_path(@resume, format: fmt), class: "block hover:bg-gray-100", style: "padding: 9px 12px; font-size: 14px; border-radius: 4px;" %>
              <% end %>
            </div>
          </div>

          <%= link_to "Cover letter", new_resume_cover_letter_path(@resume), class: "btn-ink" %>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main content -->
      <div class="lg:col-span-2">
        <%= turbo_stream_from "resume_#{@resume.id}" %>
        <%= render "resumes/content", resume: @resume %>
      </div>

      <!-- Sidebar -->
      <div style="display: flex; flex-direction: column; gap: 24px;">

        <!-- Score panel -->
        <% if @resume.ats_score.present? %>
          <div class="card-paper" style="padding: 24px;">
            <span class="font-mono-label">ATS analysis</span>
            <div style="display: flex; align-items: baseline; gap: 12px; margin-top: 12px;">
              <span class="font-display" style="font-size: 56px; color: <%= @resume.ats_score >= 75 ? 'var(--accent)' : 'var(--ink)' %>;"><%= @resume.ats_score %></span>
              <span style="color: var(--muted); font-size: 14px;">/ 100</span>
            </div>

            <% if @resume.keyword_match_computed? %>
              <div class="hairline" style="margin: 16px 0;"></div>
              <div style="display: flex; justify-content: space-between; font-size: 14px;">
                <span style="color: var(--muted);">Keyword match</span>
                <span style="font-weight: 500;"><%= @resume.keyword_match_rate %>%</span>
              </div>
              <div style="display: flex; justify-content: space-between; font-size: 14px; margin-top: 8px;">
                <span style="color: var(--muted);">Missing keywords</span>
                <%= link_to "#{@resume.missing_keywords.size} — fix in Studio →", tailor_resume_path(@resume), style: "color: var(--accent); font-weight: 500;" %>
              </div>
            <% end %>

            <% improvements = ats_improvements(@resume.ats_analysis) %>
            <% if improvements.any? %>
              <div class="hairline" style="margin: 16px 0;"></div>
              <span class="font-mono-label">Top improvements</span>
              <ol style="margin: 10px 0 0; padding-left: 18px; font-size: 13px; line-height: 1.6; color: var(--graphite);">
                <% improvements.each do |item| %>
                  <li style="margin-bottom: 6px;"><%= item %></li>
                <% end %>
              </ol>
            <% end %>

            <% if @resume.ats_score < 85 && !@resume.processing? %>
              <div class="hairline" style="margin: 16px 0;"></div>
              <%= button_to "Re-optimize with this feedback", optimize_resume_path(@resume), method: :post, class: "btn-ink", style: "width: 100%; justify-content: center;" %>
              <p style="font-size: 12px; color: var(--muted); margin-top: 8px; text-align: center;">Uses <%= CreditPolicy::RESUME_OPTIMIZATION %> credits · targets the weak spots above</p>
            <% end %>

            <% if @resume.ats_analysis.present? %>
              <div data-controller="toggle" style="margin-top: 16px;">
                <button type="button" class="font-mono-label" data-action="toggle#toggle" data-toggle-target="trigger"
                        data-toggle-show-text-value="+ Full analysis" data-toggle-hide-text-value="− Hide full analysis"
                        style="cursor: pointer; background: none; border: none; color: var(--accent); padding: 0;">+ Full analysis</button>
                <div class="hidden" data-toggle-target="content" style="margin-top: 12px; max-height: 320px; overflow-y: auto; font-size: 13px; line-height: 1.6; color: var(--graphite); white-space: pre-line;"><%= @resume.ats_analysis %></div>
              </div>
            <% end %>
          </div>
        <% elsif @resume.optimized? && @resume.job_description.present? && !@resume.processing? %>
          <div class="card-paper" style="padding: 24px;">
            <span class="font-mono-label">ATS analysis</span>
            <p style="font-size: 14px; color: var(--muted); margin: 10px 0 16px;">See how this resume scores against the job description.</p>
            <%= button_to "Analyze score", ats_score_resume_path(@resume), method: :post, class: "btn-accent", style: "width: 100%; justify-content: center;" %>
          </div>
        <% end %>

        <!-- Details -->
        <div class="card-paper" style="padding: 24px;">
          <span class="font-mono-label">Details</span>
          <dl style="margin-top: 14px; font-size: 14px;">
            <% {
              "Target role" => @resume.target_role,
              "Industry" => @resume.industry.presence&.humanize,
              "Experience" => @resume.experience_level.presence&.humanize,
              "Job description" => (@resume.job_description.present? ? "Added" : nil)
            }.compact.each do |label, value| %>
              <div style="display: flex; justify-content: space-between; gap: 12px; padding: 7px 0;">
                <dt style="color: var(--muted); flex-shrink: 0;"><%= label %></dt>
                <dd style="font-weight: 500; text-align: right;"><%= value %></dd>
              </div>
            <% end %>
          </dl>
          <% if @resume.job_description.blank? %>
            <p style="font-size: 13px; color: var(--muted); margin-top: 10px;">
              No job description yet — <%= link_to "add one", edit_resume_path(@resume), style: "color: var(--accent);" %> to unlock scoring and the Tailoring Studio.
            </p>
          <% end %>
        </div>

        <!-- Cover letters -->
        <div class="card-paper" style="padding: 24px;">
          <div style="display: flex; justify-content: space-between; align-items: baseline;">
            <span class="font-mono-label">Cover letters</span>
            <%= link_to "+ New", new_resume_cover_letter_path(@resume), class: "font-mono-label", style: "color: var(--accent);" %>
          </div>
          <% if @cover_letters.any? %>
            <div style="margin-top: 12px;">
              <% @cover_letters.first(3).each do |letter| %>
                <%= link_to resume_cover_letter_path(@resume, letter), class: "block hairline", style: "padding: 10px 0; font-size: 14px;" do %>
                  <div style="display: flex; justify-content: space-between; gap: 8px;">
                    <span style="font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= letter.company_name %></span>
                    <span style="color: var(--muted); flex-shrink: 0;"><%= letter.status %></span>
                  </div>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <p style="font-size: 14px; color: var(--muted); margin-top: 10px;">None yet for this resume.</p>
          <% end %>
        </div>

        <!-- Danger zone -->
        <div style="text-align: right;">
          <%= button_to "Delete resume", resume_path(@resume), method: :delete,
                form: { data: { turbo_confirm: "Delete this resume and its cover letters? This cannot be undone." } },
                class: "font-mono-label", style: "background: none; border: none; color: var(--muted); cursor: pointer; text-decoration: underline;" %>
        </div>
      </div>
    </div>
  </main>
</div>
