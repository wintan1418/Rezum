<div style="background: var(--paper); min-height: 100vh; color: var(--ink); font-family: 'Inter Tight', system-ui, sans-serif;">
  <main class="max-w-4xl mx-auto" style="padding: 32px 24px 64px;">

    <!-- Header -->
    <div style="padding-bottom: 28px; border-bottom: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); margin-bottom: 32px;">
      <span class="font-mono-label">New resume</span>
      <h1 class="font-display" style="font-size: clamp(32px, 4.5vw, 48px); margin-top: 6px;">
        Start with your <em>resume</em>.
      </h1>
      <p style="color: var(--muted); font-size: 15px; margin-top: 8px;">
        Upload a file, paste the text, or pull it straight from LinkedIn — we'll take it from there.
      </p>
    </div>

    <!-- Errors -->
    <% if @resume.errors.any? %>
      <div class="card-paper" style="border-left: 3px solid var(--accent); padding: 18px 22px; margin-bottom: 28px;">
        <span class="font-mono-label" style="color: var(--accent);">Please fix the following</span>
        <ul style="margin-top: 8px; font-size: 14px; line-height: 1.7; list-style: disc; padding-left: 18px;">
          <% @resume.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="group" data-controller="tabs">

      <!-- Tab row -->
      <div style="display: flex; gap: 28px; border-bottom: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); margin-bottom: 32px;">
        <% [["Upload a file", 0], ["Paste text", 1], ["Import from LinkedIn", 2]].each do |label, index| %>
          <button type="button"
                  class="border-b-2 border-transparent text-gray-500 cursor-pointer"
                  style="font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; background: none; padding: 0 2px 12px; margin-bottom: -1px;"
                  data-tabs-target="tab"
                  data-index="<%= index %>"
                  data-action="tabs#switch"><%= label %></button>
        <% end %>
      </div>

      <!-- MAIN form: upload / paste + details + job description -->
      <%= form_with model: @resume, local: true, html: { multipart: true, data: { controller: "file-upload" } } do |f| %>

        <!-- Panel 0: Upload -->
        <div data-tabs-target="panel">
          <div class="transition-colors [&.dragover]:bg-[var(--accent-soft)]"
               style="border: 2px dashed color-mix(in oklab, var(--ink) 22%, transparent); border-radius: 8px; padding: 44px 24px; text-align: center; cursor: pointer;"
               data-file-upload-target="dropzone"
               data-action="dragover->file-upload#handleDragOver dragenter->file-upload#handleDragEnter dragleave->file-upload#handleDragLeave drop->file-upload#handleDrop click->file-upload#openFileDialog">
            <p class="font-display" style="font-size: 22px;">Drop your resume here</p>
            <p style="color: var(--muted); font-size: 14px; margin-top: 6px;">
              or <span style="color: var(--accent); font-weight: 500;">click to browse</span>
            </p>
            <p class="font-mono-label" style="margin-top: 16px;">PDF · DOCX · DOC · TXT — up to 10MB</p>

            <%= f.file_field :file,
                id: "resume_file",
                accept: ".pdf,.docx,.doc,.txt",
                class: "hidden",
                data: { file_upload_target: "fileInput", action: "change->file-upload#handleFileSelect" } %>

            <!-- File preview -->
            <div class="hidden" style="margin: 24px auto 0; max-width: 420px; text-align: left; background: var(--accent-soft); border-radius: 6px; padding: 12px 16px;" data-file-upload-target="filePreview">
              <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px;">
                <div style="min-width: 0;">
                  <p style="font-size: 14px; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" data-file-upload-target="fileName"></p>
                  <p class="font-mono-label" data-file-upload-target="fileSize"></p>
                </div>
                <button type="button" style="color: var(--muted); background: none; border: none; cursor: pointer; flex-shrink: 0; font-size: 18px; line-height: 1;" aria-label="Remove file" data-action="click->file-upload#removeFile">&times;</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Panel 1: Paste text -->
        <div class="hidden" data-tabs-target="panel">
          <%= f.text_area :original_content,
              rows: 12,
              class: "input-ink",
              placeholder: "Paste your full resume text here — summary, experience, education, skills." %>
        </div>

        <!-- Shared: details + job description + submit (hidden on the LinkedIn tab) -->
        <div class="group-has-[.li-panel:not(.hidden)]:hidden">

          <!-- Details -->
          <div style="margin-top: 40px;">
            <span class="font-mono-label">Details</span>
            <div class="grid grid-cols-1 sm:grid-cols-2" style="gap: 16px; margin-top: 14px;">
              <div class="sm:col-span-2">
                <%= f.label :target_role, "Target role", class: "font-mono-label", style: "display: block; margin-bottom: 6px;" %>
                <%= f.text_field :target_role, required: true, class: "input-ink", placeholder: "e.g. Software Engineer, Product Manager" %>
              </div>
              <div>
                <%= f.label :industry, "Industry", class: "font-mono-label", style: "display: block; margin-bottom: 6px;" %>
                <%= f.select :industry,
                    options_for_select([
                      ["Technology", "technology"], ["Healthcare", "healthcare"], ["Finance", "finance"],
                      ["Education", "education"], ["Manufacturing", "manufacturing"], ["Retail", "retail"],
                      ["Consulting", "consulting"], ["Government", "government"], ["Non-profit", "nonprofit"], ["Other", "other"]
                    ]),
                    { prompt: "Select industry (optional)" },
                    { class: "input-ink" } %>
              </div>
              <div>
                <%= f.label :experience_level, "Experience level", class: "font-mono-label", style: "display: block; margin-bottom: 6px;" %>
                <%= f.select :experience_level,
                    options_for_select([
                      ["Entry Level (0-2 years)", "entry"], ["Mid Level (3-5 years)", "mid"],
                      ["Senior Level (6-10 years)", "senior"], ["Executive Level (10+ years)", "executive"]
                    ]),
                    { prompt: "Select experience level (optional)" },
                    { class: "input-ink" } %>
              </div>
            </div>
          </div>

          <!-- Target job description (collapsed by default) -->
          <div data-controller="toggle" style="margin-top: 36px;">
            <button type="button" class="font-mono-label" style="color: var(--accent); background: none; border: none; padding: 0; cursor: pointer;" data-action="click->toggle#toggle">
              + Add job description (recommended)
            </button>
            <div class="hidden" data-toggle-target="content" data-controller="job-url-fetcher" style="margin-top: 16px;">
              <p style="color: var(--muted); font-size: 14px; margin-bottom: 14px;">We tailor and score against it.</p>

              <div style="display: flex; gap: 10px;">
                <input type="url"
                       class="input-ink"
                       style="flex: 1;"
                       placeholder="https://jobs.company.com/posting"
                       data-job-url-fetcher-target="urlInput">
                <button type="button" class="btn-outline" style="flex-shrink: 0;" data-action="click->job-url-fetcher#fetchJob" data-job-url-fetcher-target="fetchButton">
                  <span class="hidden" data-job-url-fetcher-target="spinner">
                    <svg class="animate-spin" style="width: 14px; height: 14px;" fill="none" viewBox="0 0 24 24"><circle style="opacity: 0.25;" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path style="opacity: 0.75;" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                  </span>
                  <span data-job-url-fetcher-target="buttonText">Fetch</span>
                </button>
              </div>

              <div class="hidden" style="margin-top: 12px; font-size: 13px; color: var(--accent);" data-job-url-fetcher-target="successMessage">
                Fetched. <span data-job-url-fetcher-target="fetchedInfo"></span>
              </div>
              <div class="hidden" style="margin-top: 12px; font-size: 13px; color: #B42318;" data-job-url-fetcher-target="errorMessage">
                Couldn't fetch that posting. <span data-job-url-fetcher-target="errorText"></span>
              </div>

              <%= f.text_area :job_description,
                  rows: 8,
                  class: "input-ink",
                  style: "margin-top: 12px;",
                  placeholder: "Or paste the job description here.",
                  data: { job_url_fetcher_target: "jobDescription" } %>
            </div>
          </div>

          <!-- Submit -->
          <div style="margin-top: 36px;">
            <%= f.submit "Upload & optimize →",
                class: "btn-accent",
                style: "width: 100%; justify-content: center;",
                data: { disable_with: "Optimizing…" } %>
            <p style="color: var(--muted); font-size: 13px; text-align: center; margin-top: 12px;">
              Processed securely — usually takes 30-60 seconds. Don't have a resume yet?
              <%= link_to "Build one from scratch", new_resume_wizard_path, style: "color: var(--accent); font-weight: 500;" %>
            </p>
          </div>
        </div>
      <% end %>

      <!-- Panel 2: LinkedIn import (SEPARATE form, never nested in the main form) -->
      <div class="hidden li-panel" data-tabs-target="panel">
        <p style="color: var(--muted); font-size: 14px; margin-bottom: 18px;">
          Imports your profile and <span style="color: var(--ink); font-weight: 500;">optimizes it automatically</span> — no details form needed.
          On LinkedIn: your profile → <span style="font-weight: 500;">More</span> → <span style="font-weight: 500;">Save to PDF</span>, then upload it below.
        </p>

        <%= form_with url: import_linkedin_resumes_path, method: :post, local: true, multipart: true do |lf| %>
          <label class="font-mono-label" style="display: block; margin-bottom: 6px;">LinkedIn PDF</label>
          <%= lf.file_field :linkedin_pdf, accept: ".pdf", class: "input-ink" %>

          <div data-controller="toggle" style="margin-top: 18px;">
            <button type="button" class="font-mono-label" style="color: var(--accent); background: none; border: none; padding: 0; cursor: pointer;" data-action="click->toggle#toggle">
              + Don't have the PDF? Paste your profile text instead
            </button>
            <div class="hidden" data-toggle-target="content" style="margin-top: 12px;">
              <%= lf.text_area :linkedin_text,
                  rows: 6,
                  class: "input-ink",
                  placeholder: "On your LinkedIn profile: select all, copy, and paste here." %>
            </div>
          </div>

          <div style="margin-top: 28px;">
            <%= lf.submit "Import & optimize →",
                class: "btn-ink",
                style: "width: 100%; justify-content: center;",
                data: { disable_with: "Importing…" } %>
            <p style="color: var(--muted); font-size: 13px; text-align: center; margin-top: 12px;">
              We parse your profile, build the resume, and run optimization in one step.
            </p>
          </div>
        <% end %>
      </div>
    </div>
  </main>
</div>
