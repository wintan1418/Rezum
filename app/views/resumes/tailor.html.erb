<div style="background: var(--paper); min-height: 100vh; color: var(--ink); font-family: 'Inter Tight', system-ui, sans-serif;">
  <main class="max-w-7xl mx-auto" style="padding: 32px 24px 64px;"
        data-controller="tailor-studio"
        data-tailor-studio-suggest-url-value="<%= suggest_bullets_resume_path(@resume) %>"
        data-tailor-studio-apply-url-value="<%= apply_bullet_resume_path(@resume) %>">

    <!-- Header -->
    <div style="display: flex; align-items: end; justify-content: space-between; gap: 24px; flex-wrap: wrap; padding-bottom: 28px; border-bottom: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); margin-bottom: 36px;">
      <div>
        <%= link_to "← Back to resume", resume_path(@resume), class: "font-mono-label", style: "display: inline-block; margin-bottom: 10px;" %>
        <h1 class="font-display" style="font-size: clamp(32px, 4.5vw, 48px);">
          Tailoring <em>Studio</em>
        </h1>
        <p style="color: var(--muted); font-size: 15px; margin-top: 8px;">
          <%= @resume.target_role %> — close the gaps between your resume and this job posting, one honest bullet at a time.
        </p>
      </div>
      <div style="display: flex; gap: 32px; align-items: end; flex-shrink: 0;">
        <div>
          <span class="font-mono-label">Keyword match</span>
          <div class="font-display" style="font-size: 44px; color: var(--accent);" data-tailor-studio-target="rate"><%= @resume.keyword_match_computed? ? "#{@resume.keyword_match_rate}%" : "—" %></div>
        </div>
        <% if @resume.ats_score.present? %>
          <div>
            <span class="font-mono-label">ATS score</span>
            <div class="font-display" style="font-size: 44px;"><%= @resume.ats_score %></div>
          </div>
        <% end %>
      </div>
    </div>

    <% if @resume.keyword_match_computed? %>
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">

        <!-- Gap table -->
        <div class="lg:col-span-2">
          <div class="card-paper" style="padding: 24px;">
            <div style="display: flex; justify-content: space-between; align-items: baseline;">
              <span class="font-mono-label">Missing from your resume</span>
              <span class="font-mono-label" style="color: var(--accent);" data-tailor-studio-target="missingCount"><%= @resume.missing_keywords.size %></span>
            </div>
            <p style="font-size: 13px; color: var(--muted); margin: 8px 0 16px;">
              Click a keyword to get bullet suggestions grounded in your real experience.
            </p>
            <div data-tailor-studio-target="missingList">
              <% if @resume.missing_keywords.any? %>
                <% @resume.missing_keywords.each do |entry| %>
                  <button class="tailor-chip"
                          style="display: inline-flex; align-items: center; gap: 6px; padding: 7px 14px; margin: 0 8px 8px 0; background: var(--accent-soft); color: var(--ink); border: 1px solid transparent; border-radius: 999px; font-size: 13px; cursor: pointer;"
                          data-keyword="<%= entry['term'] %>"
                          data-action="tailor-studio#selectKeyword"><%= entry["term"] %></button>
                <% end %>
              <% else %>
                <p style="font-size: 14px; color: var(--muted);">Nothing missing — full keyword coverage.</p>
              <% end %>
            </div>

            <div class="hairline" style="margin: 20px 0;"></div>

            <div style="display: flex; justify-content: space-between; align-items: baseline;">
              <span class="font-mono-label">Already covered</span>
              <span class="font-mono-label" data-tailor-studio-target="matchedCount"><%= @resume.matched_keywords.size %></span>
            </div>
            <div style="margin-top: 14px;" data-tailor-studio-target="matchedList">
              <% @resume.matched_keywords.each do |entry| %>
                <span style="display: inline-flex; align-items: center; gap: 6px; padding: 7px 14px; margin: 0 8px 8px 0; background: transparent; border: 1px solid color-mix(in oklab, var(--ink) 15%, transparent); border-radius: 999px; font-size: 13px; color: var(--muted);"><%= entry["term"] %><%= " ×#{entry['count']}" if entry["count"].to_i > 1 %></span>
              <% end %>
            </div>
          </div>

          <p style="font-size: 12px; color: var(--muted); margin-top: 12px; line-height: 1.5;">
            Match rate is computed by exact text matching against the job description — not AI guesswork. Suggestions only claim what your resume actually supports.
          </p>
        </div>

        <!-- Suggestions + content -->
        <div class="lg:col-span-3">
          <div class="card-paper" style="padding: 24px; min-height: 180px; margin-bottom: 24px;">
            <div data-tailor-studio-target="suggestPanel">
              <div style="padding: 32px; text-align: center; color: var(--muted);">
                <span class="font-mono-label">How it works</span>
                <p style="margin-top: 12px; font-size: 15px; max-width: 400px; margin-left: auto; margin-right: auto;">
                  Pick a missing keyword on the left. We check your resume for real evidence, then draft three bullets you can add with one click — or tell you honestly when a keyword isn't yours to claim.
                </p>
              </div>
            </div>
          </div>

          <div class="card-paper" style="padding: 24px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px;">
              <span class="font-mono-label">Your resume (updates live)</span>
              <%= link_to "Re-run full analysis", ats_score_resume_path(@resume), data: { turbo_method: :post }, class: "font-mono-label", style: "color: var(--accent);" %>
            </div>
            <pre style="white-space: pre-wrap; font-family: 'Inter Tight', system-ui, sans-serif; font-size: 14px; line-height: 1.6; max-height: 480px; overflow-y: auto; margin: 0;" data-tailor-studio-target="content"><%= @resume.optimized_content %></pre>
          </div>
        </div>
      </div>
    <% else %>
      <!-- No match data yet: run analysis first -->
      <div class="card-paper" style="padding: 48px; text-align: center; max-width: 560px; margin: 0 auto;">
        <span class="font-mono-label">One step first</span>
        <h2 class="font-display" style="font-size: 28px; margin-top: 10px;">Run the ATS analysis</h2>
        <p style="color: var(--muted); font-size: 15px; margin: 14px 0 24px;">
          The studio needs the keyword gap data from your ATS analysis. It takes about 20 seconds.
        </p>
        <%= button_to "Analyze against job description", ats_score_resume_path(@resume), method: :post, class: "btn-accent", style: "margin: 0 auto;" %>
      </div>
    <% end %>
  </main>
</div>
