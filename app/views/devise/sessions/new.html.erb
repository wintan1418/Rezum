<% content_for(:page_title) { "Welcome back" } %>
<% content_for(:page_subtitle) { "Sign in to continue tailoring." } %>

<!-- Google Sign In -->
<div class="mb-6">
  <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false },
      class: "btn-outline w-full",
      style: "width: 100%; justify-content: center; padding: 14px 20px; background: #FBFBFC;" do %>
    <svg style="width: 18px; height: 18px;" viewBox="0 0 24 24">
      <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
      <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
      <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
      <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
    </svg>
    <span>Continue with Google</span>
  <% end %>
</div>

<!-- Divider -->
<div class="relative mb-6 flex items-center gap-4">
  <div style="flex:1; height:1px; background: color-mix(in oklab, var(--ink) 12%, transparent);"></div>
  <span class="font-mono-label" style="color: var(--muted); flex-shrink: 0;">Or with email</span>
  <div style="flex:1; height:1px; background: color-mix(in oklab, var(--ink) 12%, transparent);"></div>
</div>

<!-- Email / Password Form -->
<%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
  <div>
    <%= f.label :email, class: "font-mono-label", style: "display: block; margin-bottom: 8px;" %>
    <%= f.email_field :email,
        class: "auth-input",
        placeholder: "you@example.com",
        autofocus: true,
        autocomplete: "email" %>
  </div>

  <div>
    <div class="flex items-center justify-between" style="margin-bottom: 8px;">
      <%= f.label :password, class: "font-mono-label" %>
      <%= link_to "Forgot password?", new_password_path(resource_name),
          style: "font-size: 12px; color: var(--accent); text-decoration: none; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.04em;" %>
    </div>
    <%= f.password_field :password,
        class: "auth-input",
        placeholder: "Enter your password",
        autocomplete: "current-password" %>
  </div>

  <% if devise_mapping.rememberable? %>
    <label class="flex items-center gap-2" style="cursor: pointer;">
      <%= f.check_box :remember_me, style: "width: 16px; height: 16px; accent-color: var(--accent);" %>
      <span style="font-size: 14px; color: var(--ink);">Remember me</span>
    </label>
  <% end %>

  <div class="pt-2">
    <%= f.submit "Sign in",
        class: "btn-ink",
        style: "width: 100%; justify-content: center; padding: 16px 24px; font-size: 15px;" %>
  </div>
<% end %>

<% content_for(:footer_links) do %>
  <p style="text-align: center; font-size: 14px; color: var(--muted);">
    Don't have an account?
    <%= link_to "Create one", new_registration_path(resource_name),
        style: "color: var(--ink); font-weight: 500; text-decoration: none; border-bottom: 1px solid var(--ink); padding-bottom: 1px; margin-left: 4px;" %>
  </p>
<% end %>
