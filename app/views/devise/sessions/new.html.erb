<% content_for(:page_title) { "Welcome back" } %>
<% content_for(:page_subtitle) { "Sign in to your account to continue" } %>

<!-- Google Sign In -->
<div class="mb-6">
  <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false },
      class: "w-full inline-flex items-center justify-center gap-3 px-4 py-3 bg-white border border-gray-200 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 hover:border-gray-300 hover:shadow-sm transition-all cursor-pointer" do %>
    <svg class="w-5 h-5" viewBox="0 0 24 24">
      <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
      <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
      <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
      <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
    </svg>
    Continue with Google
  <% end %>
</div>

<!-- Divider -->
<div class="relative mb-6">
  <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
  <div class="relative flex justify-center text-xs">
    <span class="bg-gray-50 px-3 text-gray-400 uppercase tracking-wide font-medium">or sign in with email</span>
  </div>
</div>

<!-- Email/Password Form -->
<%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
  <div>
    <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <div class="relative">
      <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </div>
      <%= f.email_field :email,
          class: "auth-input block w-full rounded-xl border border-gray-200 shadow-sm focus:outline-none sm:text-sm py-2.5 pl-10 pr-3.5",
          placeholder: "you@example.com",
          autofocus: true,
          autocomplete: "email" %>
    </div>
  </div>

  <div>
    <div class="flex items-center justify-between mb-1.5">
      <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
      <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-sm text-blue-600 hover:text-blue-500 font-medium" %>
    </div>
    <div class="relative">
      <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
      </div>
      <%= f.password_field :password,
          class: "auth-input block w-full rounded-xl border border-gray-200 shadow-sm focus:outline-none sm:text-sm py-2.5 pl-10 pr-3.5",
          placeholder: "Enter your password",
          autocomplete: "current-password" %>
    </div>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="flex items-center">
      <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
      <span class="ml-2 text-sm text-gray-600">Remember me</span>
    </div>
  <% end %>

  <div class="pt-1">
    <%= f.submit "Sign in",
        class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-sm text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all cursor-pointer" %>
  </div>
<% end %>

<% content_for(:footer_links) do %>
  <p class="text-center text-sm text-gray-500">
    Don't have an account?
    <%= link_to "Create one", new_registration_path(resource_name), class: "font-semibold text-blue-600 hover:text-blue-500" %>
  </p>
<% end %>
