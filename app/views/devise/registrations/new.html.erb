<% content_for(:page_title) { "Create your account" } %>
<% content_for(:page_subtitle) { "Two free credits, no card required." } %>

<!-- Google Sign Up -->
<div class="mb-6">
  <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false },
      class: "btn-outline w-full",
      style: "width: 100%; justify-content: center; padding: 14px 20px; background: #FBFBFC;" do %>
    <svg style="width: 18px; height: 18px;" viewBox="0 0 24 24">
      <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
      <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
      <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
      <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
    </svg>
    <span>Continue with Google</span>
  <% end %>
</div>

<!-- Divider -->
<div class="relative mb-6 flex items-center gap-4">
  <div style="flex:1; height:1px; background: color-mix(in oklab, var(--ink) 12%, transparent);"></div>
  <span class="font-mono-label" style="color: var(--muted); flex-shrink: 0;">Or with email</span>
  <div style="flex:1; height:1px; background: color-mix(in oklab, var(--ink) 12%, transparent);"></div>
</div>

<!-- Registration Form -->
<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>

  <!-- Error Messages -->
  <% if resource.errors.any? %>
    <div style="padding: 14px 16px; border: 1px solid color-mix(in oklab, var(--ink) 30%, transparent); background: color-mix(in oklab, var(--ink) 5%, var(--paper)); border-radius: 6px;">
      <span class="font-mono-label" style="color: var(--accent);">Please fix</span>
      <ul style="margin-top: 8px; padding-left: 18px; font-size: 14px; color: var(--ink); line-height: 1.5;">
        <% resource.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Personal Info -->
  <div>
    <span class="font-mono-label" style="display: block; margin-bottom: 12px;">01 / Personal info</span>
    <div class="space-y-3">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <%= f.text_field :first_name, class: "auth-input", placeholder: "First name", autocomplete: "given-name", required: true %>
        <%= f.text_field :last_name, class: "auth-input", placeholder: "Last name", autocomplete: "family-name", required: true %>
      </div>
      <%= f.email_field :email, class: "auth-input", placeholder: "you@example.com", autofocus: true, autocomplete: "email", required: true %>
      <%= f.select :experience_level,
          options_for_select([
            ['Entry Level (0–2 years)', 'entry'],
            ['Mid Level (3–5 years)', 'mid'],
            ['Senior (6–10 years)', 'senior'],
            ['Executive (10+ years)', 'executive']
          ]),
          { prompt: "Select experience level" },
          { class: "auth-input" } %>
    </div>
  </div>

  <!-- Security -->
  <div>
    <span class="font-mono-label" style="display: block; margin-bottom: 12px;">02 / Security</span>
    <div class="space-y-3">
      <div>
        <%= f.password_field :password, class: "auth-input", placeholder: "Create a password", autocomplete: "new-password", required: true %>
        <p style="font-size: 12px; color: var(--muted); margin-top: 6px; margin-left: 2px;">Minimum 6 characters</p>
      </div>
      <%= f.password_field :password_confirmation, class: "auth-input", placeholder: "Confirm your password", autocomplete: "new-password", required: true %>
    </div>
  </div>

  <%= f.hidden_field :language, value: 'en' %>

  <!-- Terms -->
  <label class="flex items-start gap-3" style="cursor: pointer;">
    <%= check_box_tag :terms_accepted, "1", false, required: true, style: "margin-top: 2px; width: 16px; height: 16px; accent-color: var(--accent); flex-shrink: 0;" %>
    <span style="font-size: 13px; color: var(--muted); line-height: 1.5;">
      I agree to the
      <%= link_to "Terms", terms_path, target: "_blank", style: "color: var(--ink); text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 2px;" %>
      and
      <%= link_to "Privacy Policy", privacy_path, target: "_blank", style: "color: var(--ink); text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 2px;" %>
    </span>
  </label>

  <div class="pt-2">
    <%= f.submit "Create account",
        class: "btn-ink",
        style: "width: 100%; justify-content: center; padding: 16px 24px; font-size: 15px;" %>
  </div>
<% end %>

<% content_for(:footer_links) do %>
  <p style="text-align: center; font-size: 14px; color: var(--muted);">
    Already have an account?
    <%= link_to "Sign in", new_session_path(resource_name),
        style: "color: var(--ink); font-weight: 500; text-decoration: none; border-bottom: 1px solid var(--ink); padding-bottom: 1px; margin-left: 4px;" %>
  </p>
<% end %>
