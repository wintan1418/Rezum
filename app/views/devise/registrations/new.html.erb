<% content_for(:page_title) { "Create your account" } %>
<% content_for(:page_subtitle) { "Start optimizing your career with AI" } %>

<!-- Google Sign Up -->
<div class="mb-6">
  <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false },
      class: "w-full inline-flex items-center justify-center gap-3 px-4 py-3 bg-white border border-gray-200 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 hover:border-gray-300 hover:shadow-sm transition-all cursor-pointer" do %>
    <svg class="w-5 h-5" viewBox="0 0 24 24">
      <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
      <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
      <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
      <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
    </svg>
    Continue with Google
  <% end %>
</div>

<!-- Divider -->
<div class="relative mb-6">
  <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
  <div class="relative flex justify-center text-xs">
    <span class="bg-gray-50 px-3 text-gray-400 uppercase tracking-wide font-medium">or register with email</span>
  </div>
</div>

<!-- Registration Form -->
<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>

  <!-- Error Messages -->
  <% if resource.errors.any? %>
    <div class="rounded-xl bg-red-50 border border-red-200 p-4">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
        </svg>
        <ul class="text-sm text-red-700 space-y-1">
          <% resource.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <!-- Name -->
  <div class="grid grid-cols-2 gap-3">
    <div>
      <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
      <%= f.text_field :first_name,
          class: "auth-input block w-full rounded-xl border border-gray-200 shadow-sm focus:outline-none sm:text-sm py-2.5 px-3.5",
          placeholder: "First name",
          autocomplete: "given-name",
          required: true %>
    </div>
    <div>
      <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
      <%= f.text_field :last_name,
          class: "auth-input block w-full rounded-xl border border-gray-200 shadow-sm focus:outline-none sm:text-sm py-2.5 px-3.5",
          placeholder: "Last name",
          autocomplete: "family-name",
          required: true %>
    </div>
  </div>

  <!-- Email -->
  <div>
    <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <%= f.email_field :email,
        class: "auth-input block w-full rounded-xl border border-gray-200 shadow-sm focus:outline-none sm:text-sm py-2.5 px-3.5",
        placeholder: "you@example.com",
        autofocus: true,
        autocomplete: "email",
        required: true %>
  </div>

  <!-- Password -->
  <div>
    <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <%= f.password_field :password,
        class: "auth-input block w-full rounded-xl border border-gray-200 shadow-sm focus:outline-none sm:text-sm py-2.5 px-3.5",
        placeholder: "Min. 6 characters",
        autocomplete: "new-password",
        required: true %>
  </div>

  <!-- Confirm Password -->
  <div>
    <%= f.label :password_confirmation, "Confirm password", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <%= f.password_field :password_confirmation,
        class: "auth-input block w-full rounded-xl border border-gray-200 shadow-sm focus:outline-none sm:text-sm py-2.5 px-3.5",
        placeholder: "Confirm your password",
        autocomplete: "new-password",
        required: true %>
  </div>

  <!-- Experience Level -->
  <div>
    <%= f.label :experience_level, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <%= f.select :experience_level,
        options_for_select([
          ['Entry Level (0-2 years)', 'entry'],
          ['Mid Level (3-5 years)', 'mid'],
          ['Senior (6-10 years)', 'senior'],
          ['Executive (10+ years)', 'executive']
        ]),
        { prompt: "Select experience level" },
        { class: "auth-input block w-full rounded-xl border border-gray-200 shadow-sm focus:outline-none sm:text-sm py-2.5 px-3.5" } %>
  </div>

  <!-- Hidden defaults -->
  <%= f.hidden_field :language, value: 'en' %>

  <!-- Terms -->
  <div class="flex items-start gap-2.5">
    <%= check_box_tag :terms_accepted, "1", false,
        required: true,
        class: "mt-0.5 h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
    <label for="terms_accepted" class="text-sm text-gray-500 leading-tight">
      I agree to the
      <%= link_to "Terms of Service", terms_path, class: "text-blue-600 hover:text-blue-500 font-medium", target: "_blank" %>
      and
      <%= link_to "Privacy Policy", privacy_path, class: "text-blue-600 hover:text-blue-500 font-medium", target: "_blank" %>
    </label>
  </div>

  <!-- Submit -->
  <div class="pt-1">
    <%= f.submit "Create account",
        class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-sm text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all cursor-pointer" %>
  </div>
<% end %>

<% content_for(:footer_links) do %>
  <p class="text-center text-sm text-gray-500">
    Already have an account?
    <%= link_to "Sign in", new_session_path(resource_name), class: "font-semibold text-blue-600 hover:text-blue-500" %>
  </p>
<% end %>
