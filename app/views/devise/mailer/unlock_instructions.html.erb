<p style="font-size: 16px; color: #374151;">Hi <%= @resource.email %>,</p>

<p style="font-size: 14px; color: #6b7280; line-height: 1.6;">
  Your account has been locked due to an excessive number of unsuccessful sign in attempts.
</p>

<p style="font-size: 14px; color: #6b7280; line-height: 1.6;">
  Click the button below to unlock your account:
</p>

<div style="text-align: center; margin: 32px 0 16px;">
  <a href="<%= unlock_url(@resource, unlock_token: @token) %>" style="background: linear-gradient(135deg, #2563eb, #7c3aed); color: #ffffff; padding: 12px 32px; text-decoration: none; border-radius: 8px; font-size: 14px; font-weight: 600; display: inline-block;">
    Unlock My Account
  </a>
</div>
