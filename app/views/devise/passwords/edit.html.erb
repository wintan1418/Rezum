<% content_for(:page_title) { "Set new password" } %>
<% content_for(:page_subtitle) { "Choose a new password for your account" } %>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  <%= f.hidden_field :reset_password_token %>

  <div>
    <%= f.label :password, "New password", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <% if @minimum_password_length %>
      <p class="text-xs text-gray-400 mb-1"><%= @minimum_password_length %> characters minimum</p>
    <% end %>
    <%= f.password_field :password,
        class: "auth-input block w-full rounded-xl border border-gray-200 shadow-sm focus:outline-none sm:text-sm py-2.5 px-3.5",
        placeholder: "New password",
        autofocus: true,
        autocomplete: "new-password" %>
  </div>

  <div>
    <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <%= f.password_field :password_confirmation,
        class: "auth-input block w-full rounded-xl border border-gray-200 shadow-sm focus:outline-none sm:text-sm py-2.5 px-3.5",
        placeholder: "Confirm new password",
        autocomplete: "new-password" %>
  </div>

  <div class="pt-1">
    <%= f.submit "Change password",
        class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-sm text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all cursor-pointer" %>
  </div>
<% end %>

<% content_for(:footer_links) do %>
  <p class="text-center text-sm text-gray-500">
    <%= link_to "Back to sign in", new_session_path(resource_name), class: "font-semibold text-blue-600 hover:text-blue-500" %>
  </p>
<% end %>
