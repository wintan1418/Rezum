<% content_for(:page_title) { "Set new password" } %>
<% content_for(:page_subtitle) { "Choose a new password for your account" } %>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  <%= f.hidden_field :reset_password_token %>

  <div>
    <%= f.label :password, "New password", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <div class="relative">
      <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
      </div>
      <%= f.password_field :password,
          class: "auth-input block w-full rounded-xl border border-gray-200 shadow-sm focus:outline-none sm:text-sm py-2.5 pl-10 pr-3.5",
          placeholder: "New password",
          autofocus: true,
          autocomplete: "new-password" %>
    </div>
    <% if @minimum_password_length %>
      <p class="text-xs text-gray-400 mt-1.5 ml-1"><%= @minimum_password_length %> characters minimum</p>
    <% end %>
  </div>

  <div>
    <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <div class="relative">
      <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
      </div>
      <%= f.password_field :password_confirmation,
          class: "auth-input block w-full rounded-xl border border-gray-200 shadow-sm focus:outline-none sm:text-sm py-2.5 pl-10 pr-3.5",
          placeholder: "Confirm new password",
          autocomplete: "new-password" %>
    </div>
  </div>

  <div class="pt-1">
    <%= f.submit "Change password",
        class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-sm text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all cursor-pointer" %>
  </div>
<% end %>

<% content_for(:footer_links) do %>
  <p class="text-center text-sm text-gray-500">
    <%= link_to "Back to sign in", new_session_path(resource_name), class: "font-semibold text-blue-600 hover:text-blue-500" %>
  </p>
<% end %>
