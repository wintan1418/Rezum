<div style="background: var(--paper); min-height: 100vh; color: var(--ink); font-family: 'Inter Tight', system-ui, sans-serif;">
  <main class="max-w-7xl mx-auto" style="padding: 32px 24px 64px;">

    <!-- Upsell banner (kept, restyled inline below) -->
    <% unless current_user.has_active_subscription? %>
      <% if current_user.credits_remaining <= 1 %>
        <%= render "shared/upsell_banner", heading: "Running low on credits.", message: "You have #{current_user.credits_remaining} credit left. Upgrade to Pro for unlimited optimizations, cover letters, and more." %>
      <% elsif current_user.resumes.count >= 1 %>
        <%= render "shared/upsell_banner", heading: "Ready for your next interview?", message: "Unlock AI Interview Prep, LinkedIn Optimization, and the Automated Job Scraper with Premium." %>
      <% end %>
    <% end %>

    <!-- Greeting -->
    <div style="display: flex; align-items: end; justify-content: space-between; gap: 24px; padding-bottom: 32px; border-bottom: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); margin-bottom: 40px;">
      <div>
        <span class="font-mono-label">Today</span>
        <h1 class="font-display" style="font-size: clamp(36px, 5vw, 56px); margin-top: 6px; line-height: 1.05;">
          <%= time_of_day_greeting %>, <em><%= current_user.first_name %></em>.
        </h1>
        <p style="color: var(--muted); font-size: 15px; margin-top: 8px; font-family:'Fraunces',serif; font-style: italic; font-weight: 300; font-variation-settings:'opsz' 24;">
          Here's what's happening with your job search.
        </p>
      </div>
      <%= link_to new_resume_path, class: "btn-ink hidden sm:inline-flex", style: "flex-shrink: 0;" do %>
        <svg style="width: 14px; height: 14px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m6-6H6"/></svg>
        New resume
      <% end %>
    </div>

    <!-- Status banners -->
    <% if !current_user.has_active_subscription? && current_user.credits_remaining == 0 %>
      <div style="display: flex; justify-content: space-between; align-items: center; gap: 16px; padding: 20px 24px; background: var(--ink); color: var(--paper); border-radius: 6px; margin-bottom: 32px;">
        <div>
          <span class="font-mono-label" style="color: var(--accent);">Out of credits</span>
          <p style="font-family:'Fraunces',serif; font-size: 19px; font-weight: 400; letter-spacing: -0.01em; font-variation-settings:'opsz' 24; margin-top: 4px;">
            You've used your free credits. <em style="color: var(--accent); font-style: italic;">Upgrade to keep tailoring.</em>
          </p>
        </div>
        <%= link_to "Upgrade", new_subscription_path, class: "btn-accent", style: "flex-shrink: 0;" %>
      </div>
    <% elsif current_user.trial_active? %>
      <div style="display: flex; justify-content: space-between; align-items: center; gap: 16px; padding: 20px 24px; background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 14%, transparent); border-radius: 6px; margin-bottom: 32px;">
        <div>
          <span class="font-mono-label" style="color: var(--accent);">Trial active</span>
          <p style="font-family:'Fraunces',serif; font-size: 17px; font-weight: 400; margin-top: 4px;">
            Your trial ends <em style="color: var(--accent); font-style: italic;"><%= time_ago_in_words(current_user.trial_ends_at) %></em> from now.
          </p>
        </div>
        <%= link_to "View plans", new_subscription_path, class: "btn-outline", style: "flex-shrink: 0;" %>
      </div>
    <% end %>

    <!-- Stats grid — editorial 4-up -->
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 6px; overflow: hidden; margin-bottom: 56px;" class="stats-grid">
      <% stats = [
        ["Credits", current_user.has_active_subscription? ? "∞" : @credits_remaining.to_s, current_user.has_active_subscription? ? "Unlimited (subscription)" : "Remaining on your account"],
        ["Resumes", @resumes_count.to_s, "#{@optimized_count} optimized"],
        ["Cover letters", @cover_letters_count.to_s, "Drafted on RezumFit"],
        ["Avg ATS score", (@avg_ats_score ? "#{@avg_ats_score}%" : "—"), "Across optimized resumes"]
      ] %>
      <% stats.each_with_index do |(label, value, sub), i| %>
        <div style="padding: 28px 24px; <%= 'border-left: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);' unless i == 0 %> background: var(--paper);">
          <span class="font-mono-label"><%= label %></span>
          <div style="font-family:'Fraunces',serif; font-size: clamp(36px, 4vw, 56px); font-weight: 400; letter-spacing: -0.03em; line-height: 0.95; font-variation-settings:'opsz' 96; margin-top: 12px;">
            <% if value.match?(/^[+\-]?\d/) %><em style="font-style: italic; color: var(--accent);"><%= value %></em><% else %><%= value %><% end %>
          </div>
          <p style="font-size: 13px; color: var(--muted); margin-top: 8px; font-family:'Fraunces',serif; font-weight: 300; font-style: italic; font-variation-settings:'opsz' 24;"><%= sub %></p>
        </div>
      <% end %>
    </div>

    <!-- Quick Actions -->
    <div style="margin-bottom: 56px;">
      <div style="display: flex; align-items: end; justify-content: space-between; margin-bottom: 24px;">
        <div>
          <span class="font-mono-label">01 / Quick actions</span>
          <h2 class="font-display" style="font-size: 32px; line-height: 1; margin-top: 6px;">What's next?</h2>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;" class="actions-grid">
        <% [
          [new_resume_wizard_path, "Build resume", "Create from scratch with AI"],
          [new_resume_path, "Upload resume", "Optimize for any job posting"],
          [(current_user.resumes.any? ? new_resume_cover_letter_path(current_user.resumes.recent.first) : new_resume_path), "Write cover letter", current_user.resumes.any? ? "Tailored to the job" : "Upload a resume first"],
          [billing_index_path, "Billing & credits", "Manage subscription and packs"]
        ].each do |path, title, sub| %>
          <%= link_to path, style: "display: flex; flex-direction: column; gap: 12px; padding: 22px 20px; background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 6px; text-decoration: none; color: var(--ink); transition: background .15s, border-color .15s; min-height: 140px;",
              onmouseover: "this.style.background='var(--paper-2)'; this.style.borderColor='var(--ink)'", onmouseout: "this.style.background='var(--paper)'; this.style.borderColor='color-mix(in oklab, var(--ink) 12%, transparent)'" do %>
            <span class="font-mono-label" style="color: var(--accent);">→</span>
            <div style="margin-top: auto;">
              <p style="font-family:'Fraunces',serif; font-size: 19px; font-weight: 500; letter-spacing: -0.01em; font-variation-settings:'opsz' 24;"><%= title %></p>
              <p style="font-size: 13px; color: var(--muted); margin-top: 4px; line-height: 1.4;"><%= sub %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Locked premium tools -->
    <% unless current_user.has_premium_subscription? %>
      <div style="margin-bottom: 56px;">
        <div style="margin-bottom: 24px;">
          <span class="font-mono-label">02 / Premium</span>
          <h2 class="font-display" style="font-size: 32px; line-height: 1; margin-top: 6px;">Tools to <em>unlock</em>.</h2>
        </div>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;" class="locked-grid">
          <% [
            [interview_preps_path, "AI Interview Prep", "STAR-method answers for any role"],
            [linkedin_optimizations_path, "LinkedIn Optimization", "AI-powered profile rewrite"],
            [scraped_jobs_path, "Automated Job Scraper", "AI finds jobs matching your skills"]
          ].each do |path, title, sub| %>
            <%= link_to path, style: "position: relative; display: flex; flex-direction: column; gap: 14px; padding: 24px; background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 6px; text-decoration: none; color: var(--ink); transition: all .15s; min-height: 160px;",
                onmouseover: "this.style.background='var(--paper-2)'", onmouseout: "this.style.background='var(--paper)'" do %>
              <span class="font-mono-label" style="position: absolute; top: 16px; right: 16px; color: var(--accent);">Premium</span>
              <span class="font-mono-label">Locked</span>
              <div style="margin-top: auto;">
                <p style="font-family:'Fraunces',serif; font-size: 21px; font-weight: 500; letter-spacing: -0.01em; font-variation-settings:'opsz' 24;"><%= title %></p>
                <p style="font-size: 13px; color: var(--muted); margin-top: 4px; line-height: 1.45;"><%= sub %></p>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Job scraper widget (premium) -->
    <% if current_user.has_premium_subscription? %>
      <% scraped = current_user.scraped_jobs.not_hidden.high_match.limit(3) %>
      <div style="margin-bottom: 56px;">
        <div style="display: flex; align-items: end; justify-content: space-between; margin-bottom: 24px;">
          <div>
            <span class="font-mono-label">03 / Scraped jobs</span>
            <h2 class="font-display" style="font-size: 32px; line-height: 1; margin-top: 6px;">Latest <em>matches</em>.</h2>
          </div>
          <%= link_to scraped_jobs_path, style: "font-size: 13px; color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--ink);" do %>View all →<% end %>
        </div>
        <% if scraped.any? %>
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;" class="scraped-grid">
            <% scraped.each do |job| %>
              <div style="padding: 22px 20px; background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 6px;">
                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px;">
                  <span class="font-mono-label" style="color: var(--accent);"><%= job.match_score %>% match</span>
                  <% if job.remote? %><span class="font-mono-label">Remote</span><% end %>
                </div>
                <p style="font-family:'Fraunces',serif; font-size: 17px; font-weight: 500; letter-spacing: -0.01em; font-variation-settings:'opsz' 24;"><%= job.role %></p>
                <p style="font-size: 13px; color: var(--muted); margin-top: 4px; font-family:'Fraunces',serif; font-style: italic; font-weight: 300;"><%= job.company_name %></p>
                <% if job.location.present? %><p style="font-size: 12px; color: var(--muted); margin-top: 2px;"><%= job.location %></p><% end %>
                <%= link_to scraped_job_path(job), style: "font-size: 13px; color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--ink); display: inline-block; margin-top: 14px;" do %>View →<% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div style="padding: 32px; background: var(--paper); border: 1px dashed color-mix(in oklab, var(--ink) 18%, transparent); border-radius: 6px; text-align: center;">
            <p style="font-family:'Fraunces',serif; font-size: 17px; font-style: italic; color: var(--muted); margin-bottom: 14px;">No scraped jobs yet — configure your scraper to begin.</p>
            <%= link_to "Set up scraper", settings_scraped_jobs_path, class: "btn-outline" %>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Recent activity -->
    <div>
      <div style="margin-bottom: 24px;">
        <span class="font-mono-label">Latest</span>
        <h2 class="font-display" style="font-size: 32px; line-height: 1; margin-top: 6px;">Recent <em>activity</em>.</h2>
      </div>

      <% if @recent_activity.any? %>
        <div style="background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 6px; overflow: hidden;">
          <% @recent_activity.each_with_index do |activity, i| %>
            <div style="display: flex; align-items: center; justify-content: space-between; padding: 18px 22px; <%= 'border-top: 1px solid color-mix(in oklab, var(--ink) 10%, transparent);' if i > 0 %>">
              <div style="display: flex; align-items: center; gap: 16px; min-width: 0;">
                <span class="font-mono-label" style="color: var(--accent); flex-shrink: 0; min-width: 60px;">
                  <%= activity[:type] == "resume" ? "Resume" : "Cover" %>
                </span>
                <div style="min-width: 0;">
                  <p style="font-family:'Fraunces',serif; font-size: 16px; font-weight: 500; letter-spacing: -0.01em; font-variation-settings:'opsz' 24; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= activity[:title] %></p>
                  <p style="font-size: 12px; color: var(--muted); margin-top: 2px;">
                    <%= activity[:action] %> · <%= time_ago_in_words(activity[:date]) %> ago
                  </p>
                </div>
              </div>
              <% target = activity[:type] == "resume" ? resume_path(activity[:record]) : resume_cover_letter_path(activity[:record].resume, activity[:record]) %>
              <%= link_to target, style: "font-size: 13px; color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--ink); flex-shrink: 0;" do %>View<% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div style="padding: 56px 32px; background: var(--paper); border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent); border-radius: 6px; text-align: center;">
          <span class="font-mono-label">Empty</span>
          <h3 class="font-display" style="font-size: 28px; margin-top: 8px;">Nothing yet.</h3>
          <p style="font-family:'Fraunces',serif; font-style: italic; color: var(--muted); font-size: 16px; font-weight: 300; margin: 8px 0 24px;">Upload your first resume to get started.</p>
          <%= link_to "Upload resume", new_resume_path, class: "btn-ink" %>
        </div>
      <% end %>
    </div>
  </main>
</div>

<style>
  @media (max-width: 960px){
    .stats-grid{grid-template-columns: repeat(2, 1fr) !important;}
    .stats-grid > div:nth-child(odd){border-left: none !important;}
    .stats-grid > div:nth-child(n+3){border-top: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);}
    .actions-grid{grid-template-columns: repeat(2, 1fr) !important;}
    .locked-grid, .scraped-grid{grid-template-columns: 1fr !important;}
  }
  @media (max-width: 600px){
    .stats-grid{grid-template-columns: 1fr !important;}
    .stats-grid > div{border-left: none !important; border-top: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);}
    .stats-grid > div:first-child{border-top: none;}
    .actions-grid{grid-template-columns: 1fr !important;}
  }
</style>
